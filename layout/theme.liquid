<!doctype html>
<html
  lang="{{ request.locale.iso_code }}"
  dir="{% if request.locale.iso_code == 'ar' %}rtl{% else %}ltr{% endif %}"
  class="no-js"
  data-asset-base="{{ '' | asset_url }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="{{ settings.color_background | default: '#ffffff' }}">

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
    <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 192 }}">
  {%- endif -%}

  <title>
    {%- if template == 'index' -%}
      {{ shop.name }}{% if page_title != shop.name %} — {{ page_title }}{% endif %}
    {%- else -%}
      {{ page_title }}{% if current_tags %} — {{ current_tags | join: ', ' }}{% endif %} — {{ shop.name }}
    {%- endif -%}
  </title>

  {%- if page_description != blank -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {%- comment -%} Resource hints {%- endcomment -%}
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <link rel="dns-prefetch" href="https://cdn.shopify.com">
  <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>

  {%- comment -%} Fonts — preload only weights used; font-display: swap {%- endcomment -%}
  {%- unless settings.font_heading.system? -%}
    <link rel="preload" as="font" type="font/woff2" href="{{ settings.font_heading | font_url }}" crossorigin>
  {%- endunless -%}
  {%- unless settings.font_body.system? -%}
    <link rel="preload" as="font" type="font/woff2" href="{{ settings.font_body | font_url }}" crossorigin>
  {%- endunless -%}

  <style>
    {{ settings.font_heading | font_face: font_display: 'swap' }}
    {{ settings.font_body | font_face: font_display: 'swap' }}
  </style>

  {%- comment -%}
    Critical CSS — async-loaded with high priority. Shopify Liquid cannot read
    asset file contents inline at runtime, so we treat critical.css as an early
    blocking stylesheet (very small, ~3KB) and async-load the rest below.
  {%- endcomment -%}
  <link rel="stylesheet" href="{{ 'critical.css' | asset_url }}">

  {%- comment -%} LCP image preload — homepage hero {%- endcomment -%}
  {%- if template.name == 'index' -%}
    {%- for section in template.sections -%}
      {%- if section.type == 'hero' and section.settings.image != blank -%}
        <link
          rel="preload"
          as="image"
          fetchpriority="high"
          href="{{ section.settings.image | image_url: width: 1920 }}"
          imagesrcset="{{ section.settings.image | image_url: width: 750 }} 750w, {{ section.settings.image | image_url: width: 1100 }} 1100w, {{ section.settings.image | image_url: width: 1500 }} 1500w, {{ section.settings.image | image_url: width: 1920 }} 1920w"
          imagesizes="100vw">
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}

  {%- comment -%} Async CSS — preload pattern with noscript fallback {%- endcomment -%}
  <link rel="preload" href="{{ 'base.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <link rel="preload" href="{{ 'components.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <link rel="preload" href="{{ 'templates.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <link rel="preload" href="{{ 'motion.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript>
    <link rel="stylesheet" href="{{ 'base.css' | asset_url }}">
    <link rel="stylesheet" href="{{ 'components.css' | asset_url }}">
    <link rel="stylesheet" href="{{ 'templates.css' | asset_url }}">
    <link rel="stylesheet" href="{{ 'motion.css' | asset_url }}">
  </noscript>

  {%- comment -%} Analytics config first, then head tags {%- endcomment -%}
  {%- render 'analytics-config' -%}
  {%- render 'analytics-head' -%}

  {%- comment -%} SEO {%- endcomment -%}
  {%- render 'meta-tags' -%}
  {%- render 'structured-data' -%}

  {%- comment -%} Theme settings exposed to JS {%- endcomment -%}
  <script>
    window.themeSettings = {
      cartType: {{ settings.cart_type | default: 'drawer' | json }},
      currency: {{ cart.currency.iso_code | json }},
      moneyFormat: {{ shop.money_format | json }},
      moneyWithCurrencyFormat: {{ shop.money_with_currency_format | json }},
      locale: {{ request.locale.iso_code | json }},
      country: {{ localization.country.iso_code | json }},
      freeShippingThreshold: {{ settings.free_shipping_threshold | default: 0 | json }},
      lowStockThreshold: {{ settings.low_stock_threshold | default: 10 | json }},
      enableQuickView: {{ settings.enable_quick_view | json }},
      enableRecentlyViewed: {{ settings.enable_recently_viewed | json }},
      enableBackToTop: {{ settings.enable_back_to_top | json }},
      enableStickyCart: {{ settings.enable_sticky_cart | json }},
      enablePredictiveSearch: {{ settings.enable_predictive_search | json }},
      routes: {
        root: {{ routes.root_url | json }},
        cart: {{ routes.cart_url | json }},
        cartAdd: {{ routes.cart_add_url | json }},
        cartChange: {{ routes.cart_change_url | json }},
        cartUpdate: {{ routes.cart_update_url | json }},
        predictiveSearch: {{ routes.predictive_search_url | json }},
        search: {{ routes.search_url | json }},
        account: {{ routes.account_url | json }},
        accountLogin: {{ routes.account_login_url | json }}
      }
    };
  </script>

  {{ content_for_header }}
</head>

<body
  class="template-{{ template.name | replace: '.', '-' | handle }}{% if template.suffix %} template-suffix-{{ template.suffix }}{% endif %}"
  data-cart-type="{{ settings.cart_type | default: 'drawer' }}"
  data-template="{{ template.name }}">

  <a class="skip-to-content" href="#main">{{ 'general.skip_to_content' | t }}</a>

  {% sections 'header-group' %}

  <main id="main" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  {%- comment -%} Global overlays — rendered once {%- endcomment -%}
  {% section 'search-modal' %}

  {%- if settings.cart_type == 'drawer' -%}
    {% section 'cart-drawer' %}
  {%- endif -%}

  {% section 'exit-intent-modal' %}
  {% section 'recently-sold-toast' %}

  {%- if settings.enable_back_to_top -%}
    {% section 'back-to-top' %}
  {%- endif -%}

  {%- comment -%} Theme JS — single deferred entry, lazy-loads modules {%- endcomment -%}
  <script src="{{ 'theme.js' | asset_url }}" type="module" defer></script>

  <script>document.documentElement.classList.remove('no-js');</script>
</body>
</html>

{
    "sections": {
        "announcement-bar": {
            "type": "announcement-bar",
            "settings": {
                "show_bar": true,
                "text": "🎉 Free shipping on orders over $50",
                "bg_color": "#1a1a1a",
                "text_color": "#ffffff"
            }
        },
        "hero-banner": {
            "type": "hero-banner",
            "settings": {
                "heading": "Welcome to Zelexto",
                "subheading": "Premium products, exceptional experience.",
                "button_label": "Shop Now",
                "full_height": true,
                "enable_animation": true
            }
        },
        "story-intro": {
            "type": "story-intro",
            "settings": {
                "heading": "Our Story",
                "enable_animation": true
            }
        },
        "story-product-showcase": {
            "type": "story-product-showcase",
            "settings": {
                "heading": "Featured Products",
                "products_to_show": 4,
                "show_view_all": true,
                "enable_animation": true
            }
        },
        "story-statistics": {
            "type": "story-statistics",
            "settings": {
                "heading": "By the Numbers",
                "enable_animation": true
            },
            "blocks": {
                "stat-1": {
                    "type": "stat",
                    "settings": {
                        "number": 50000,
                        "suffix": "+",
                        "label": "Happy customers"
                    }
                },
                "stat-2": {
                    "type": "stat",
                    "settings": {
                        "number": 4.9,
                        "suffix": "★",
                        "label": "Average rating"
                    }
                },
                "stat-3": {
                    "type": "stat",
                    "settings": {
                        "number": 120,
                        "suffix": "+",
                        "label": "Countries"
                    }
                },
                "stat-4": {
                    "type": "stat",
                    "settings": {
                        "number": 99,
                        "suffix": "%",
                        "label": "Satisfaction"
                    }
                }
            },
            "blocks_order": [
                "stat-1",
                "stat-2",
                "stat-3",
                "stat-4"
            ]
        },
        "story-feature": {
            "type": "story-feature",
            "settings": {
                "heading": "Why Zelexto?",
                "image_side": "left",
                "enable_animation": true
            },
            "blocks": {
                "f1": {
                    "type": "feature_item",
                    "settings": {
                        "icon": "truck",
                        "label": "Fast Shipping",
                        "text": "Orders ship within 24 hours."
                    }
                },
                "f2": {
                    "type": "feature_item",
                    "settings": {
                        "icon": "shield",
                        "label": "Secure Payments",
                        "text": "256-bit SSL encryption."
                    }
                },
                "f3": {
                    "type": "feature_item",
                    "settings": {
                        "icon": "refresh",
                        "label": "Easy Returns",
                        "text": "30-day hassle-free returns."
                    }
                }
            },
            "blocks_order": [
                "f1",
                "f2",
                "f3"
            ]
        },
        "story-cta": {
            "type": "story-cta",
            "settings": {
                "heading": "Ready to Start?",
                "subheading": "Join thousands of happy customers.",
                "button_label": "Shop Now",
                "show_trust_badges": true,
                "enable_animation": true
            }
        },
        "footer": {
            "type": "footer",
            "settings": {
                "show_newsletter": true,
                "show_payment_icons": true
            }
        }
    },
    "order": [
        "announcement-bar",
        "hero-banner",
        "story-intro",
        "story-product-showcase",
        "story-statistics",
        "story-feature",
        "story-cta",
        "footer"
    ]
}
{%- liquid
  assign speed = section.settings.speed | default: 40
  assign bg = section.settings.bg | default: 'surface'
-%}

<section class="marquee marquee--{{ bg }} section" data-section-id="{{ section.id }}">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <p class="marquee__heading">{{ section.settings.heading }}</p>
    {%- endif -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="marquee__track-wrap" aria-hidden="false">
      <div class="marquee__track" style="--marquee-duration: {{ speed }}s;">
        {%- for n in (1..2) -%}
          <ul class="marquee__list" role="list" {% if n == 2 %}aria-hidden="true"{% endif %}>
            {%- for block in section.blocks -%}
              <li class="marquee__item" {{ block.shopify_attributes }}>
                {%- if block.settings.url != blank -%}
                  <a href="{{ block.settings.url }}" target="_blank" rel="noopener" aria-label="{{ block.settings.alt | default: 'Brand' }}">
                {%- endif -%}
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 240 }}"
                      srcset="{{ block.settings.image | image_url: width: 160 }} 1x, {{ block.settings.image | image_url: width: 320 }} 2x"
                      alt="{{ block.settings.alt | escape | default: 'Brand logo' }}"
                      width="120"
                      height="40"
                      loading="lazy"
                      decoding="async"
                      class="marquee__img">
                  {%- elsif block.settings.text != blank -%}
                    <span class="marquee__text">{{ block.settings.text }}</span>
                  {%- endif -%}
                {%- if block.settings.url != blank -%}
                  </a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

<style>
  #shopify-section-{{ section.id }} .marquee--bg{background:var(--c-bg)}
  #shopify-section-{{ section.id }} .marquee--surface{background:var(--c-surface)}
  #shopify-section-{{ section.id }} .marquee--elev{background:var(--c-elev)}
  #shopify-section-{{ section.id }} .marquee--ink{background:var(--c-ink);color:var(--c-bg)}

  #shopify-section-{{ section.id }} .marquee__heading{
    text-align:center;font-size:var(--fs-12);
    letter-spacing:.12em;text-transform:uppercase;
    color:var(--c-ink-muted);margin-bottom:var(--s-5);
  }
  #shopify-section-{{ section.id }} .marquee--ink .marquee__heading{color:rgba(255,255,255,.7)}

  #shopify-section-{{ section.id }} .marquee__track-wrap{
    overflow:hidden;mask-image:linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    -webkit-mask-image:linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  #shopify-section-{{ section.id }} .marquee__track{
    display:flex;width:max-content;
    animation:marquee-scroll var(--marquee-duration, 40s) linear infinite;
  }
  #shopify-section-{{ section.id }} .marquee__list{
    display:flex;align-items:center;gap:var(--s-7);
    list-style:none;padding:0 var(--s-5);margin:0;
  }
  #shopify-section-{{ section.id }} .marquee__item{
    display:inline-flex;align-items:center;justify-content:center;
    height:48px;
  }
  #shopify-section-{{ section.id }} .marquee__img{
    height:32px;width:auto;
    opacity:.65;filter:grayscale(1);
    transition:opacity var(--dur-fast) var(--ease-standard),filter var(--dur-fast) var(--ease-standard);
  }
  #shopify-section-{{ section.id }} .marquee__item:hover .marquee__img{opacity:1;filter:none}
  #shopify-section-{{ section.id }} .marquee__text{
    font-size:var(--fs-19);font-weight:var(--weight-semibold);
    letter-spacing:.04em;color:var(--c-ink-muted);
    text-transform:uppercase;
  }

  @keyframes marquee-scroll{
    from{transform:translateX(0)}
    to{transform:translateX(-50%)}
  }
  @media (prefers-reduced-motion:reduce){
    #shopify-section-{{ section.id }} .marquee__track{animation:none}
  }
</style>

{% schema %}
{
  "name": "Marquee",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "As featured in" },
    { "type": "range", "id": "speed", "label": "Animation speed (seconds per loop)", "min": 20, "max": 120, "step": 5, "default": 40 },
    {
      "type": "select", "id": "bg", "label": "Background",
      "options": [
        { "value": "bg",      "label": "White" },
        { "value": "surface", "label": "Surface" },
        { "value": "elev",    "label": "Elevated" },
        { "value": "ink",     "label": "Dark" }
      ],
      "default": "surface"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "text", "label": "Or text (used if no image)" },
        { "type": "text", "id": "alt", "label": "Alt text" },
        { "type": "url",  "id": "url", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 24,
  "presets": [
    {
      "name": "Marquee",
      "blocks": [
        { "type": "logo", "settings": { "text": "Vogue" } },
        { "type": "logo", "settings": { "text": "Forbes" } },
        { "type": "logo", "settings": { "text": "GQ" } },
        { "type": "logo", "settings": { "text": "Wired" } },
        { "type": "logo", "settings": { "text": "Fast Company" } },
        { "type": "logo", "settings": { "text": "Mint" } }
      ]
    }
  ]
}
{% endschema %}

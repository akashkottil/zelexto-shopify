{%- comment -%}
  Marquee — looping press / brand strip with logos.
{%- endcomment -%}

{%- liquid
  assign theme = section.settings.theme | default: 'light'
  assign speed = section.settings.speed | default: 40
-%}

<section class="marquee marquee--{{ theme }}" data-section-id="{{ section.id }}">
  <div class="container">
    {%- if section.settings.label != blank -%}
      <p class="marquee__label" data-reveal="up">{{ section.settings.label }}</p>
    {%- endif -%}
  </div>

  <div class="marquee__viewport" aria-hidden="true">
    <div class="marquee__track" style="--marquee-speed:{{ speed }}s;">
      {%- for n in (1..2) -%}
        <ul class="marquee__row" role="list">
          {%- for block in section.blocks -%}
            <li class="marquee__item" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                {%- render 'responsive-image',
                    image: block.settings.image,
                    alt: block.settings.label,
                    sizes: '160px',
                    widths: '160,240,320',
                    loading: 'lazy',
                    class: 'marquee__logo' -%}
              {%- else -%}
                <span class="marquee__text">{{ block.settings.label | default: 'Demo brand' }}</span>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} { display: block; }

  .marquee {
    padding-block: clamp(var(--s-7), 8vh, var(--s-9));
    background: var(--c-bg);
    color: var(--c-ink);
    overflow: hidden;
  }
  .marquee--soft { background: var(--c-surface); }
  .marquee--dark { background: var(--c-bg-inv); color: var(--c-ink-inv); }

  .marquee__label {
    margin: 0 0 var(--s-6);
    text-align: center;
    font-size: var(--fs-14);
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-ink-muted);
  }
  .marquee--dark .marquee__label { color: var(--c-ink-muted-inv); }

  .marquee__viewport {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
            mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  .marquee__track {
    display: flex;
    gap: var(--s-9);
    width: max-content;
    animation: marquee-scroll var(--marquee-speed, 40s) linear infinite;
  }
  .marquee__row {
    display: flex;
    align-items: center;
    gap: var(--s-9);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .marquee__item {
    flex: 0 0 auto;
    color: var(--c-ink-muted);
    font-family: var(--font-display);
    font-size: var(--fs-21);
    font-weight: var(--weight-medium);
    letter-spacing: -0.01em;
    opacity: 0.7;
    transition: opacity var(--dur-base) var(--ease-soft);
  }
  .marquee__item:hover { opacity: 1; color: var(--c-ink); }
  .marquee--dark .marquee__item:hover { color: var(--c-ink-inv); }
  .marquee__logo {
    height: 32px;
    width: auto;
    display: block;
    filter: grayscale(100%);
    opacity: 0.6;
    transition: opacity var(--dur-base) var(--ease-soft);
  }
  .marquee__item:hover .marquee__logo { opacity: 1; }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee__track { animation: none; }
  }
</style>

{% schema %}
{
  "name": "Marquee",
  "settings": [
    { "type": "select", "id": "theme", "label": "Theme",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "soft",  "label": "Soft" },
        { "value": "dark",  "label": "Dark" }
      ], "default": "soft" },
    { "type": "text",  "id": "label", "label": "Caption", "default": "As featured in" },
    { "type": "range", "id": "speed", "label": "Scroll speed", "min": 20, "max": 120, "step": 5, "unit": "s", "default": 40 }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Logo (PNG/SVG)" },
        { "type": "text",         "id": "label", "label": "Fallback text",  "default": "Demo brand" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee",
      "blocks": [
        { "type": "logo", "settings": { "label": "VOGUE"      } },
        { "type": "logo", "settings": { "label": "WIRED"      } },
        { "type": "logo", "settings": { "label": "Forbes"     } },
        { "type": "logo", "settings": { "label": "Bloomberg"  } },
        { "type": "logo", "settings": { "label": "TechCrunch" } },
        { "type": "logo", "settings": { "label": "GQ"         } }
      ]
    }
  ]
}
{% endschema %}

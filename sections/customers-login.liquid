{% comment %}
  ZELEXTO THEME — sections/customers-login.liquid
  Customer login page with optional social proof.
{% endcomment %}

<div class="auth-page section">
  <div class="auth-page__container">

    <div class="auth-card">
      <div class="auth-card__header">
        {%- render 'icon', name: 'user', size: 32 -%}
        <h1 class="auth-card__title">{{ 'customer.login.title' | t | default: 'Sign in' }}</h1>
        <p class="auth-card__sub">{{ 'customer.login.subtitle' | t | default: 'Welcome back!' }}</p>
      </div>

      {%- form 'customer_login', class: 'auth-form' -%}

        {%- if form.errors -%}
          <div class="auth-form__errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="form-field">
          <label class="form-label" for="CustomerEmail">{{ 'customer.login.email' | t | default: 'Email' }}</label>
          <input
            type="email"
            name="customer[email]"
            id="CustomerEmail"
            class="form-input"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            required>
        </div>

        <div class="form-field">
          <label class="form-label" for="CustomerPassword">
            {{ 'customer.login.password' | t | default: 'Password' }}
            <a href="{{ routes.account_recover_url }}" class="form-label__link">{{ 'customer.login.forgot_password' | t | default: 'Forgot?' }}</a>
          </label>
          <input
            type="password"
            name="customer[password]"
            id="CustomerPassword"
            class="form-input"
            autocomplete="current-password"
            required>
        </div>

        <button type="submit" class="btn btn--primary btn--full btn--lg">
          {{ 'customer.login.submit' | t | default: 'Sign in' }}
        </button>

        <p style="text-align:center; font-size:var(--font-size-sm); color:var(--color-text-secondary);">
          {{ 'customer.login.no_account' | t | default: "Don't have an account?" }}
          <a href="{{ routes.account_register_url }}" class="auth-link">{{ 'customer.register.title' | t | default: 'Create one' }}</a>
        </p>

      {%- endform -%}
    </div>

  </div>
</div>

{%- render 'customer-auth-styles' -%}

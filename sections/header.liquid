{%- liquid
  assign sticky = section.settings.header_sticky
  assign transparent = section.settings.header_transparent
  assign logo_width = section.settings.logo_width | default: 120
  assign nav_menu = linklists[section.settings.nav_menu] | default: linklists['main-menu']
-%}

<header
  class="site-header{% if sticky %} site-header--sticky{% endif %}{% if transparent %} site-header--transparent{% endif %}"
  id="site-header"
  role="banner"
  data-section-id="{{ section.id }}">

  <div class="container">
    <div class="site-header__inner">

      {%- comment -%} Hamburger — mobile {%- endcomment -%}
      <button
        type="button"
        class="header-icon-btn site-header__hamburger"
        aria-label="{{ 'navigation.open_menu' | t }}"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-mobile-menu-open>
        {%- render 'icon', name: 'menu', class: 'icon' -%}
      </button>

      {%- comment -%} Logo {%- endcomment -%}
      <a href="{{ routes.root_url }}" class="site-header__brand" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          {%- assign logo_height = section.settings.logo.height | times: logo_width | divided_by: section.settings.logo.width -%}
          <img
            src="{{ section.settings.logo | image_url: width: logo_width }}"
            srcset="{{ section.settings.logo | image_url: width: logo_width }} 1x, {{ section.settings.logo | image_url: width: logo_width | times: 2 }} 2x"
            alt="{{ shop.name | escape }}"
            width="{{ logo_width }}"
            height="{{ logo_height }}"
            loading="eager"
            fetchpriority="high"
            decoding="sync">
        {%- else -%}
          <span class="site-header__brand-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      {%- comment -%} Desktop navigation {%- endcomment -%}
      {%- render 'navigation-menu', menu: nav_menu -%}

      {%- comment -%} Header icons — search, account, cart, locale {%- endcomment -%}
      {%- render 'header-icons',
        show_currency_selector: section.settings.show_currency_selector,
        show_locale_selector: section.settings.show_locale_selector
      -%}

    </div>
  </div>
</header>

{%- comment -%} Mobile menu — outside header for stacking context {%- endcomment -%}
{%- render 'mobile-menu', menu: nav_menu -%}

<style>
  .site-header{
    position:relative;width:100%;z-index:var(--z-sticky);
    background:rgba(255,255,255,.92);
    -webkit-backdrop-filter:saturate(180%) blur(20px);
    backdrop-filter:saturate(180%) blur(20px);
    border-bottom:1px solid var(--c-line);
    transition:background-color var(--dur-base) var(--ease-standard),
               border-color var(--dur-base) var(--ease-standard);
  }
  .site-header--sticky{position:sticky;top:0}
  .site-header--transparent{
    position:absolute;left:0;right:0;
    background:transparent;border-bottom-color:transparent;color:#fff;
  }
  .site-header--transparent.is-scrolled{
    position:sticky;
    background:rgba(255,255,255,.92);
    border-bottom-color:var(--c-line);
    color:var(--c-ink);
  }
  .site-header__inner{
    display:flex;align-items:center;gap:var(--s-4);
    height:56px;
  }
  @media (min-width:769px){
    .site-header__inner{height:60px}
  }
  .site-header__brand{
    flex-shrink:0;display:flex;align-items:center;
    font-family:var(--font-display);font-weight:var(--weight-semibold);
    font-size:var(--fs-19);letter-spacing:var(--tracking-display);
    color:var(--c-ink);text-decoration:none;
  }
  .site-header--transparent:not(.is-scrolled) .site-header__brand{color:#fff}
  .site-header__brand img{display:block;max-height:32px;width:auto}
  .site-header__hamburger{display:inline-flex}
  @media (min-width:769px){
    .site-header__hamburger{display:none}
  }
  /* center nav, push icons right */
  .nav-desktop{flex:1;justify-content:center}
  .header-icons{flex-shrink:0;margin-left:auto}
  /* mobile: push brand to center, icons right */
  @media (max-width:768px){
    .site-header__brand{margin-inline:auto}
    .site-header__hamburger + .site-header__brand{margin-left:0}
  }
</style>

<script>
  (function(){
    'use strict';
    var header = document.getElementById('site-header');
    if(!header) return;
    if(!header.classList.contains('site-header--sticky') && !header.classList.contains('site-header--transparent')) return;
    var sentinel = document.createElement('div');
    sentinel.style.cssText = 'position:absolute;top:0;left:0;width:1px;height:1px;pointer-events:none;';
    document.body.prepend(sentinel);
    var io = new IntersectionObserver(function(entries){
      header.classList.toggle('is-scrolled', !entries[0].isIntersecting);
    }, { threshold: 0 });
    io.observe(sentinel);
  })();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "range", "id": "logo_width", "label": "Logo width", "min": 60, "max": 240, "step": 10, "unit": "px", "default": 120 },
    { "type": "link_list", "id": "nav_menu", "label": "Navigation", "default": "main-menu" },
    { "type": "checkbox", "id": "header_sticky", "label": "Sticky header", "default": true },
    { "type": "checkbox", "id": "header_transparent", "label": "Transparent over hero", "default": false },
    { "type": "header", "content": "Localization" },
    { "type": "checkbox", "id": "show_currency_selector", "label": "Show currency selector", "default": true },
    { "type": "checkbox", "id": "show_locale_selector", "label": "Show language selector", "default": true }
  ]
}
{% endschema %}

{%- if section.settings.show_bar and section.settings.text != blank -%}
<div class="announcement-bar" data-module="announcement-bar" data-section-id="{{ section.id }}" role="region" aria-label="Announcement">
  <div class="announcement-bar__inner">
    {%- if section.settings.url != blank -%}
      <a href="{{ section.settings.url }}" class="announcement-bar__text">{{ section.settings.text | escape }}</a>
    {%- else -%}
      <span class="announcement-bar__text">{{ section.settings.text | escape }}</span>
    {%- endif -%}
  </div>

  {%- if section.settings.show_dismiss -%}
    <button
      type="button"
      class="announcement-bar__close"
      aria-label="{{ 'general.close' | t }}"
      data-announcement-close>
      {%- render 'icon', name: 'close', class: 'icon icon--xs' -%}
    </button>
  {%- endif -%}
</div>

<style>
  .announcement-bar{
    display:flex;align-items:center;justify-content:center;
    min-height:36px;padding:6px 16px;position:relative;
    background:{{ section.settings.bg_color | default: '#1d1d1f' }};
    color:{{ section.settings.text_color | default: '#ffffff' }};
    font-size:var(--fs-14);line-height:1.3;text-align:center;
  }
  .announcement-bar__inner{flex:1;text-align:center}
  .announcement-bar__text{
    display:inline-block;color:inherit;
    font-weight:var(--weight-medium);letter-spacing:.01em;
  }
  a.announcement-bar__text{text-decoration:underline;text-underline-offset:2px}
  .announcement-bar__close{
    position:absolute;right:var(--s-3);top:50%;transform:translateY(-50%);
    width:32px;height:32px;display:inline-flex;align-items:center;justify-content:center;
    color:inherit;opacity:.78;border-radius:var(--radius-pill);
    transition:opacity var(--dur-fast) var(--ease-standard);
  }
  .announcement-bar__close:hover{opacity:1;background:rgba(255,255,255,.08)}
  [dir="rtl"] .announcement-bar__close{right:auto;left:var(--s-3)}
</style>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "checkbox", "id": "show_bar", "label": "Show announcement bar", "default": true },
    { "type": "text", "id": "text", "label": "Text", "default": "Free shipping on orders over ₹999. Cash on delivery available pan-India." },
    { "type": "url", "id": "url", "label": "Link" },
    { "type": "checkbox", "id": "show_dismiss", "label": "Allow dismissal", "default": false },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#1d1d1f" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#ffffff" }
  ],
  "presets": [{ "name": "Announcement bar" }]
}
{% endschema %}

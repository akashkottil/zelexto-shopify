{%- comment -%}
  Rich text — large headline + body + optional CTA. Apple-style breathing room.
{%- endcomment -%}

{%- liquid
  assign theme = section.settings.theme | default: 'light'
  assign align = section.settings.text_align | default: 'center'
-%}

<section class="rt rt--{{ theme }} rt--align-{{ align }}" data-section-id="{{ section.id }}">
  <div class="container rt__inner" data-stagger>
    {%- if section.settings.eyebrow != blank -%}
      <p class="rt__eyebrow" data-reveal="up">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="rt__heading" data-reveal="up">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="rt__body" data-reveal="up">{{ section.settings.body }}</div>
    {%- endif -%}
    {%- if section.settings.cta_label != blank -%}
      <div class="rt__cta-wrap" data-reveal="up">
        <a href="{{ section.settings.cta_url | default: '#' }}" class="btn btn--primary">{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} { display: block; }

  .rt {
    padding-block: clamp(var(--s-9), 12vh, var(--s-10));
    background: var(--c-bg);
    color: var(--c-ink);
  }
  .rt--soft { background: var(--c-surface); }
  .rt--dark { background: var(--c-bg-inv); color: var(--c-ink-inv); }

  .rt__inner {
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
  }
  .rt--align-center .rt__inner { margin-inline: auto; text-align: center; align-items: center; }
  .rt--align-left   .rt__inner { text-align: left; align-items: flex-start; }

  .rt__eyebrow {
    margin: 0;
    font-size: var(--fs-14);
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-ink-muted);
  }
  .rt--dark .rt__eyebrow { color: var(--c-ink-muted-inv); }
  .rt__heading {
    margin: 0;
    font-size: clamp(var(--fs-28), 4vw, var(--fs-56));
    font-weight: var(--weight-semibold);
    letter-spacing: -0.022em;
    line-height: 1.06;
    max-width: 22ch;
  }
  .rt__body {
    margin: 0;
    font-size: var(--fs-19);
    line-height: 1.55;
    color: var(--c-ink-muted);
    max-width: 60ch;
  }
  .rt--dark .rt__body { color: var(--c-ink-muted-inv); }
  .rt__cta-wrap { margin-top: var(--s-3); }
  .rt--dark .btn--primary { background: #fff; color: #000; }
  .rt--dark .btn--primary:hover { background: #e8e8ed; }
</style>

{% schema %}
{
  "name": "Rich text",
  "settings": [
    { "type": "select", "id": "theme", "label": "Theme",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "soft",  "label": "Soft" },
        { "value": "dark",  "label": "Dark" }
      ], "default": "light" },
    { "type": "select", "id": "text_align", "label": "Alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" }
      ], "default": "center" },
    { "type": "text",     "id": "eyebrow",   "label": "Eyebrow", "default": "About us" },
    { "type": "text",     "id": "heading",   "label": "Heading", "default": "We make things worth keeping." },
    { "type": "richtext", "id": "body",      "label": "Body",    "default": "<p>Founded on the belief that good design should be felt, not just seen.</p>" },
    { "type": "text",     "id": "cta_label", "label": "CTA label" },
    { "type": "url",      "id": "cta_url",   "label": "CTA URL" }
  ],
  "presets": [
    { "name": "Rich text" }
  ]
}
{% endschema %}

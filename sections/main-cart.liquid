{%- comment -%}
  Zelexto v2 — sections/main-cart.liquid
  Full-page cart. Wrapped in <cart-page> Custom Element so cart.js can
  intercept qty changes and remove buttons via /cart/change.js.
{%- endcomment -%}

<cart-page class="cart" data-module="cart.js">
  <div class="container cart__container">
    {%- if cart.item_count == 0 -%}
      <div class="cart__empty">
        {% render 'icon', name: 'cart' %}
        <h1 class="cart__empty-title">{{ 'cart.empty' | t | default: 'Your bag is empty' }}</h1>
        <p class="cart__empty-sub">{{ 'cart.empty_sub' | t | default: "Items you add will appear here." }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">
          {{ 'cart.empty_cta' | t | default: 'Continue shopping' }}
        </a>
      </div>
    {%- else -%}
      <header class="cart__header">
        {% render 'breadcrumb' %}
        <h1 class="cart__title">
          {{ 'cart.title' | t | default: 'Your bag' }}
          <span class="cart__count">{{ 'cart.items_count' | t: count: cart.item_count }}</span>
        </h1>
      </header>

      {%- if settings.free_shipping_threshold and settings.free_shipping_threshold > 0 -%}
        {% render 'free-shipping-bar' %}
      {%- endif -%}

      <form action="{{ routes.cart_url }}" method="post" novalidate class="cart__form" data-cart-form>
        <div class="cart__layout">
          <div class="cart__items" role="list">
            {%- for item in cart.items -%}
              <div class="cart-line" role="listitem" data-cart-line data-cart-line-key="{{ item.key }}" data-cart-line-index="{{ forloop.index }}">
                <a href="{{ item.url }}" class="cart-line__media aspect" style="aspect-ratio: 1/1;" tabindex="-1">
                  {%- if item.image -%}
                    {% render 'responsive-image',
                       image: item.image,
                       alt: item.image.alt | default: item.title,
                       sizes: '120px',
                       loading: 'lazy',
                       aspect_ratio: '1/1' %}
                  {%- endif -%}
                </a>

                <div class="cart-line__body">
                  <div class="cart-line__head">
                    <div>
                      <a href="{{ item.url }}" class="cart-line__title">{{ item.product.title }}</a>
                      {%- unless item.product.has_only_default_variant -%}
                        <p class="cart-line__variant">{{ item.variant.title }}</p>
                      {%- endunless -%}
                      {%- for property in item.properties -%}
                        {%- if property.last != blank and property.first != "_" -%}
                          <p class="cart-line__property"><span>{{ property.first }}:</span> {{ property.last }}</p>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                    <div class="cart-line__price">
                      {%- if item.original_line_price != item.final_line_price -%}
                        <s class="cart-line__compare" data-money-cents="{{ item.original_line_price }}">{{ item.original_line_price | money }}</s>
                      {%- endif -%}
                      <span data-money-cents="{{ item.final_line_price }}">{{ item.final_line_price | money }}</span>
                    </div>
                  </div>

                  <div class="cart-line__foot">
                    <div class="qty cart-line__qty" role="group" aria-label="{{ 'cart.quantity' | t | default: 'Quantity' }}">
                      <button type="button" class="qty__btn" data-cart-qty-step="-1" data-cart-line-key="{{ item.key }}" aria-label="{{ 'product.decrease_quantity' | t | default: 'Decrease' }}">
                        {% render 'icon', name: 'minus' %}
                      </button>
                      <input
                        type="number"
                        class="qty__input"
                        name="updates[{{ item.key }}]"
                        value="{{ item.quantity }}"
                        min="0"
                        inputmode="numeric"
                        aria-label="{{ item.product.title | escape }} quantity"
                        data-cart-qty-input
                        data-cart-line-key="{{ item.key }}">
                      <button type="button" class="qty__btn" data-cart-qty-step="1" data-cart-line-key="{{ item.key }}" aria-label="{{ 'product.increase_quantity' | t | default: 'Increase' }}">
                        {% render 'icon', name: 'plus' %}
                      </button>
                    </div>

                    <button type="button" class="cart-line__remove btn btn--ghost btn--sm" data-cart-remove data-cart-line-key="{{ item.key }}" aria-label="{{ 'cart.remove_item' | t: title: item.title }}">
                      {% render 'icon', name: 'close' %}
                      <span>{{ 'cart.remove' | t | default: 'Remove' }}</span>
                    </button>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>

          <aside class="cart__summary">
            <div class="cart-summary">
              <h2 class="cart-summary__title">{{ 'cart.summary' | t | default: 'Order summary' }}</h2>

              <dl class="cart-summary__rows">
                <div class="cart-summary__row">
                  <dt>{{ 'cart.subtotal' | t | default: 'Subtotal' }}</dt>
                  <dd data-money-cents="{{ cart.total_price }}" data-cart-subtotal>{{ cart.total_price | money }}</dd>
                </div>
                {%- if cart.cart_level_discount_applications.size > 0 -%}
                  {%- for discount in cart.cart_level_discount_applications -%}
                    <div class="cart-summary__row cart-summary__row--discount">
                      <dt>{{ discount.title }}</dt>
                      <dd>−<span data-money-cents="{{ discount.total_allocated_amount }}">{{ discount.total_allocated_amount | money }}</span></dd>
                    </div>
                  {%- endfor -%}
                {%- endif -%}
                <div class="cart-summary__row cart-summary__row--note">
                  <dt>{{ 'cart.taxes_note' | t | default: 'Taxes & shipping' }}</dt>
                  <dd>{{ 'cart.taxes_at_checkout' | t | default: 'Calculated at checkout' }}</dd>
                </div>
              </dl>

              {% render 'payment-method-selector', context: 'cart', id: 'cart' %}

              {% render 'gst-invoice-field' %}

              {%- if section.settings.show_cart_note | default: settings.cart_notes -%}
                <details class="cart-summary__note">
                  <summary>{{ 'cart.note' | t | default: 'Add a note' }}</summary>
                  <textarea name="note" class="field__textarea" rows="3" placeholder="{{ 'cart.note_placeholder' | t | default: 'Notes about your order (optional)' }}">{{ cart.note }}</textarea>
                </details>
              {%- endif -%}

              <button type="submit" name="checkout" class="btn btn--primary btn--full cart-summary__checkout" data-cart-checkout>
                {{ 'cart.checkout' | t | default: 'Checkout' }} · <span data-money-cents="{{ cart.total_price }}">{{ cart.total_price | money }}</span>
              </button>

              {% render 'payment-badges', context: 'cart' %}
              {% render 'trust-badges' %}

              <a href="{{ routes.all_products_collection_url }}" class="cart-summary__continue">
                {{ 'cart.continue_shopping' | t | default: 'Continue shopping' }}
              </a>
            </div>
          </aside>
        </div>
      </form>
    {%- endif -%}
  </div>
</cart-page>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "class": "section section--cart",
  "settings": [
    { "type": "checkbox", "id": "show_cart_note", "label": "Allow order notes", "default": true }
  ],
  "presets": [{ "name": "Cart page" }]
}
{% endschema %}

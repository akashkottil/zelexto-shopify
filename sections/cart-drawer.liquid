{%- comment -%}
  Zelexto v2 — sections/cart-drawer.liquid
  Slide-out drawer. Wrapped in <cart-drawer> Custom Element. Eager-loaded
  because it must respond instantly when the header cart button fires
  `cart:drawer-open`.
{%- endcomment -%}

<cart-drawer
  class="cart-drawer"
  data-module="cart.js"
  data-module-eager
  aria-hidden="true">

  <div class="cart-drawer__overlay" data-cart-overlay></div>

  <aside
    class="cart-drawer__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="cart-drawer-title"
    tabindex="-1"
    data-cart-panel>

    <header class="cart-drawer__head">
      <h2 id="cart-drawer-title" class="cart-drawer__title">
        {{ 'cart.title' | t | default: 'Your bag' }}
        <span class="cart-drawer__count" data-cart-count>{{ 'cart.items_count' | t: count: cart.item_count }}</span>
      </h2>
      <button type="button" class="cart-drawer__close" data-cart-close aria-label="{{ 'general.close' | t | default: 'Close' }}">
        {% render 'icon', name: 'close' %}
      </button>
    </header>

    {%- if settings.free_shipping_threshold and settings.free_shipping_threshold > 0 -%}
      <div class="cart-drawer__shipping" data-shipping-region>
        {% render 'free-shipping-bar', compact: true %}
      </div>
    {%- endif -%}

    <div class="cart-drawer__body" data-cart-region>
      {%- if cart.item_count == 0 -%}
        <div class="cart-drawer__empty">
          {% render 'icon', name: 'cart' %}
          <p>{{ 'cart.empty' | t | default: 'Your bag is empty' }}</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary" data-cart-close>
            {{ 'cart.empty_cta' | t | default: 'Continue shopping' }}
          </a>
        </div>
      {%- else -%}
        <ul class="cart-drawer__items" role="list" data-cart-lines>
          {%- for item in cart.items -%}
            <li class="cart-line cart-line--compact" data-cart-line data-cart-line-key="{{ item.key }}" data-cart-line-index="{{ forloop.index }}">
              <a href="{{ item.url }}" class="cart-line__media aspect" style="aspect-ratio: 1/1;" tabindex="-1">
                {%- if item.image -%}
                  {% render 'responsive-image',
                     image: item.image,
                     alt: item.image.alt | default: item.title,
                     sizes: '88px',
                     loading: 'lazy',
                     aspect_ratio: '1/1' %}
                {%- endif -%}
              </a>

              <div class="cart-line__body">
                <a href="{{ item.url }}" class="cart-line__title">{{ item.product.title }}</a>
                {%- unless item.product.has_only_default_variant -%}
                  <p class="cart-line__variant">{{ item.variant.title }}</p>
                {%- endunless -%}

                <div class="cart-line__foot">
                  <div class="qty cart-line__qty">
                    <button type="button" class="qty__btn" data-cart-qty-step="-1" data-cart-line-key="{{ item.key }}" aria-label="{{ 'product.decrease_quantity' | t | default: 'Decrease' }}">
                      {% render 'icon', name: 'minus' %}
                    </button>
                    <input
                      type="number"
                      class="qty__input"
                      value="{{ item.quantity }}"
                      min="0"
                      inputmode="numeric"
                      aria-label="{{ item.product.title | escape }} quantity"
                      data-cart-qty-input
                      data-cart-line-key="{{ item.key }}">
                    <button type="button" class="qty__btn" data-cart-qty-step="1" data-cart-line-key="{{ item.key }}" aria-label="{{ 'product.increase_quantity' | t | default: 'Increase' }}">
                      {% render 'icon', name: 'plus' %}
                    </button>
                  </div>
                  <span class="cart-line__price" data-money-cents="{{ item.final_line_price }}">{{ item.final_line_price | money }}</span>
                </div>
              </div>

              <button type="button" class="cart-line__remove" data-cart-remove data-cart-line-key="{{ item.key }}" aria-label="{{ 'cart.remove_item' | t: title: item.title }}">
                {% render 'icon', name: 'close' %}
              </button>
            </li>
          {%- endfor -%}
        </ul>

        {% render 'cart-cross-sell' %}
      {%- endif -%}
    </div>

    {%- if cart.item_count > 0 -%}
      <footer class="cart-drawer__foot">
        {% render 'payment-method-selector', context: 'drawer' %}

        <div class="cart-drawer__totals">
          <span>{{ 'cart.subtotal' | t | default: 'Subtotal' }}</span>
          <span data-cart-subtotal data-money-cents="{{ cart.total_price }}">{{ cart.total_price | money }}</span>
        </div>
        <p class="cart-drawer__taxes">{{ 'cart.taxes_note' | t | default: 'Taxes and shipping calculated at checkout' }}</p>

        <a href="{{ routes.checkout_url }}" class="btn btn--primary btn--full cart-drawer__checkout" data-cart-checkout>
          {{ 'cart.checkout' | t | default: 'Checkout' }}
        </a>
        <a href="{{ routes.cart_url }}" class="cart-drawer__view-cart">
          {{ 'cart.view_cart' | t | default: 'View bag' }}
        </a>

        {% render 'payment-badges', context: 'drawer' %}
      </footer>
    {%- endif -%}
  </aside>
</cart-drawer>

{% schema %}
{
  "name": "Cart drawer",
  "settings": []
}
{% endschema %}

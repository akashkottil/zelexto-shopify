{% comment %}
  ZELEXTO THEME — sections/hero-banner.liquid
  Full-screen hero with image/video/gradient background.
  Headline, subheading, CTA button.
  Hero animations use CSS keyframes (not IntersectionObserver — above fold).
{% endcomment %}

{%- liquid
  assign has_image = false
  if section.settings.image != blank
    assign has_image = true
  endif
  assign has_video = false
  if section.settings.video_url != blank
    assign has_video = true
  endif
  assign enable_anim = section.settings.enable_animation | default: settings.enable_animations
  assign overlay_opacity = section.settings.overlay_opacity | times: 0.01
-%}

<section
  class="hero-banner{% if section.settings.full_height %} hero-banner--full{% else %} hero-banner--auto{% endif %}"
  id="section-{{ section.id }}"
  style="--hero-height: {{ section.settings.min_height }}px;
         --hero-overlay: {{ overlay_opacity }};
         --hero-text-color: {{ section.settings.text_color }};">

  <!-- Background media -->
  <div class="hero-banner__bg">
    {%- if has_image and has_video == false -%}
      <img
        src="{{ section.settings.image | image_url: width: 1920 }}"
        srcset="{{ section.settings.image | image_url: width: 750 }} 750w,
                {{ section.settings.image | image_url: width: 1100 }} 1100w,
                {{ section.settings.image | image_url: width: 1600 }} 1600w,
                {{ section.settings.image | image_url: width: 1920 }} 1920w"
        sizes="100vw"
        alt="{{ section.settings.image.alt | escape | default: section.settings.heading }}"
        width="1920"
        height="{{ 1920 | divided_by: section.settings.image.aspect_ratio | round }}"
        loading="eager"
        decoding="sync"
        fetchpriority="high"
        class="hero-banner__image{% if section.settings.enable_parallax %} animate-parallax{% endif %}"
        {% if section.settings.enable_parallax %}data-parallax="0.2"{% endif %}>

    {%- elsif has_video -%}
      <video
        class="hero-banner__video"
        autoplay
        muted
        loop
        playsinline
        loading="lazy"
        aria-hidden="true">
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>

    {%- else -%}
      <!-- Gradient fallback -->
      <div
        class="hero-banner__gradient{% if section.settings.animate_gradient %} animate-gradient{% endif %}"
        style="background: linear-gradient(135deg, {{ section.settings.gradient_from }}, {{ section.settings.gradient_to }});">
      </div>
    {%- endif -%}

    <!-- Overlay -->
    <div class="hero-banner__overlay" aria-hidden="true"></div>
  </div>

  <!-- Content -->
  <div class="hero-banner__content container">
    <div class="hero-banner__inner" style="text-align: {{ section.settings.text_alignment }};">

      {%- if section.settings.eyebrow != blank -%}
        <p class="hero-banner__eyebrow{% if enable_anim %} animate-hero-headline{% endif %}">
          {{ section.settings.eyebrow }}
        </p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="hero-banner__heading{% if enable_anim %} animate-hero-headline{% endif %}">
          {{ section.settings.heading }}
        </h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="hero-banner__subheading{% if enable_anim %} animate-hero-subhead{% endif %}">
          {{ section.settings.subheading }}
        </p>
      {%- endif -%}

      <div class="hero-banner__cta{% if enable_anim %} animate-hero-cta{% endif %}">
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn--primary btn--xl">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.button_2_label != blank -%}
          <a href="{{ section.settings.button_2_url | default: '#' }}" class="btn btn--secondary btn--xl">
            {{ section.settings.button_2_label }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

<style>
  .hero-banner {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: {{ section.settings.vertical_alignment | default: 'center' }};
    color: var(--hero-text-color, #ffffff);
  }

  .hero-banner--full {
    min-height: 100vh;
    min-height: 100dvh;
  }

  .hero-banner--auto {
    min-height: var(--hero-height, 600px);
  }

  /* Background */
  .hero-banner__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-banner__image,
  .hero-banner__video,
  .hero-banner__gradient {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-banner__gradient { width: 100%; height: 100%; }

  /* Overlay */
  .hero-banner__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, var(--hero-overlay, 0.3));
  }

  /* Content */
  .hero-banner__content {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-block: var(--space-20);
  }

  .hero-banner__inner {
    max-width: {{ section.settings.content_width | default: 700 }}px;
    {%- if section.settings.text_alignment == 'center' -%}
    margin-inline: auto;
    {%- elsif section.settings.text_alignment == 'right' -%}
    margin-left: auto;
    {%- endif -%}
  }

  .hero-banner__eyebrow {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.85;
    margin-bottom: var(--space-4);
  }

  .hero-banner__heading {
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 1.05;
    margin-bottom: var(--space-6);
    color: inherit;
  }

  .hero-banner__subheading {
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: var(--line-height-relaxed);
    opacity: 0.9;
    max-width: 560px;
    margin-bottom: var(--space-8);
    {%- if section.settings.text_alignment == 'center' -%}
    margin-inline: auto;
    {%- endif -%}
  }

  .hero-banner__cta {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    {%- if section.settings.text_alignment == 'center' -%}
    justify-content: center;
    {%- elsif section.settings.text_alignment == 'right' -%}
    justify-content: flex-end;
    {%- endif -%}
  }

  @media (max-width: 768px) {
    .hero-banner__content { padding-block: var(--space-16); }
    .hero-banner__heading { font-size: clamp(2rem, 8vw, 3rem); }
    .hero-banner--full { min-height: 85vh; min-height: 85dvh; }
    .hero-banner__cta .btn--xl { padding: var(--space-4) var(--space-6); font-size: var(--font-size-md); }
  }
</style>

{% schema %}
{
  "name": "Hero banner",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Background video URL",
      "info": "MP4 video URL. Replaces image if set."
    },
    {
      "type": "color",
      "id": "gradient_from",
      "label": "Gradient from",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "gradient_to",
      "label": "Gradient to",
      "default": "#16213e"
    },
    {
      "type": "checkbox",
      "id": "animate_gradient",
      "label": "Animate gradient",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_parallax",
      "label": "Enable parallax effect",
      "default": false,
      "info": "Automatically disabled on mobile"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Zelexto"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium products, exceptional experience."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Vertical alignment",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Middle" },
        { "value": "flex-end", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content max width",
      "min": 400,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 700
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Secondary button label"
    },
    {
      "type": "url",
      "id": "button_2_url",
      "label": "Secondary button URL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "full_height",
      "label": "Full screen height",
      "default": true
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height (when not full screen)",
      "min": 300,
      "max": 900,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable animations",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Hero banner",
      "settings": {
        "heading": "Welcome to Zelexto",
        "subheading": "Premium products, exceptional experience.",
        "button_label": "Shop now",
        "full_height": true
      }
    }
  ]
}
{% endschema %}

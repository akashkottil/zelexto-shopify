{% comment %}
  ZELEXTO THEME — sections/story-hero.liquid
  Section 1: Cinematic fullscreen hero. Parallax background (0.5×), decorative shapes (0.7×), text stagger.
{% endcomment %}

{%- liquid
  assign enable_anim  = section.settings.enable_animation
  assign overlay_opac = section.settings.overlay_opacity | times: 0.01
-%}

<link rel="stylesheet" href="{{ 'story.css' | asset_url }}" media="all">
<script src="{{ 'parallax-engine.js' | asset_url }}" defer></script>

<section
  class="story-hero story-section"
  id="story-hero-{{ section.id }}"
  style="min-height: {{ section.settings.min_height }}vh; color: {{ section.settings.text_color }};">

  <!-- BG layer (0.5×) -->
  <div class="story-hero__bg" aria-hidden="true">
    {%- if section.settings.bg_image != blank -%}
      <img
        src="{{ section.settings.bg_image | image_url: width: 2000 }}"
        srcset="{{ section.settings.bg_image | image_url: width: 1200 }} 1200w,
                {{ section.settings.bg_image | image_url: width: 1600 }} 1600w,
                {{ section.settings.bg_image | image_url: width: 2000 }} 2000w"
        sizes="100vw"
        alt=""
        width="2000"
        height="1125"
        loading="eager"
        fetchpriority="high"
        decoding="sync"
        class="story-hero__bg-img parallax-layer"
        data-parallax-speed="0.5"
        data-parallax-max="80">
    {%- else -%}
      <div style="position:absolute; inset:0; background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);"></div>
    {%- endif -%}
    <div class="story-hero__overlay" style="background: rgba(0,0,0,{{ overlay_opac }});"></div>
  </div>

  <!-- Decorative shapes (0.7×) -->
  {%- if enable_anim -%}
    <div aria-hidden="true" class="parallax-layer" data-parallax-speed="0.7"
      style="position:absolute; inset:0; pointer-events:none; overflow:hidden;">
      <div style="position:absolute; width:500px; height:500px; top:-80px; right:-100px; border-radius:50%; background: {{ section.settings.accent_color }}; opacity:0.06;"></div>
      <div style="position:absolute; width:220px; height:220px; bottom:12%; left:6%; border-radius:50%; background: {{ section.settings.accent_color }}; opacity:0.06;"></div>
    </div>
  {%- endif -%}

  <!-- Content -->
  <div class="story-container" style="position:relative; z-index:2; min-height: inherit; display:flex; align-items:center;">
    <div class="story-hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="story-eyebrow story-animate anim-fade-in" {% if enable_anim %}data-animate{% endif %}>{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h1 class="story-heading-hero story-animate anim-slide-up delay-1" {% if enable_anim %}data-animate{% endif %}>
        {{ section.settings.heading | default: 'Designed for everyday performance.' }}
      </h1>

      {%- if section.settings.subheading != blank -%}
        <p class="story-body-lg story-animate anim-slide-up delay-2" {% if enable_anim %}data-animate{% endif %}
          style="margin-top:1.5rem; max-width:540px;">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <div class="story-animate anim-slide-up delay-3" {% if enable_anim %}data-animate{% endif %}
        style="margin-top:2.5rem; display:flex; gap:16px; flex-wrap:wrap;">
        {%- if section.settings.btn_primary_label != blank -%}
          <a href="{{ section.settings.btn_primary_url | default: routes.all_products_collection_url }}"
            class="story-btn story-btn--primary">
            {{ section.settings.btn_primary_label }}
            <span class="story-btn__arrow" aria-hidden="true">→</span>
          </a>
        {%- endif -%}
        {%- if section.settings.btn_secondary_label != blank -%}
          <a href="{{ section.settings.btn_secondary_url | default: '#' }}"
            class="story-btn story-btn--outline">{{ section.settings.btn_secondary_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="story-hero__scroll-hint" aria-hidden="true">
    <svg width="16" height="24" viewBox="0 0 16 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="1" y="1" width="14" height="22" rx="7"/><circle cx="8" cy="8" r="2" fill="currentColor"/>
    </svg>
    <span>Scroll</span>
  </div>

</section>

{% schema %}
{
  "name": "Story — Hero",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Welcome" },
    { "type": "textarea", "id": "heading", "label": "Headline", "default": "Designed for everyday performance." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Premium quality meets modern design. Experience the difference." },
    { "type": "header", "content": "Buttons" },
    { "type": "text", "id": "btn_primary_label", "label": "Primary button", "default": "Shop Now" },
    { "type": "url", "id": "btn_primary_url", "label": "Primary button URL" },
    { "type": "text", "id": "btn_secondary_label", "label": "Secondary button" },
    { "type": "url", "id": "btn_secondary_url", "label": "Secondary button URL" },
    { "type": "header", "content": "Background" },
    { "type": "image_picker", "id": "bg_image", "label": "Background image" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 10, "max": 85, "step": 5, "default": 45 },
    { "type": "range", "id": "min_height", "label": "Min height (vh)", "min": 60, "max": 100, "step": 5, "default": 100 },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Shape color", "default": "#6366f1" },
    { "type": "header", "content": "Animation" },
    { "type": "checkbox", "id": "enable_animation", "label": "Enable animation", "default": true }
  ],
  "presets": [{ "name": "Story — Hero", "settings": { "heading": "Designed for everyday performance.", "subheading": "Premium quality meets modern design." } }]
}
{% endschema %}

{% comment %}
  ZELEXTO THEME — sections/story-hero.liquid
  Full-screen storytelling hero. Part of the flexible story engine.
  Merchants stack multiple story sections on page.json for cinematic landing pages.
{% endcomment %}

{%- liquid
  assign enable_anim = section.settings.enable_animation
  assign anim_type   = section.settings.animation_type | default: 'animate-slide-up'
  assign anim_delay  = section.settings.animation_delay | default: 0
-%}

<section
  class="story-hero"
  id="story-{{ section.id }}"
  style="--section-bg: {{ section.settings.bg_color }};
         --story-text-color: {{ section.settings.text_color }};
         --overlay-opacity: {{ section.settings.overlay_opacity | times: 0.01 }};">

  <!-- Background -->
  <div class="story-hero__bg">
    {%- if section.settings.bg_image != blank -%}
      <img
        src="{{ section.settings.bg_image | image_url: width: 1920 }}"
        srcset="{{ section.settings.bg_image | image_url: width: 1100 }} 1100w,
                {{ section.settings.bg_image | image_url: width: 1920 }} 1920w"
        sizes="100vw"
        alt="{{ section.settings.bg_image.alt | escape }}"
        width="1920"
        height="{{ 1920 | divided_by: section.settings.bg_image.aspect_ratio | round }}"
        loading="lazy"
        decoding="async"
        class="story-hero__bg-img{% if section.settings.enable_parallax %} animate-parallax{% endif %}"
        {% if section.settings.enable_parallax %}data-parallax="0.25"{% endif %}>
    {%- else -%}
      <div class="story-hero__bg-gradient{% if section.settings.animate_gradient %} animate-gradient{% endif %}"
        style="background: linear-gradient(135deg, {{ section.settings.gradient_from | default: '#0f0c29' }}, {{ section.settings.gradient_to | default: '#302b63' }}, {{ section.settings.gradient_end | default: '#24243e' }});"></div>
    {%- endif -%}
    <div class="story-hero__overlay"></div>
  </div>

  <!-- Content -->
  <div class="story-hero__content container">
    <div class="story-hero__inner{% if section.settings.text_alignment == 'center' %} story-hero__inner--center{% endif %}">

      {%- if section.settings.eyebrow != blank -%}
        <p class="story-hero__eyebrow{% if enable_anim %} {{ anim_type }}{% endif %}"
          {% if enable_anim %}data-animate="{{ anim_type }}" style="--animation-delay: {{ anim_delay }}ms;"{% endif %}>
          {{ section.settings.eyebrow }}
        </p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="story-hero__heading{% if enable_anim %} {{ anim_type }}{% endif %}"
          {% if enable_anim %}data-animate="{{ anim_type }}" style="--animation-delay: {{ anim_delay | plus: 100 }}ms;"{% endif %}>
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="story-hero__subheading{% if enable_anim %} animate-slide-up{% endif %}"
          {% if enable_anim %}data-animate="animate-slide-up" style="--animation-delay: {{ anim_delay | plus: 200 }}ms;"{% endif %}>
          {{ section.settings.subheading }}
        </p>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <div class="story-hero__cta{% if enable_anim %} animate-scale-in{% endif %}"
          {% if enable_anim %}data-animate="animate-scale-in" style="--animation-delay: {{ anim_delay | plus: 350 }}ms;"{% endif %}>
          <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn--primary btn--xl">
            {{ section.settings.button_label }}
          </a>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

<style>
  .story-hero {
    position: relative;
    min-height: {{ section.settings.min_height | default: 90 }}vh;
    min-height: {{ section.settings.min_height | default: 90 }}dvh;
    display: flex;
    align-items: center;
    color: var(--story-text-color, #fff);
    overflow: hidden;
  }
  .story-hero__bg { position: absolute; inset: 0; }
  .story-hero__bg-img, .story-hero__bg-gradient { width: 100%; height: 100%; object-fit: cover; }
  .story-hero__overlay {
    position: absolute; inset: 0;
    background: rgba(0,0,0, var(--overlay-opacity, 0.4));
  }
  .story-hero__content { position: relative; z-index: 1; padding-block: var(--space-20); }
  .story-hero__inner { max-width: 760px; }
  .story-hero__inner--center { margin-inline: auto; text-align: center; }
  .story-hero__eyebrow {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.8;
    margin-bottom: var(--space-4);
  }
  .story-hero__heading {
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 1.08;
    margin-bottom: var(--space-6);
    color: inherit;
  }
  .story-hero__subheading {
    font-size: clamp(1rem, 2vw, 1.25rem);
    opacity: 0.88;
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-8);
    max-width: 560px;
  }
  .story-hero__inner--center .story-hero__subheading { margin-inline: auto; }
  .story-hero__cta { display: flex; gap: var(--space-4); flex-wrap: wrap; }
  .story-hero__inner--center .story-hero__cta { justify-content: center; }
  @media (max-width: 768px) {
    .story-hero { min-height: 80vh; min-height: 80dvh; }
  }
</style>

{% schema %}
{
  "name": "Story — Hero",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Background" },
    { "type": "image_picker", "id": "bg_image", "label": "Background image" },
    { "type": "color", "id": "gradient_from", "label": "Gradient start", "default": "#0f0c29" },
    { "type": "color", "id": "gradient_to", "label": "Gradient middle", "default": "#302b63" },
    { "type": "color", "id": "gradient_end", "label": "Gradient end", "default": "#24243e" },
    { "type": "checkbox", "id": "animate_gradient", "label": "Animate gradient", "default": false },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay darkness", "min": 0, "max": 80, "step": 5, "unit": "%", "default": 40 },
    { "type": "checkbox", "id": "enable_parallax", "label": "Enable parallax", "default": false },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Tell your brand story" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "select", "id": "text_alignment", "label": "Alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"}], "default": "center" },
    { "type": "text", "id": "button_label", "label": "CTA button label" },
    { "type": "url", "id": "button_url", "label": "CTA button URL" },
    { "type": "range", "id": "min_height", "label": "Min height (vh)", "min": 50, "max": 100, "step": 5, "unit": "vh", "default": 90 },
    { "type": "header", "content": "Animation" },
    { "type": "checkbox", "id": "enable_animation", "label": "Enable animation", "default": true },
    { "type": "select", "id": "animation_type", "label": "Animation style", "options": [{"value":"animate-fade-in","label":"Fade in"},{"value":"animate-slide-up","label":"Slide up"},{"value":"animate-scale-in","label":"Scale in"}], "default": "animate-slide-up" },
    { "type": "range", "id": "animation_delay", "label": "Animation delay", "min": 0, "max": 500, "step": 50, "unit": "ms", "default": 0 }
  ],
  "presets": [{ "name": "Story — Hero", "settings": { "heading": "Tell your brand story", "enable_animation": true } }]
}
{% endschema %}

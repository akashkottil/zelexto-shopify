{%- comment -%}
  Testimonials — minimal quote cards.
{%- endcomment -%}

{%- liquid
  assign theme = section.settings.theme | default: 'light'
  assign columns = section.settings.columns | default: 3
-%}

<section class="reviews reviews--{{ theme }}" data-section-id="{{ section.id }}">
  <div class="container">
    <header class="reviews__header" data-reveal="up">
      {%- if section.settings.eyebrow != blank -%}
        <p class="reviews__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="reviews__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.show_summary and section.settings.rating > 0 -%}
        <div class="reviews__summary" data-reveal="up">
          <span class="reviews__stars" aria-hidden="true">
            {%- for i in (1..5) -%}
              {%- render 'icon', name: 'star', class: 'icon icon--star' -%}
            {%- endfor -%}
          </span>
          <span class="reviews__rating">{{ section.settings.rating }} / 5</span>
          {%- if section.settings.count != blank -%}
            <span class="reviews__count">— {{ section.settings.count }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </header>

    <div class="reviews__grid reviews__grid--cols-{{ columns }}" data-stagger>
      {%- for block in section.blocks -%}
        <figure class="review" data-reveal="up" {{ block.shopify_attributes }}>
          {%- if block.settings.rating > 0 -%}
            <div class="review__stars" aria-label="{{ block.settings.rating }} out of 5">
              {%- for i in (1..5) -%}
                {%- if forloop.index <= block.settings.rating -%}
                  {%- render 'icon', name: 'star', class: 'icon icon--star' -%}
                {%- else -%}
                  {%- render 'icon', name: 'star-empty', class: 'icon icon--star icon--star-empty' -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          <blockquote class="review__quote">
            {{ block.settings.quote }}
          </blockquote>

          <figcaption class="review__attribution">
            <div class="review__avatar">
              {%- if block.settings.avatar != blank -%}
                {%- render 'responsive-image',
                    image: block.settings.avatar,
                    alt: block.settings.author,
                    sizes: '40px',
                    widths: '80,120',
                    loading: 'lazy',
                    aspect_ratio: '1/1' -%}
              {%- else -%}
                {%- render 'demo-image', kind: 'avatar' -%}
              {%- endif -%}
            </div>
            <div>
              <p class="review__author">{{ block.settings.author | default: 'Verified buyer' }}</p>
              {%- if block.settings.location != blank -%}
                <p class="review__location">{{ block.settings.location }}</p>
              {%- endif -%}
            </div>
          </figcaption>
        </figure>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} { display: block; }

  .reviews {
    padding-block: clamp(var(--s-9), 12vh, var(--s-10));
    background: var(--c-bg);
    color: var(--c-ink);
  }
  .reviews--soft { background: var(--c-surface); }
  .reviews--dark { background: var(--c-bg-inv); color: var(--c-ink-inv); }

  .reviews__header {
    max-width: 720px;
    margin: 0 auto var(--s-9);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }
  .reviews__eyebrow {
    margin: 0;
    font-size: var(--fs-14);
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-ink-muted);
  }
  .reviews--dark .reviews__eyebrow { color: var(--c-ink-muted-inv); }
  .reviews__heading {
    margin: 0;
    font-size: clamp(var(--fs-28), 4vw, var(--fs-56));
    font-weight: var(--weight-semibold);
    letter-spacing: -0.022em;
    line-height: 1.06;
  }
  .reviews__summary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--s-2);
    color: var(--c-ink-muted);
  }
  .reviews--dark .reviews__summary { color: var(--c-ink-muted-inv); }
  .reviews__stars { display: inline-flex; gap: 2px; color: var(--c-ink); }
  .reviews--dark .reviews__stars { color: var(--c-ink-inv); }
  .reviews__rating { font-weight: var(--weight-medium); color: var(--c-ink); }
  .reviews--dark .reviews__rating { color: var(--c-ink-inv); }

  .reviews__grid {
    display: grid;
    gap: var(--s-5);
    grid-template-columns: 1fr;
  }
  @media (min-width: 750px)  { .reviews__grid--cols-2, .reviews__grid--cols-3 { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 990px)  { .reviews__grid--cols-3 { grid-template-columns: repeat(3, 1fr); } }

  .review {
    margin: 0;
    padding: var(--s-6);
    background: var(--c-surface);
    border: 1px solid var(--c-line-soft);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
  }
  .reviews--soft .review { background: var(--c-bg); }
  .reviews--dark .review { background: var(--c-elev-inv); border-color: var(--c-line-inv); }

  .review__stars { display: inline-flex; gap: 2px; color: var(--c-ink); }
  .reviews--dark .review__stars { color: var(--c-ink-inv); }
  .review__stars .icon--star-empty { color: var(--c-ink-muted); }
  .icon--star { width: 16px; height: 16px; }

  .review__quote {
    margin: 0;
    font-size: var(--fs-19);
    line-height: 1.5;
    color: var(--c-ink);
  }
  .reviews--dark .review__quote { color: var(--c-ink-inv); }

  .review__attribution {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    margin-top: auto;
  }
  .review__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--c-elev);
  }
  .review__avatar img,
  .review__avatar svg { width: 100%; height: 100%; object-fit: cover; }
  .review__author { margin: 0; font-weight: var(--weight-medium); font-size: var(--fs-14); }
  .review__location { margin: 0; color: var(--c-ink-muted); font-size: var(--fs-14); }
  .reviews--dark .review__location { color: var(--c-ink-muted-inv); }
</style>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "select", "id": "theme", "label": "Theme",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "soft",  "label": "Soft" },
        { "value": "dark",  "label": "Dark" }
      ], "default": "soft" },
    { "type": "select", "id": "columns", "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ], "default": "3" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What people say" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Loved by 50,000+ customers." },
    { "type": "checkbox", "id": "show_summary", "label": "Show aggregate rating", "default": true },
    { "type": "number",   "id": "rating",       "label": "Average rating (e.g. 4.9)", "default": 4.9 },
    { "type": "text",     "id": "count",        "label": "Total review count text", "default": "2,847 reviews" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "richtext", "id": "quote", "label": "Quote",
          "default": "<p>Best purchase I've made all year. Quality is unreal.</p>" },
        { "type": "text",     "id": "author",   "label": "Author",   "default": "Anika R." },
        { "type": "text",     "id": "location", "label": "Location", "default": "Mumbai" },
        { "type": "image_picker", "id": "avatar", "label": "Avatar (optional)" },
        { "type": "range",    "id": "rating", "label": "Rating", "min": 1, "max": 5, "step": 1, "default": 5 }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "review", "settings": { "author": "Anika R.",   "location": "Mumbai",     "rating": 5, "quote": "<p>Best purchase I've made all year. Quality is unreal.</p>" } },
        { "type": "review", "settings": { "author": "Rohan M.",   "location": "Bengaluru",  "rating": 5, "quote": "<p>Looks even better in person. Daily-driver material.</p>" } },
        { "type": "review", "settings": { "author": "Priya S.",   "location": "Delhi",      "rating": 5, "quote": "<p>Genuinely excited every time I use it. Worth every rupee.</p>" } }
      ]
    }
  ]
}
{% endschema %}

{%- liquid
  assign columns = section.settings.columns | default: 3
  assign bg = section.settings.bg | default: 'surface'
-%}

<section class="testimonials testimonials--{{ bg }} section" data-section-id="{{ section.id }}">
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.eyebrow != blank -%}
      <header class="testimonials__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="testimonials__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="testimonials__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="testimonials__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.aggregate_rating > 0 -%}
          <div class="testimonials__aggregate">
            <span class="testimonials__rating">{{ section.settings.aggregate_rating }}</span>
            <div class="testimonials__stars" aria-hidden="true">
              {%- for i in (1..5) -%}
                {%- assign filled = i | minus: 1 -%}
                {%- if filled < section.settings.aggregate_rating -%}
                  {%- render 'icon', name: 'star', class: 'icon icon--xs' -%}
                {%- else -%}
                  {%- render 'icon', name: 'star-empty', class: 'icon icon--xs' -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
            {%- if section.settings.review_count > 0 -%}
              <span class="testimonials__count">{{ section.settings.review_count }} reviews</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="testimonials__grid testimonials__grid--{{ columns }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonial' -%}
          <blockquote class="testimonial-card" {{ block.shopify_attributes }}>
            {%- if block.settings.rating > 0 -%}
              <div class="testimonial-card__stars" aria-label="{{ block.settings.rating }} out of 5">
                {%- for i in (1..5) -%}
                  {%- if i <= block.settings.rating -%}
                    {%- render 'icon', name: 'star', class: 'icon icon--xs' -%}
                  {%- else -%}
                    {%- render 'icon', name: 'star-empty', class: 'icon icon--xs' -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}
            <p class="testimonial-card__quote">{{ block.settings.quote }}</p>
            <footer class="testimonial-card__author">
              {%- if block.settings.avatar != blank -%}
                <img
                  src="{{ block.settings.avatar | image_url: width: 88 }}"
                  alt="{{ block.settings.author }}"
                  width="44" height="44"
                  loading="lazy" decoding="async"
                  class="testimonial-card__avatar">
              {%- elsif block.settings.author != blank -%}
                <span class="testimonial-card__avatar testimonial-card__avatar--initials" aria-hidden="true">
                  {{ block.settings.author | slice: 0, 1 | upcase }}
                </span>
              {%- endif -%}
              <span>
                <strong class="testimonial-card__name">{{ block.settings.author }}</strong>
                {%- if block.settings.location != blank -%}
                  <span class="testimonial-card__location">{{ block.settings.location }}</span>
                {%- endif -%}
              </span>
            </footer>
          </blockquote>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .testimonials--bg{background:var(--c-bg)}
  #shopify-section-{{ section.id }} .testimonials--surface{background:var(--c-surface)}
  #shopify-section-{{ section.id }} .testimonials--elev{background:var(--c-elev)}

  #shopify-section-{{ section.id }} .testimonials__header{
    max-width:760px;margin:0 auto var(--s-7);text-align:center;
  }
  #shopify-section-{{ section.id }} .testimonials__eyebrow{
    font-size:var(--fs-14);font-weight:var(--weight-medium);
    letter-spacing:.04em;text-transform:uppercase;
    color:var(--c-ink-muted);margin-bottom:var(--s-2);
  }
  #shopify-section-{{ section.id }} .testimonials__heading{
    font-size:clamp(var(--fs-28), 4vw, var(--fs-56));
    line-height:var(--lh-snug);
  }
  #shopify-section-{{ section.id }} .testimonials__sub{
    margin-top:var(--s-3);font-size:var(--fs-19);color:var(--c-ink-muted);
  }
  #shopify-section-{{ section.id }} .testimonials__aggregate{
    margin-top:var(--s-4);display:inline-flex;align-items:center;gap:var(--s-2);
    font-size:var(--fs-14);
  }
  #shopify-section-{{ section.id }} .testimonials__rating{font-weight:var(--weight-semibold);font-size:var(--fs-16)}
  #shopify-section-{{ section.id }} .testimonials__stars{display:inline-flex;color:#f5a524;gap:2px}
  #shopify-section-{{ section.id }} .testimonials__count{color:var(--c-ink-muted)}

  #shopify-section-{{ section.id }} .testimonials__grid{display:grid;gap:var(--s-5)}
  #shopify-section-{{ section.id }} .testimonials__grid--2{grid-template-columns:repeat(2,1fr)}
  #shopify-section-{{ section.id }} .testimonials__grid--3{grid-template-columns:repeat(3,1fr)}
  #shopify-section-{{ section.id }} .testimonials__grid--4{grid-template-columns:repeat(4,1fr)}
  @media (max-width:1024px){
    #shopify-section-{{ section.id }} .testimonials__grid--3,
    #shopify-section-{{ section.id }} .testimonials__grid--4{grid-template-columns:repeat(2,1fr)}
  }
  @media (max-width:640px){
    #shopify-section-{{ section.id }} .testimonials__grid{grid-template-columns:1fr}
  }

  #shopify-section-{{ section.id }} .testimonial-card{
    background:var(--c-bg);border:1px solid var(--c-line);
    border-radius:var(--radius-lg);padding:var(--s-5);
    display:flex;flex-direction:column;gap:var(--s-3);margin:0;
  }
  #shopify-section-{{ section.id }} .testimonial-card__stars{display:flex;gap:2px;color:#f5a524}
  #shopify-section-{{ section.id }} .testimonial-card__quote{
    font-size:var(--fs-16);line-height:var(--lh-body);color:var(--c-ink);flex:1;margin:0;
  }
  #shopify-section-{{ section.id }} .testimonial-card__author{display:flex;align-items:center;gap:var(--s-3)}
  #shopify-section-{{ section.id }} .testimonial-card__avatar{
    width:44px;height:44px;border-radius:var(--radius-pill);object-fit:cover;flex-shrink:0;
  }
  #shopify-section-{{ section.id }} .testimonial-card__avatar--initials{
    display:inline-flex;align-items:center;justify-content:center;
    background:var(--c-elev);color:var(--c-ink);font-weight:var(--weight-semibold);
  }
  #shopify-section-{{ section.id }} .testimonial-card__name{display:block;font-size:var(--fs-14);font-weight:var(--weight-semibold)}
  #shopify-section-{{ section.id }} .testimonial-card__location{display:block;font-size:var(--fs-12);color:var(--c-ink-muted)}
</style>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What customers say" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Loved by thousands" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "range", "id": "aggregate_rating", "label": "Aggregate rating (0 to hide)", "min": 0, "max": 5, "step": 1, "default": 5 },
    { "type": "number", "id": "review_count", "label": "Review count" },
    {
      "type": "select", "id": "columns", "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "select", "id": "bg", "label": "Background",
      "options": [
        { "value": "bg",      "label": "White" },
        { "value": "surface", "label": "Surface" },
        { "value": "elev",    "label": "Elevated" }
      ],
      "default": "surface"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Best purchase I’ve made all year." },
        { "type": "text", "id": "author", "label": "Author", "default": "Aanya R." },
        { "type": "text", "id": "location", "label": "Location", "default": "Mumbai" },
        { "type": "range", "id": "rating", "label": "Rating", "min": 0, "max": 5, "step": 1, "default": 5 },
        { "type": "image_picker", "id": "avatar", "label": "Avatar" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial", "settings": { "quote": "Outstanding quality. Worth every rupee.", "author": "Aanya R.", "location": "Mumbai", "rating": 5 } },
        { "type": "testimonial", "settings": { "quote": "Quick delivery, beautifully packaged.", "author": "Vikram S.", "location": "Bengaluru", "rating": 5 } },
        { "type": "testimonial", "settings": { "quote": "Lives up to the hype, and then some.", "author": "Priya M.", "location": "Delhi", "rating": 5 } }
      ]
    }
  ]
}
{% endschema %}

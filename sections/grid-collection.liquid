{%- comment -%}
  Grid collection — 2/3/4-up product or collection tiles.
{%- endcomment -%}

{%- liquid
  assign collection = collections[section.settings.collection]
  assign columns = section.settings.columns | default: 4
  assign limit = section.settings.product_limit | default: 8
  assign theme = section.settings.theme | default: 'light'
  assign render_type = section.settings.render_type | default: 'product'
-%}

<section class="grid-collection grid-collection--{{ theme }}" data-section-id="{{ section.id }}">
  <div class="container">
    <header class="grid-collection__header" data-reveal="up">
      {%- if section.settings.eyebrow != blank -%}
        <p class="grid-collection__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="grid-collection__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_url | default: collection.url | default: '#' }}" class="grid-collection__view-all">
          {{ section.settings.cta_label }}
          {%- render 'icon', name: 'arrow-right', class: 'icon icon--sm' -%}
        </a>
      {%- endif -%}
    </header>

    <div class="grid-collection__grid grid-collection__grid--cols-{{ columns }}" data-stagger>
      {%- if render_type == 'collection' -%}
        {%- for block in section.blocks -%}
          {%- assign blk_collection = collections[block.settings.collection] -%}
          {%- assign blk_image = block.settings.image | default: blk_collection.image -%}
          <a href="{{ blk_collection.url | default: block.settings.url | default: '#' }}" class="collection-tile zoomable" data-reveal="up" {{ block.shopify_attributes }}>
            <div class="collection-tile__media">
              {%- if blk_image != blank -%}
                {%- render 'responsive-image',
                    image: blk_image,
                    alt: blk_collection.title | default: block.settings.label,
                    sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 100vw',
                    widths: '480,640,800,1100',
                    loading: 'lazy',
                    aspect_ratio: '4/5',
                    class: 'collection-tile__image' -%}
              {%- else -%}
                <div class="collection-tile__demo">
                  {%- render 'demo-image', kind: 'collection' -%}
                </div>
              {%- endif -%}
            </div>
            <div class="collection-tile__caption">
              <span class="collection-tile__label">{{ block.settings.label | default: blk_collection.title | default: 'Demo collection' }}</span>
              <span class="collection-tile__arrow" aria-hidden="true">{%- render 'icon', name: 'arrow-right', class: 'icon icon--sm' -%}</span>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- if collection.products.size > 0 -%}
          {%- for product in collection.products limit: limit -%}
            <div data-reveal="up">
              {%- render 'product-card', product: product -%}
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..limit) -%}
            <a href="#" class="collection-tile zoomable" data-reveal="up">
              <div class="collection-tile__media collection-tile__media--demo">
                {%- render 'demo-image', kind: 'product' -%}
              </div>
              <div class="collection-tile__caption">
                <span class="collection-tile__label">Demo product {{ i }}</span>
              </div>
            </a>
          {%- endfor -%}
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} { display: block; }

  .grid-collection {
    padding-block: clamp(var(--s-9), 12vh, var(--s-10));
    background: var(--c-bg);
    color: var(--c-ink);
  }
  .grid-collection--soft { background: var(--c-surface); }
  .grid-collection--dark { background: var(--c-bg-inv); color: var(--c-ink-inv); }

  .grid-collection__header {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: var(--s-4);
    margin-bottom: var(--s-7);
  }
  .grid-collection__eyebrow {
    margin: 0 0 var(--s-2);
    font-size: var(--fs-14);
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-ink-muted);
  }
  .grid-collection--dark .grid-collection__eyebrow { color: var(--c-ink-muted-inv); }
  .grid-collection__heading {
    margin: 0;
    font-size: clamp(var(--fs-28), 3.5vw, var(--fs-56));
    font-weight: var(--weight-semibold);
    letter-spacing: -0.022em;
    line-height: 1.06;
  }
  .grid-collection__view-all {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    font-weight: var(--weight-medium);
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    align-self: end;
  }
  .grid-collection__view-all .icon { transition: transform var(--dur-base) var(--ease-apple); }
  .grid-collection__view-all:hover .icon { transform: translateX(4px); }

  .grid-collection__grid {
    display: grid;
    gap: var(--s-5);
    grid-template-columns: 1fr 1fr;
  }
  @media (min-width: 750px) {
    .grid-collection__grid--cols-3 { grid-template-columns: repeat(3, 1fr); }
    .grid-collection__grid--cols-4 { grid-template-columns: repeat(4, 1fr); }
  }
  @media (min-width: 990px) {
    .grid-collection__grid--cols-2 { grid-template-columns: repeat(2, 1fr); }
  }

  .collection-tile {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    color: inherit;
  }
  .collection-tile__media {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--c-elev);
    aspect-ratio: 4 / 5;
  }
  .grid-collection--dark .collection-tile__media { background: var(--c-elev-inv); }
  .collection-tile__media svg,
  .collection-tile__media img,
  .collection-tile__demo svg { width: 100%; height: 100%; object-fit: cover; }

  .collection-tile__caption {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-2);
    padding-inline: var(--s-1);
  }
  .collection-tile__label {
    font-weight: var(--weight-medium);
    font-size: var(--fs-16);
  }
  .collection-tile__arrow { color: var(--c-ink-muted); transition: transform var(--dur-base) var(--ease-apple); }
  .grid-collection--dark .collection-tile__arrow { color: var(--c-ink-muted-inv); }
  .collection-tile:hover .collection-tile__arrow { transform: translateX(4px); color: var(--c-ink); }
  .grid-collection--dark .collection-tile:hover .collection-tile__arrow { color: var(--c-ink-inv); }
</style>

{% schema %}
{
  "name": "Grid collection",
  "settings": [
    { "type": "select", "id": "theme", "label": "Theme",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "soft",  "label": "Soft" },
        { "value": "dark",  "label": "Dark" }
      ], "default": "light" },
    {
      "type": "select",
      "id": "render_type",
      "label": "Tile type",
      "options": [
        { "value": "product",    "label": "Products from a collection" },
        { "value": "collection", "label": "Custom collection tiles (blocks)" }
      ],
      "default": "product"
    },
    { "type": "select", "id": "columns", "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ], "default": "4" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Now on" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best sellers." },
    { "type": "collection", "id": "collection", "label": "Source collection (Products mode)" },
    { "type": "range", "id": "product_limit", "label": "Max products", "min": 4, "max": 16, "step": 2, "default": 8 },
    { "type": "text", "id": "cta_label", "label": "View-all label", "default": "View all" },
    { "type": "url",  "id": "cta_url",   "label": "View-all URL" }
  ],
  "blocks": [
    {
      "type": "collection_tile",
      "name": "Collection tile",
      "settings": [
        { "type": "collection",   "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image",      "label": "Image (overrides collection image)" },
        { "type": "text",         "id": "label",      "label": "Label override" },
        { "type": "url",          "id": "url",        "label": "URL override" }
      ]
    }
  ],
  "presets": [
    { "name": "Grid collection" },
    {
      "name": "Collection tiles",
      "settings": { "render_type": "collection", "columns": "4", "heading": "Shop by category" },
      "blocks": [
        { "type": "collection_tile", "settings": { "label": "Best sellers"   } },
        { "type": "collection_tile", "settings": { "label": "New arrivals"   } },
        { "type": "collection_tile", "settings": { "label": "Trending now"   } },
        { "type": "collection_tile", "settings": { "label": "Limited edition" } }
      ]
    }
  ]
}
{% endschema %}

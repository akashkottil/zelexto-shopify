{%- liquid
  assign collection = collections[section.settings.collection]
  assign limit = section.settings.product_limit | default: 8
  assign columns = section.settings.columns | default: 4
  assign bg = section.settings.bg | default: 'bg'
-%}

<section class="grid-collection grid-collection--{{ bg }} section" data-section-id="{{ section.id }}">
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.eyebrow != blank -%}
      <header class="grid-collection__header">
        <div>
          {%- if section.settings.eyebrow != blank -%}
            <p class="grid-collection__eyebrow">{{ section.settings.eyebrow }}</p>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="grid-collection__heading">{{ section.settings.heading }}</h2>
          {%- endif -%}
          {%- if section.settings.subheading != blank -%}
            <p class="grid-collection__sub">{{ section.settings.subheading }}</p>
          {%- endif -%}
        </div>
        {%- if section.settings.show_view_all and collection != blank -%}
          <a href="{{ collection.url }}" class="grid-collection__view-all">
            {{ section.settings.view_all_label | default: 'View all' }}
            {%- render 'icon', name: 'arrow-right', class: 'icon icon--xs' -%}
          </a>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="grid-collection__grid grid-collection__grid--{{ columns }}">
      {%- if collection != blank -%}
        {%- for product in collection.products limit: limit -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..limit) -%}
          <div class="grid-collection__placeholder">
            <div class="aspect aspect--1/1">{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
            <p class="grid-collection__placeholder-title">{{ 'general.title' | t | default: 'Product title' }}</p>
            <p class="grid-collection__placeholder-price">$0.00</p>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .grid-collection--bg{background:var(--c-bg)}
  #shopify-section-{{ section.id }} .grid-collection--surface{background:var(--c-surface)}
  #shopify-section-{{ section.id }} .grid-collection--elev{background:var(--c-elev)}

  #shopify-section-{{ section.id }} .grid-collection__header{
    display:flex;align-items:flex-end;justify-content:space-between;
    flex-wrap:wrap;gap:var(--s-4);margin-bottom:var(--s-6);
  }
  #shopify-section-{{ section.id }} .grid-collection__eyebrow{
    font-size:var(--fs-14);font-weight:var(--weight-medium);
    letter-spacing:.04em;text-transform:uppercase;
    color:var(--c-ink-muted);margin-bottom:var(--s-2);
  }
  #shopify-section-{{ section.id }} .grid-collection__heading{
    font-size:clamp(var(--fs-28), 3.5vw, var(--fs-40));
    line-height:var(--lh-snug);
  }
  #shopify-section-{{ section.id }} .grid-collection__sub{
    margin-top:var(--s-2);color:var(--c-ink-muted);font-size:var(--fs-16);max-width:60ch;
  }
  #shopify-section-{{ section.id }} .grid-collection__view-all{
    display:inline-flex;align-items:center;gap:var(--s-1);
    font-size:var(--fs-14);font-weight:var(--weight-medium);color:var(--c-accent);
  }
  #shopify-section-{{ section.id }} .grid-collection__view-all:hover{text-decoration:underline}

  #shopify-section-{{ section.id }} .grid-collection__grid{
    display:grid;gap:var(--s-5);
  }
  #shopify-section-{{ section.id }} .grid-collection__grid--2{grid-template-columns:repeat(2,1fr)}
  #shopify-section-{{ section.id }} .grid-collection__grid--3{grid-template-columns:repeat(3,1fr)}
  #shopify-section-{{ section.id }} .grid-collection__grid--4{grid-template-columns:repeat(4,1fr)}
  @media (max-width:1024px){
    #shopify-section-{{ section.id }} .grid-collection__grid--3,
    #shopify-section-{{ section.id }} .grid-collection__grid--4{grid-template-columns:repeat(2,1fr)}
  }
  @media (max-width:480px){
    #shopify-section-{{ section.id }} .grid-collection__grid{grid-template-columns:1fr 1fr;gap:var(--s-3)}
  }
  #shopify-section-{{ section.id }} .grid-collection__placeholder{padding:var(--s-3)}
  #shopify-section-{{ section.id }} .grid-collection__placeholder svg{width:100%;height:100%;background:var(--c-elev)}
  #shopify-section-{{ section.id }} .grid-collection__placeholder-title{margin-top:var(--s-2);font-size:var(--fs-14);color:var(--c-ink-muted)}
  #shopify-section-{{ section.id }} .grid-collection__placeholder-price{font-size:var(--fs-12);color:var(--c-ink-muted)}
</style>

{% schema %}
{
  "name": "Grid collection",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Bestsellers" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "label": "Products to show", "min": 2, "max": 16, "step": 1, "default": 8 },
    {
      "type": "select", "id": "columns", "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    { "type": "checkbox", "id": "show_view_all", "label": "Show 'View all' link", "default": true },
    { "type": "text", "id": "view_all_label", "label": "View-all label", "default": "View all" },
    {
      "type": "select", "id": "bg", "label": "Background",
      "options": [
        { "value": "bg",      "label": "White" },
        { "value": "surface", "label": "Surface" },
        { "value": "elev",    "label": "Elevated" }
      ],
      "default": "bg"
    }
  ],
  "presets": [{ "name": "Grid collection" }]
}
{% endschema %}

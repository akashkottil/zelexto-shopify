{% comment %}
  ZELEXTO THEME — sections/story-cta.liquid
  Full-width conversion CTA section.
{% endcomment %}

{%- liquid
  assign enable_anim = section.settings.enable_animation
-%}

<section
  class="story-cta section"
  id="story-cta-{{ section.id }}"
  style="background-color: {{ section.settings.bg_color }};">

  {%- if section.settings.bg_image != blank -%}
    <div class="story-cta__bg-image" aria-hidden="true">
      <img
        src="{{ section.settings.bg_image | image_url: width: 1600 }}"
        alt=""
        width="1600"
        height="600"
        loading="lazy"
        decoding="async">
      <div class="story-cta__overlay" style="opacity: {{ section.settings.overlay_opacity | times: 0.01 }};"></div>
    </div>
  {%- endif -%}

  <div class="container" style="position: relative; z-index: 1;">
    <div class="story-cta__inner">

      {%- if section.settings.eyebrow != blank -%}
        <p class="story-cta__eyebrow{% if enable_anim %} animate-fade-in{% endif %}"
          {% if enable_anim %}data-animate="animate-fade-in"{% endif %}
          style="color: {{ section.settings.text_color }};">
          {{ section.settings.eyebrow }}
        </p>
      {%- endif -%}

      <h2 class="story-cta__heading{% if enable_anim %} animate-slide-up{% endif %}"
        {% if enable_anim %}data-animate="animate-slide-up"{% endif %}
        style="color: {{ section.settings.text_color }};">
        {{ section.settings.heading }}
      </h2>

      {%- if section.settings.subheading != blank -%}
        <p class="story-cta__subheading{% if enable_anim %} animate-fade-in{% endif %}"
          {% if enable_anim %}data-animate="animate-fade-in" style="--animation-delay: 100ms; color: {{ section.settings.text_color }}; opacity: 0.85;"{% else %}style="color: {{ section.settings.text_color }}; opacity: 0.85;"{% endif %}>
          {{ section.settings.subheading }}
        </p>
      {%- endif -%}

      <div class="story-cta__buttons{% if enable_anim %} animate-scale-in{% endif %}"
        {% if enable_anim %}data-animate="animate-scale-in" style="--animation-delay: 200ms;"{% endif %}>
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn--primary btn--xl">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.button_2_label != blank -%}
          <a href="{{ section.settings.button_2_url | default: '#' }}" class="btn btn--secondary btn--xl">
            {{ section.settings.button_2_label }}
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.show_trust_badges -%}
        <div class="story-cta__trust{% if enable_anim %} animate-fade-in{% endif %}"
          {% if enable_anim %}data-animate="animate-fade-in" style="--animation-delay: 300ms;"{% endif %}>
          {%- render 'trust-badges' -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

<style>
  .story-cta {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-24);
    text-align: center;
  }
  .story-cta__bg-image {
    position: absolute; inset: 0;
  }
  .story-cta__bg-image img { width: 100%; height: 100%; object-fit: cover; }
  .story-cta__overlay {
    position: absolute; inset: 0;
    background: #000;
  }
  .story-cta__inner {
    max-width: 700px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
  }
  .story-cta__eyebrow {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0;
  }
  .story-cta__heading {
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 1.1;
    margin: 0;
  }
  .story-cta__subheading {
    font-size: var(--font-size-lg);
    line-height: var(--line-height-relaxed);
    max-width: 560px;
    margin: 0;
  }
  .story-cta__buttons {
    display: flex; gap: var(--space-4); flex-wrap: wrap; justify-content: center;
  }
  .story-cta__trust { margin-top: var(--space-4); opacity: 0.8; }
</style>

{% schema %}
{
  "name": "Story — CTA",
  "tag": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#1a1a1a" },
    { "type": "image_picker", "id": "bg_image", "label": "Background image (optional)" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 60 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ready to start?" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "text", "id": "button_label", "label": "Primary CTA label", "default": "Shop now" },
    { "type": "url", "id": "button_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "button_2_label", "label": "Secondary CTA label" },
    { "type": "url", "id": "button_2_url", "label": "Secondary CTA URL" },
    { "type": "checkbox", "id": "show_trust_badges", "label": "Show trust badges", "default": true },
    { "type": "header", "content": "Animation" },
    { "type": "checkbox", "id": "enable_animation", "label": "Enable animation", "default": true }
  ],
  "presets": [{ "name": "Story — CTA", "settings": { "heading": "Ready to start?", "button_label": "Shop now" } }]
}
{% endschema %}

{% comment %}
  ZELEXTO THEME — sections/email-signup.liquid
  Standalone newsletter signup section.
{% endcomment %}

<section
  class="email-signup section"
  id="email-signup-{{ section.id }}"
  style="background-color: {{ section.settings.bg_color }};
         background-image: {% if section.settings.bg_image %}url('{{ section.settings.bg_image | image_url: width: 1600 }}'){% else %}none{% endif %};
         background-size: cover; background-position: center;">

  {%- if section.settings.bg_image -%}
    <div class="email-signup__overlay" style="background: rgba(0,0,0,{{ section.settings.overlay_opacity | times: 0.01 }});"></div>
  {%- endif -%}

  <div class="container email-signup__inner">

    <div class="email-signup__text">
      {%- if section.settings.eyebrow != blank -%}
        <p class="email-signup__eyebrow" style="color: {{ section.settings.text_color }}; opacity: 0.7;">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="email-signup__heading" style="color: {{ section.settings.text_color }};">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="email-signup__subheading" style="color: {{ section.settings.text_color }}; opacity: 0.8;">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- form 'customer', class: 'email-signup__form', id: 'EmailSignupForm' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">

      {%- if form.posted_successfully? -%}
        <div class="email-signup__success" role="status">
          {%- render 'icon', name: 'check', size: 20 -%}
          {{ 'newsletter.success' | t | default: 'Thanks for subscribing!' }}
        </div>
      {%- else -%}
        <div class="email-signup__input-row">
          <label for="email-signup-{{ section.id }}" class="visually-hidden">{{ 'newsletter.email' | t | default: 'Email address' }}</label>
          <input
            type="email"
            name="contact[email]"
            id="email-signup-{{ section.id }}"
            class="email-signup__input"
            placeholder="{{ section.settings.placeholder | default: 'Enter your email' }}"
            required
            autocomplete="email">
          <button type="submit" class="btn email-signup__submit" style="background: {{ section.settings.btn_color }}; color: {{ section.settings.btn_text_color }};">
            {{ section.settings.button_label | default: 'Subscribe' }}
          </button>
        </div>
        {%- if section.settings.disclaimer != blank -%}
          <p class="email-signup__disclaimer" style="color: {{ section.settings.text_color }};">{{ section.settings.disclaimer }}</p>
        {%- endif -%}
      {%- endif -%}

    {%- endform -%}

  </div>
</section>

<style>
  .email-signup { padding-block: var(--section-padding); position: relative; overflow: hidden; }
  .email-signup__overlay { position: absolute; inset: 0; }
  .email-signup__inner { position: relative; z-index: 1; display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-8); }
  .email-signup__text { flex: 1; min-width: 240px; }
  .email-signup__eyebrow { font-size: var(--font-size-xs); font-weight: var(--font-weight-semibold); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: var(--space-2); }
  .email-signup__heading { font-size: clamp(1.5rem, 3vw, 2.25rem); margin-bottom: var(--space-2); }
  .email-signup__subheading { font-size: var(--font-size-sm); }
  .email-signup__form { flex: 1; min-width: 260px; max-width: 440px; display: flex; flex-direction: column; gap: var(--space-3); }
  .email-signup__input-row { display: flex; gap: 0; }
  .email-signup__input {
    flex: 1;
    border: 1.5px solid var(--color-border);
    border-right: none;
    border-radius: var(--radius) 0 0 var(--radius);
    padding: 0 var(--space-4);
    font-family: var(--font-body); font-size: var(--font-size-sm);
    height: 48px;
    outline: none;
    background: rgba(255,255,255,0.9);
  }
  .email-signup__input:focus { border-color: var(--color-primary); }
  .email-signup__submit {
    border-radius: 0 var(--radius) var(--radius) 0 !important;
    padding-inline: var(--space-5);
    height: 48px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .email-signup__disclaimer { font-size: var(--font-size-xs); opacity: 0.6; }
  .email-signup__success {
    display: flex; align-items: center; gap: var(--space-2);
    font-weight: var(--font-weight-semibold); font-size: var(--font-size-sm);
    color: #16a34a; background: #f0fdf4; border: 1px solid #bbf7d0;
    border-radius: var(--radius); padding: var(--space-4);
  }
</style>

{% schema %}
{
  "name": "Email signup",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Join the community" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get exclusive deals & updates" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Subscribe to our newsletter and be the first to know." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Enter your email address" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" },
    { "type": "text", "id": "disclaimer", "label": "Disclaimer text", "default": "No spam, unsubscribe anytime." },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#111827" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "color", "id": "btn_color", "label": "Button color", "default": "#ffffff" },
    { "type": "color", "id": "btn_text_color", "label": "Button text color", "default": "#111827" },
    { "type": "header", "content": "Background image" },
    { "type": "image_picker", "id": "bg_image", "label": "Background image" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 90, "step": 5, "default": 50 }
  ],
  "presets": [{ "name": "Email signup" }]
}
{% endschema %}

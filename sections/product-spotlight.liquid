{%- comment -%}
  Product spotlight — single-product cinematic showcase.

  Apple "look closer" pattern: huge product image on a solid background, title +
  short description + price below, big CTA. Theme-able (light or dark).
{%- endcomment -%}

{%- liquid
  assign product = all_products[section.settings.product]
  assign image = section.settings.image
  if image == blank and product != blank
    assign image = product.featured_image
  endif
  assign theme = section.settings.theme | default: 'light'
  assign cta_url = product.url | default: section.settings.cta_url | default: '#'
  assign cta_label = section.settings.cta_label | default: 'Shop now'
-%}

<section class="spotlight spotlight--{{ theme }}" data-section-id="{{ section.id }}">
  <div class="container spotlight__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="spotlight__eyebrow" data-reveal="up">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="spotlight__heading" data-reveal="up">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="spotlight__body" data-reveal="up">{{ section.settings.body }}</div>
    {%- endif -%}

    <div class="spotlight__media zoomable" data-reveal="zoom">
      {%- if image != blank -%}
        {%- render 'responsive-image',
            image: image,
            alt: product.title | default: section.settings.heading,
            sizes: '(min-width: 990px) 80vw, 100vw',
            widths: '750,1100,1500,1900,2400',
            loading: 'lazy',
            aspect_ratio: '4/3',
            class: 'spotlight__image' -%}
      {%- else -%}
        {%- render 'demo-image', kind: 'product', class: 'spotlight__image' -%}
      {%- endif -%}
    </div>

    <div class="spotlight__footer" data-reveal="up">
      {%- if product != blank -%}
        <p class="spotlight__product">
          <span class="spotlight__product-name">{{ product.title }}</span>
          {%- if product.price -%}
            <span class="spotlight__product-price">{{ 'general.from' | t | default: 'From' }} {{ product.price | money }}</span>
          {%- endif -%}
        </p>
      {%- endif -%}
      <a href="{{ cta_url }}" class="btn btn--primary spotlight__cta">{{ cta_label }}</a>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} { display: block; }

  .spotlight {
    padding-block: clamp(var(--s-9), 14vh, var(--s-10));
    background: var(--c-bg);
    color: var(--c-ink);
  }
  .spotlight--soft { background: var(--c-surface); }
  .spotlight--dark {
    background: var(--c-bg-inv);
    color: var(--c-ink-inv);
  }

  .spotlight__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--s-5);
  }
  .spotlight__eyebrow {
    margin: 0;
    font-size: var(--fs-14);
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-ink-muted);
  }
  .spotlight--dark .spotlight__eyebrow { color: var(--c-ink-muted-inv); }

  .spotlight__heading {
    margin: 0;
    font-size: clamp(var(--fs-28), 5vw, var(--fs-80));
    font-weight: var(--weight-semibold);
    letter-spacing: -0.025em;
    line-height: 1.04;
    max-width: 18ch;
  }
  .spotlight__body {
    margin: 0;
    max-width: 56ch;
    font-size: clamp(var(--fs-19), 1.5vw, var(--fs-21));
    line-height: 1.5;
    color: var(--c-ink-muted);
  }
  .spotlight--dark .spotlight__body { color: var(--c-ink-muted-inv); }

  .spotlight__media {
    width: 100%;
    max-width: 1280px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-block: var(--s-6);
    background: var(--c-elev);
  }
  .spotlight--dark .spotlight__media { background: var(--c-elev-inv); }
  .spotlight__media svg,
  .spotlight__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .spotlight__footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-4);
  }
  .spotlight__product {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--s-2) var(--s-4);
    font-size: var(--fs-19);
  }
  .spotlight__product-name { font-weight: var(--weight-medium); }
  .spotlight__product-price { color: var(--c-ink-muted); }
  .spotlight--dark .spotlight__product-price { color: var(--c-ink-muted-inv); }

  .spotlight__cta { min-height: 50px; padding-inline: var(--s-7); font-size: var(--fs-16); }
  .spotlight--dark .btn--primary { background: #fff; color: #000; }
  .spotlight--dark .btn--primary:hover { background: #e8e8ed; }
</style>

{% schema %}
{
  "name": "Product spotlight",
  "settings": [
    { "type": "product", "id": "product", "label": "Product" },
    { "type": "image_picker", "id": "image", "label": "Hero image (overrides product image)" },
    {
      "type": "select",
      "id": "theme",
      "label": "Theme",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "soft",  "label": "Soft (off-white)" },
        { "value": "dark",  "label": "Dark" }
      ],
      "default": "soft"
    },
    { "type": "text",     "id": "eyebrow",   "label": "Eyebrow",   "default": "Now available" },
    { "type": "text",     "id": "heading",   "label": "Heading",   "default": "Built around you." },
    { "type": "richtext", "id": "body",      "label": "Body",      "default": "<p>The flagship — refined, considered, ready.</p>" },
    { "type": "text",     "id": "cta_label", "label": "CTA label", "default": "Shop the product" },
    { "type": "url",      "id": "cta_url",   "label": "CTA URL (only used if no product is set)" }
  ],
  "presets": [
    { "name": "Product spotlight" }
  ]
}
{% endschema %}

{%- liquid
  assign product = all_products[section.settings.product]
  assign image = section.settings.image | default: product.featured_image
  assign bg = section.settings.bg | default: 'bg'
-%}

<section class="product-spotlight product-spotlight--{{ bg }} section" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="product-spotlight__grid">

      <div class="product-spotlight__media">
        {%- if image != blank -%}
          <div class="aspect aspect--3/4">
            {%- render 'responsive-image',
              image: image,
              alt: image.alt | default: product.title | default: section.settings.heading,
              sizes: '(min-width: 769px) 50vw, 100vw',
              loading: 'lazy'
            -%}
          </div>
        {%- else -%}
          <div class="aspect aspect--3/4 product-spotlight__placeholder" aria-hidden="true">
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      <div class="product-spotlight__body">
        {%- if section.settings.eyebrow != blank -%}
          <p class="product-spotlight__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="product-spotlight__heading">{{ section.settings.heading }}</h2>
        {%- elsif product != blank -%}
          <h2 class="product-spotlight__heading">{{ product.title }}</h2>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <div class="product-spotlight__copy">{{ section.settings.body }}</div>
        {%- elsif product.description != blank -%}
          <div class="product-spotlight__copy">{{ product.description | truncate: 280 }}</div>
        {%- endif -%}

        {%- if product != blank -%}
          <div class="product-spotlight__price">
            {%- render 'price', product: product, use_variant: false -%}
          </div>

          {%- if section.settings.show_features and section.blocks.size > 0 -%}
            <ul class="product-spotlight__features" role="list">
              {%- for block in section.blocks -%}
                {%- if block.type == 'feature' -%}
                  <li class="product-spotlight__feature" {{ block.shopify_attributes }}>
                    {%- render 'icon', name: 'check', class: 'icon icon--sm product-spotlight__feature-icon' -%}
                    <span>{{ block.settings.text }}</span>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          {%- endif -%}
        {%- endif -%}

        <div class="product-spotlight__actions">
          {%- if product != blank -%}
            <a href="{{ product.url }}" class="btn btn--primary">
              {{ section.settings.cta_label | default: 'Shop now' }}
            </a>
            {%- if section.settings.secondary_cta_label != blank -%}
              <a href="{{ section.settings.secondary_cta_url | default: '#' }}" class="btn btn--ghost">
                {{ section.settings.secondary_cta_label }}
              </a>
            {%- endif -%}
          {%- else -%}
            {%- if section.settings.cta_label != blank -%}
              <a href="{{ section.settings.cta_url | default: '#' }}" class="btn btn--primary">{{ section.settings.cta_label }}</a>
            {%- endif -%}
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .product-spotlight--bg{background:var(--c-bg);color:var(--c-ink)}
  #shopify-section-{{ section.id }} .product-spotlight--surface{background:var(--c-surface);color:var(--c-ink)}
  #shopify-section-{{ section.id }} .product-spotlight--elev{background:var(--c-elev);color:var(--c-ink)}
  #shopify-section-{{ section.id }} .product-spotlight--ink{background:var(--c-ink);color:var(--c-bg)}

  #shopify-section-{{ section.id }} .product-spotlight__grid{
    display:grid;grid-template-columns:1fr 1fr;
    gap:clamp(var(--s-5), 6vw, var(--s-8));
    align-items:center;
  }
  @media (max-width:768px){
    #shopify-section-{{ section.id }} .product-spotlight__grid{grid-template-columns:1fr}
  }
  #shopify-section-{{ section.id }} .product-spotlight__media{
    border-radius:var(--radius-lg);overflow:hidden;
  }
  #shopify-section-{{ section.id }} .product-spotlight__placeholder{background:var(--c-elev)}
  #shopify-section-{{ section.id }} .product-spotlight__placeholder svg{width:100%;height:100%}

  #shopify-section-{{ section.id }} .product-spotlight__body{max-width:560px}
  #shopify-section-{{ section.id }} .product-spotlight__eyebrow{
    font-size:var(--fs-14);font-weight:var(--weight-medium);
    letter-spacing:.04em;text-transform:uppercase;
    color:var(--c-ink-muted);margin-bottom:var(--s-2);
  }
  #shopify-section-{{ section.id }} .product-spotlight--ink .product-spotlight__eyebrow{color:rgba(255,255,255,.7)}
  #shopify-section-{{ section.id }} .product-spotlight__heading{
    font-size:clamp(var(--fs-28), 4vw, var(--fs-56));
    line-height:var(--lh-snug);
  }
  #shopify-section-{{ section.id }} .product-spotlight__copy{
    margin-top:var(--s-4);
    color:var(--c-ink-muted);font-size:var(--fs-16);line-height:var(--lh-body);
    max-width:60ch;
  }
  #shopify-section-{{ section.id }} .product-spotlight--ink .product-spotlight__copy{color:rgba(255,255,255,.78)}
  #shopify-section-{{ section.id }} .product-spotlight__copy p{margin:0 0 var(--s-3)}
  #shopify-section-{{ section.id }} .product-spotlight__copy p:last-child{margin:0}

  #shopify-section-{{ section.id }} .product-spotlight__price{
    margin-top:var(--s-4);font-size:var(--fs-21);font-weight:var(--weight-semibold);
  }

  #shopify-section-{{ section.id }} .product-spotlight__features{
    margin-top:var(--s-5);display:flex;flex-direction:column;gap:var(--s-2);
    list-style:none;padding:0;
  }
  #shopify-section-{{ section.id }} .product-spotlight__feature{
    display:flex;align-items:center;gap:var(--s-2);font-size:var(--fs-14);
  }
  #shopify-section-{{ section.id }} .product-spotlight__feature-icon{color:var(--c-success)}

  #shopify-section-{{ section.id }} .product-spotlight__actions{
    margin-top:var(--s-6);display:flex;flex-wrap:wrap;gap:var(--s-3);
  }
</style>

{% schema %}
{
  "name": "Product spotlight",
  "tag": "section",
  "settings": [
    { "type": "product", "id": "product", "label": "Product" },
    { "type": "image_picker", "id": "image", "label": "Override image (optional)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Bestseller" },
    { "type": "text", "id": "heading", "label": "Heading override" },
    { "type": "richtext", "id": "body", "label": "Body" },
    { "type": "text", "id": "cta_label", "label": "Primary CTA label", "default": "Shop the product" },
    { "type": "url",  "id": "cta_url",   "label": "Primary CTA link (used when no product)" },
    { "type": "text", "id": "secondary_cta_label", "label": "Secondary CTA label" },
    { "type": "url",  "id": "secondary_cta_url",   "label": "Secondary CTA link" },
    { "type": "checkbox", "id": "show_features", "label": "Show feature bullets", "default": true },
    {
      "type": "select", "id": "bg", "label": "Background",
      "options": [
        { "value": "bg",      "label": "White" },
        { "value": "surface", "label": "Surface" },
        { "value": "elev",    "label": "Elevated" },
        { "value": "ink",     "label": "Dark" }
      ],
      "default": "bg"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature bullet",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Free shipping above ₹999" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Product spotlight",
      "blocks": [
        { "type": "feature", "settings": { "text": "Free shipping above ₹999" } },
        { "type": "feature", "settings": { "text": "30-day returns" } },
        { "type": "feature", "settings": { "text": "GST invoice on request" } }
      ]
    }
  ]
}
{% endschema %}

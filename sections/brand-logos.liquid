{% comment %}
  ZELEXTO THEME — sections/brand-logos.liquid
  Logo marquee / static grid of partner/press/brand logos.
{% endcomment %}

{%- liquid
  assign animate_marquee = section.settings.enable_marquee
  assign enable_anim     = section.settings.enable_animation
  assign logo_count      = section.blocks.size
-%}

<section class="brand-logos section" id="brand-logos-{{ section.id }}" style="background-color: {{ section.settings.bg_color }};">
  <div class="container">

    {%- if section.settings.heading != blank -%}
      <div class="section-header{% if enable_anim %} animate-fade-in{% endif %}" {% if enable_anim %}data-animate="animate-fade-in"{% endif %}>
        <p class="section-header__eyebrow" style="color: {{ section.settings.text_color }};">{{ section.settings.heading }}</p>
      </div>
    {%- endif -%}

    <div class="brand-logos__wrap">
      {%- if animate_marquee -%}
        <!-- Infinite scrolling marquee -->
        <div class="brand-logos__marquee" aria-hidden="true">
          <div class="brand-logos__track" style="--logo-count: {{ logo_count }};">
            {%- for block in section.blocks -%}
              <div class="brand-logos__logo" {{ block.shopify_attributes }}>
                {%- if block.settings.logo != blank -%}
                  <img
                    src="{{ block.settings.logo | image_url: width: 200 }}"
                    alt="{{ block.settings.alt | default: block.settings.logo.alt | default: 'Brand logo' }}"
                    width="{{ block.settings.logo_width | default: 120 }}"
                    height="48"
                    loading="lazy"
                    decoding="async">
                {%- else -%}
                  <span class="brand-logos__placeholder">Brand</span>
                {%- endif -%}
              </div>
            {%- endfor -%}
            <!-- Duplicate for seamless loop -->
            {%- for block in section.blocks -%}
              <div class="brand-logos__logo" aria-hidden="true">
                {%- if block.settings.logo != blank -%}
                  <img
                    src="{{ block.settings.logo | image_url: width: 200 }}"
                    alt=""
                    width="{{ block.settings.logo_width | default: 120 }}"
                    height="48"
                    loading="lazy"
                    decoding="async">
                {%- else -%}
                  <span class="brand-logos__placeholder">Brand</span>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        </div>

      {%- else -%}
        <!-- Static centered grid -->
        <div class="brand-logos__grid" data-stagger>
          {%- for block in section.blocks -%}
            <div class="brand-logos__logo{% if enable_anim %} animate-fade-in{% endif %}" {% if enable_anim %}data-animate="animate-fade-in" style="--animation-delay: {{ forloop.index0 | times: 40 }}ms;"{% endif %} {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}" target="_blank" rel="noopener" aria-label="{{ block.settings.alt | default: 'Brand' }}">{%- endif -%}
              {%- if block.settings.logo != blank -%}
                <img
                  src="{{ block.settings.logo | image_url: width: 200 }}"
                  alt="{{ block.settings.alt | default: block.settings.logo.alt | default: 'Brand logo' }}"
                  width="{{ block.settings.logo_width | default: 120 }}"
                  height="48"
                  loading="lazy"
                  decoding="async">
              {%- else -%}
                <span class="brand-logos__placeholder">Brand</span>
              {%- endif -%}
              {%- if block.settings.link != blank -%}</a>{%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

  </div>
</section>

<style>
  .brand-logos { padding-block: var(--space-8); }

  /* Marquee */
  .brand-logos__wrap { overflow: hidden; }

  .brand-logos__marquee {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .brand-logos__track {
    display: flex;
    gap: var(--space-10);
    width: max-content;
    animation: marquee {{ section.settings.marquee_speed | default: 30 }}s linear infinite;
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-logos__track { animation: none; }
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* Grid */
  .brand-logos__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-8);
  }

  /* Logo item */
  .brand-logos__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .brand-logos__logo img {
    height: 40px;
    width: auto;
    object-fit: contain;
    filter: grayscale(1) opacity(0.5);
    transition: filter var(--transition-base);
  }

  .brand-logos__logo:hover img { filter: grayscale(0) opacity(1); }

  .brand-logos__placeholder {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .brand-logos__logo a { display: flex; }
</style>

{% schema %}
{
  "name": "Brand logos",
  "tag": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#f9fafb" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#6b7280" },
    { "type": "text", "id": "heading", "label": "Heading text", "default": "As featured in" },
    { "type": "checkbox", "id": "enable_marquee", "label": "Enable scrolling marquee", "default": false },
    { "type": "range", "id": "marquee_speed", "label": "Marquee speed (seconds)", "min": 10, "max": 60, "step": 5, "default": 30 },
    { "type": "checkbox", "id": "enable_animation", "label": "Enable animation (grid mode)", "default": true }
  ],
  "blocks": [{
    "type": "logo",
    "name": "Logo",
    "settings": [
      { "type": "image_picker", "id": "logo", "label": "Logo image" },
      { "type": "text", "id": "alt", "label": "Brand name" },
      { "type": "url", "id": "link", "label": "Link (optional)" },
      { "type": "range", "id": "logo_width", "label": "Logo width (px)", "min": 60, "max": 200, "step": 10, "default": 120 }
    ]
  }],
  "max_blocks": 12,
  "presets": [{
    "name": "Brand logos",
    "blocks": [
      {"type":"logo"},{"type":"logo"},{"type":"logo"},
      {"type":"logo"},{"type":"logo"},{"type":"logo"}
    ]
  }]
}
{% endschema %}

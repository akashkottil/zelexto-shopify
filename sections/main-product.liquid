{%- comment -%}
  Zelexto v2 — sections/main-product.liquid
  Apple-style PDP: breadcrumb, gallery, title/vendor/rating, price,
  variant picker, qty, ATC + buy-it-now, accordion, share, sticky mobile ATC.
  Hooks render Agent C/D snippets that they own.
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'product-form-' | append: section.id
-%}

<product-form
  class="product"
  data-module="product-form.js"
  data-section-id="{{ section.id }}"
  data-product-handle="{{ product.handle }}"
  data-product-id="{{ product.id }}"
  data-update-url="{{ product.url }}">

  <div class="container product__container">
    <div class="product__breadcrumb">
      {% render 'breadcrumb' %}
    </div>

    <div class="product__layout">
      <div class="product__media">
        {% render 'product-gallery', product: product %}
      </div>

      <div class="product__info">
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'vendor' -%}
              {%- if product.vendor != blank -%}
                <p class="product__vendor" {{ block.shopify_attributes }}>{{ product.vendor }}</p>
              {%- endif -%}

            {%- when 'title' -%}
              <h1 class="product__title" {{ block.shopify_attributes }}>{{ product.title }}</h1>

            {%- when 'rating' -%}
              <div class="product__rating" {{ block.shopify_attributes }}>
                {% render 'rating-stars', product: product, size: 'md' %}
              </div>

            {%- when 'price' -%}
              <div class="product__price" data-product-price {{ block.shopify_attributes }}>
                {% render 'price', product: product, variant: current_variant %}
              </div>

            {%- when 'payment_badges' -%}
              <div class="product__payment-badges" {{ block.shopify_attributes }}>
                {% render 'payment-method-indicator', product: product %}
                {% render 'payment-badges', context: 'pdp', product: product %}
              </div>

            {%- when 'pincode' -%}
              <div class="product__pincode" {{ block.shopify_attributes }}>
                {% render 'pincode-check', context: 'pdp' %}
              </div>

            {%- when 'urgency' -%}
              <div class="product__urgency" {{ block.shopify_attributes }}>
                {% render 'low-stock-badge', product: product %}
                {% if block.settings.show_countdown %}
                  {% render 'countdown-inline', heading: block.settings.countdown_label, ends_at: block.settings.countdown_ends_at %}
                {% endif %}
              </div>

            {%- when 'variant_picker' -%}
              <div {{ block.shopify_attributes }}>
                {% render 'variant-picker', product: product %}
              </div>

            {%- when 'quantity' -%}
              <div class="product__quantity" {{ block.shopify_attributes }}>
                <label class="product__quantity-label" for="qty-{{ section.id }}">
                  {{ 'product.quantity' | t | default: 'Quantity' }}
                </label>
                <div class="qty">
                  <button type="button" class="qty__btn" data-qty-step="-1" aria-label="{{ 'product.decrease_quantity' | t | default: 'Decrease' }}">
                    {% render 'icon', name: 'minus' %}
                  </button>
                  <input
                    type="number"
                    id="qty-{{ section.id }}"
                    name="quantity"
                    class="qty__input"
                    value="1"
                    min="1"
                    inputmode="numeric"
                    data-quantity-input>
                  <button type="button" class="qty__btn" data-qty-step="1" aria-label="{{ 'product.increase_quantity' | t | default: 'Increase' }}">
                    {% render 'icon', name: 'plus' %}
                  </button>
                </div>
              </div>

            {%- when 'buy_buttons' -%}
              <div class="product__buy" {{ block.shopify_attributes }}>
                {%- form 'product', product, id: product_form_id, novalidate: 'novalidate', data-product-form: '' -%}
                  <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>
                  {%- unless block.settings.hide_quantity -%}
                    <input type="hidden" name="quantity" value="1" data-quantity-mirror>
                  {%- endunless -%}
                  <button
                    type="submit"
                    class="btn btn--primary btn--full product__atc"
                    data-atc-button
                    {% unless current_variant.available %}disabled{% endunless %}
                    data-text-default="{{ 'product.add_to_cart' | t | default: 'Add to bag' }}"
                    data-text-soldout="{{ 'product.sold_out' | t }}"
                    data-text-unavailable="{{ 'product.unavailable' | t }}"
                    data-text-adding="{{ 'product.adding' | t | default: 'Adding…' }}">
                    <span data-atc-text>
                      {%- if current_variant.available -%}
                        {{ 'product.add_to_cart' | t | default: 'Add to bag' }}
                      {%- else -%}
                        {{ 'product.sold_out' | t }}
                      {%- endif -%}
                    </span>
                  </button>
                  {%- if block.settings.show_dynamic_checkout -%}
                    {{ form | payment_button }}
                  {%- endif -%}
                {%- endform -%}
              </div>

            {%- when 'accordion' -%}
              <div class="product__accordion" {{ block.shopify_attributes }}>
                {% render 'product-tabs', product: product, section: section %}
              </div>

            {%- when 'share' -%}
              <div class="product__share" {{ block.shopify_attributes }}>
                <button type="button" class="btn btn--ghost btn--sm" data-share-button data-share-url="{{ shop.url }}{{ product.url }}" data-share-title="{{ product.title | escape }}">
                  {% render 'icon', name: 'arrow-right' %}
                  <span>{{ 'general.share' | t | default: 'Share' }}</span>
                </button>
              </div>

            {%- when 'hsn' -%}
              <div class="product__hsn" {{ block.shopify_attributes }}>
                {% render 'hsn-code', product: product %}
              </div>

            {%- when 'trust' -%}
              <div class="product__trust" {{ block.shopify_attributes }}>
                {% render 'trust-badges' %}
              </div>

            {%- when '@app' -%}
              <div class="product__app-block" {{ block.shopify_attributes }}>
                {% render block %}
              </div>

          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} Hidden product JSON consumed by product-form.js {%- endcomment -%}
  <script type="application/json" data-product-json>{{ product | json }}</script>

  {%- if section.settings.enable_sticky_atc | default: settings.enable_sticky_atc -%}
    <div class="sticky-atc" data-sticky-atc aria-hidden="true">
      <div class="sticky-atc__info">
        <span class="sticky-atc__title">{{ product.title | truncate: 40 }}</span>
        <span class="sticky-atc__price" data-sticky-price data-money-cents="{{ current_variant.price }}">{{ current_variant.price | money }}</span>
      </div>
      <button
        type="button"
        class="btn btn--primary"
        data-sticky-atc-button
        {% unless current_variant.available %}disabled{% endunless %}>
        {{ 'product.add_to_cart' | t | default: 'Add to bag' }}
      </button>
    </div>
  {%- endif -%}

  {% render 'analytics-product', product: product %}
</product-form>

{% schema %}
{
  "name": "t:sections.product.name",
  "tag": "section",
  "class": "section section--product",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_sticky_atc",
      "label": "Enable sticky Add to Bag (mobile)",
      "default": true
    }
  ],
  "blocks": [
    { "type": "vendor",         "name": "Vendor", "limit": 1 },
    { "type": "title",          "name": "Title",  "limit": 1 },
    { "type": "rating",         "name": "Rating", "limit": 1 },
    { "type": "price",          "name": "Price",  "limit": 1 },
    {
      "type": "payment_badges",
      "name": "Payment badges",
      "limit": 1
    },
    {
      "type": "pincode",
      "name": "Pincode / COD check",
      "limit": 1
    },
    {
      "type": "urgency",
      "name": "Urgency",
      "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "show_countdown", "label": "Show countdown", "default": false },
        { "type": "text", "id": "countdown_label", "label": "Countdown label", "default": "Sale ends in" },
        { "type": "text", "id": "countdown_ends_at", "label": "Ends at (ISO 8601)" }
      ]
    },
    { "type": "variant_picker", "name": "Variant picker", "limit": 1 },
    {
      "type": "quantity",
      "name": "Quantity",
      "limit": 1
    },
    {
      "type": "buy_buttons",
      "name": "Buy buttons",
      "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "show_dynamic_checkout", "label": "Show dynamic checkout button", "default": true },
        { "type": "checkbox", "id": "hide_quantity", "label": "Hide quantity input", "default": false }
      ]
    },
    {
      "type": "accordion",
      "name": "Description / shipping / returns accordion",
      "limit": 1
    },
    {
      "type": "share",
      "name": "Share",
      "limit": 1
    },
    {
      "type": "hsn",
      "name": "HSN code",
      "limit": 1
    },
    {
      "type": "trust",
      "name": "Trust badges",
      "limit": 1
    },
    {
      "type": "description",
      "name": "Description (accordion entry)",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "tab_label", "label": "Label", "default": "Description" }
      ]
    },
    {
      "type": "shipping",
      "name": "Shipping (accordion entry)",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "tab_label", "label": "Label", "default": "Shipping" },
        { "type": "richtext", "id": "content", "label": "Content" }
      ]
    },
    {
      "type": "returns",
      "name": "Returns (accordion entry)",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "tab_label", "label": "Label", "default": "Returns" },
        { "type": "richtext", "id": "content", "label": "Content" }
      ]
    },
    {
      "type": "size_guide",
      "name": "Size guide (accordion entry)",
      "settings": [
        { "type": "text", "id": "tab_label", "label": "Label", "default": "Size guide" },
        { "type": "richtext", "id": "content", "label": "Content" }
      ]
    },
    {
      "type": "custom",
      "name": "Custom accordion entry",
      "settings": [
        { "type": "text", "id": "tab_label", "label": "Label" },
        { "type": "richtext", "id": "content", "label": "Content" }
      ]
    },
    {
      "type": "metafield",
      "name": "Metafield accordion entry",
      "settings": [
        { "type": "text", "id": "tab_label", "label": "Label" },
        { "type": "text", "id": "namespace", "label": "Metafield namespace", "default": "custom" },
        { "type": "text", "id": "key", "label": "Metafield key" }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Product information",
      "blocks": [
        { "type": "vendor" },
        { "type": "title" },
        { "type": "rating" },
        { "type": "price" },
        { "type": "payment_badges" },
        { "type": "variant_picker" },
        { "type": "quantity" },
        { "type": "buy_buttons" },
        { "type": "pincode" },
        { "type": "urgency" },
        { "type": "trust" },
        { "type": "accordion" },
        { "type": "description" },
        { "type": "shipping" },
        { "type": "returns" },
        { "type": "share" },
        { "type": "hsn" }
      ]
    }
  ]
}
{% endschema %}

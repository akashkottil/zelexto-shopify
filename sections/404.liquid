{% comment %}
  ZELEXTO THEME — sections/404.liquid
  Custom 404 page with search box and suggested links.
{% endcomment %}

<section class="error-page section">
  <div class="container">

    <div class="error-page__inner">
      <div class="error-page__code" aria-hidden="true">404</div>
      <h1 class="error-page__title">{{ '404.title' | t | default: 'Page not found' }}</h1>
      <p class="error-page__text">{{ '404.subtitle' | t | default: "The page you're looking for doesn't exist or has been moved." }}</p>

      <!-- Search -->
      <form action="{{ routes.search_url }}" method="get" class="error-page__search">
        <input type="hidden" name="type" value="product">
        <div class="search-page__input-wrap" style="max-width: 440px; margin-inline: auto;">
          {%- render 'icon', name: 'search', size: 18 -%}
          <input
            type="search"
            name="q"
            class="search-page__input"
            placeholder="{{ 'search.placeholder' | t | default: 'Search our store...' }}"
            aria-label="{{ 'search.placeholder' | t | default: 'Search our store' }}">
        </div>
        <button type="submit" class="btn btn--primary">{{ 'search.submit' | t | default: 'Search' }}</button>
      </form>

      <!-- Helpful links -->
      <div class="error-page__links">
        <a href="{{ routes.root_url }}" class="btn btn--ghost">{{ '404.home_link' | t | default: 'Back to homepage' }}</a>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--ghost">{{ '404.shop_link' | t | default: 'Shop all products' }}</a>
        {%- if blogs.news.articles_count > 0 -%}
          <a href="{{ blogs.news.url }}" class="btn btn--ghost">{{ '404.blog_link' | t | default: 'Visit our blog' }}</a>
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

<style>
  .error-page { padding-block: var(--space-16); }

  .error-page__inner {
    max-width: 540px;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .error-page__code {
    font-size: clamp(6rem, 20vw, 10rem);
    font-weight: var(--font-weight-bold);
    line-height: 1;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark, var(--color-primary)));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    opacity: 0.15;
    letter-spacing: -0.05em;
    pointer-events: none;
    position: absolute;
    top: 0; left: 50%; transform: translateX(-50%);
    z-index: 0;
  }

  .error-page__inner { position: relative; isolation: isolate; }

  .error-page__title { font-size: clamp(1.75rem, 4vw, 2.5rem); }

  .error-page__text { color: var(--color-text-secondary); font-size: var(--font-size-lg); }

  .error-page__search {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    width: 100%;
  }

  .error-page__search .search-page__input-wrap {
    width: 100%; max-width: 440px;
  }

  .error-page__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
  }
</style>

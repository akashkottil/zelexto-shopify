{%- comment -%}
  Zelexto v2 — sections/404.liquid
  Apple-style 404. Big numeral, helpful copy, link home + popular collections.
{%- endcomment -%}

<section class="error">
  <div class="container error__container">
    <p class="error__code" aria-hidden="true">404</p>
    <h1 class="error__title">{{ '404.title' | t | default: 'Page not found' }}</h1>
    <p class="error__sub">{{ '404.description' | t | default: 'The page you were looking for doesn’t exist. It may have moved.' }}</p>

    <div class="error__cta">
      <a href="{{ routes.root_url }}" class="btn btn--primary">{{ '404.cta' | t | default: 'Go back home' }}</a>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--ghost">{{ 'general.browse_all' | t | default: 'Shop all products' }}</a>
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="error__popular">
        <h2 class="error__popular-title">{{ '404.popular' | t | default: 'Popular collections' }}</h2>
        <ul class="error__popular-list" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'collection' and block.settings.collection -%}
              {%- assign c = collections[block.settings.collection] -%}
              <li {{ block.shopify_attributes }}>
                <a href="{{ c.url }}" class="error__popular-link">
                  {%- if c.image -%}
                    <span class="error__popular-media aspect" style="aspect-ratio: 1/1;">
                      {% render 'responsive-image', image: c.image, alt: c.title, sizes: '120px', loading: 'lazy', aspect_ratio: '1/1' %}
                    </span>
                  {%- endif -%}
                  <span>{{ c.title }}</span>
                </a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "404 page",
  "tag": "section",
  "class": "section section--404",
  "settings": [],
  "blocks": [
    {
      "type": "collection",
      "name": "Popular collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{ "name": "404 page" }]
}
{% endschema %}

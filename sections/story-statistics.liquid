{% comment %}
  ZELEXTO THEME — sections/story-statistics.liquid
  Stats counter section. Numbers animate 0 → target using requestAnimationFrame.
  Triggered when section enters viewport via ThemeAnimations & component-stats-counter.js.
{% endcomment %}

{%- liquid
  assign enable_anim = section.settings.enable_animation
-%}

<section
  class="story-statistics section"
  id="story-stats-{{ section.id }}"
  style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">

  <div class="container">

    {%- if section.settings.heading != blank -%}
      <div class="section-header">
        <h2 class="section-header__title{% if enable_anim %} animate-fade-in{% endif %}"
          {% if enable_anim %}data-animate="animate-fade-in"{% endif %}>
          {{ section.settings.heading }}
        </h2>
      </div>
    {%- endif -%}

    <div class="story-statistics__grid" data-stagger>
      {%- for block in section.blocks -%}
        <div class="story-statistics__stat{% if enable_anim %} animate-slide-up{% endif %}"
          {% if enable_anim %}data-animate="animate-slide-up"{% endif %}
          {{ block.shopify_attributes }}>

          <div
            class="story-statistics__number"
            data-counter-target="{{ block.settings.number }}"
            data-counter-suffix="{{ block.settings.suffix }}"
            data-counter-prefix="{{ block.settings.prefix }}"
            aria-label="{{ block.settings.prefix }}{{ block.settings.number }}{{ block.settings.suffix }}">
            0
          </div>
          <p class="story-statistics__label">{{ block.settings.label }}</p>
          {%- if block.settings.sublabel != blank -%}
            <p class="story-statistics__sublabel">{{ block.settings.sublabel }}</p>
          {%- endif -%}

        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
  .story-statistics {
    padding-block: var(--section-padding);
  }

  .story-statistics__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-8);
    text-align: center;
  }

  .story-statistics__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .story-statistics__number {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: var(--font-weight-bold);
    line-height: 1;
    color: var(--color-primary);
    transition: color var(--transition-base);
  }

  .story-statistics__label {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    margin: 0;
  }

  .story-statistics__sublabel {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin: 0;
  }

  @media (max-width: 480px) {
    .story-statistics__grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

{% schema %}
{
  "name": "Story — Statistics",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Section heading" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#f9fafb" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#111827" },
    { "type": "header", "content": "Animation" },
    { "type": "checkbox", "id": "enable_animation", "label": "Enable animation", "default": true }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistic",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "prefix", "label": "Prefix (e.g. $, +)", "default": "" },
        { "type": "number", "id": "number", "label": "Number", "default": 10000 },
        { "type": "text", "id": "suffix", "label": "Suffix (e.g. K, +, %)", "default": "+" },
        { "type": "text", "id": "label", "label": "Label", "default": "Happy customers" },
        { "type": "text", "id": "sublabel", "label": "Sub-label" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{
    "name": "Story — Statistics",
    "blocks": [
      { "type": "stat", "settings": { "number": 50000, "suffix": "+", "label": "Customers served" } },
      { "type": "stat", "settings": { "number": 120, "suffix": "+", "label": "Countries shipped" } },
      { "type": "stat", "settings": { "number": 4.9, "suffix": "★", "label": "Average rating" } },
      { "type": "stat", "settings": { "number": 99, "suffix": "%", "label": "Satisfaction rate" } }
    ]
  }]
}
{% endschema %}

{%- comment -%}
  Zelexto v2 — sections/search-modal.liquid
  Full-screen search dialog. Eager-loaded since it must respond to the
  global `search:open` event from the header.
{%- endcomment -%}

<predictive-search
  class="search-modal"
  data-module="search.js"
  data-module-eager
  hidden
  role="dialog"
  aria-modal="true"
  aria-label="{{ 'search.title' | t | default: 'Search' }}">

  <div class="search-modal__backdrop" data-search-backdrop></div>

  <div class="search-modal__panel" data-search-panel>
    <form action="{{ routes.search_url }}" method="get" role="search" class="search-modal__form" data-search-form>
      <input type="hidden" name="type" value="product,article,page,collection">

      <label class="search-modal__field">
        <span class="sr-only">{{ 'search.placeholder' | t }}</span>
        {% render 'icon', name: 'search', class: 'search-modal__icon' %}
        <input
          type="search"
          name="q"
          class="search-modal__input"
          placeholder="{{ 'search.placeholder' | t | default: 'Search products, articles…' }}"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
          aria-controls="predictive-results"
          aria-autocomplete="list"
          aria-expanded="false"
          data-search-input>
        <button type="button" class="search-modal__clear" data-search-clear hidden aria-label="{{ 'search.clear' | t | default: 'Clear' }}">
          {% render 'icon', name: 'close' %}
        </button>
      </label>

      <button type="button" class="btn btn--ghost btn--sm search-modal__close" data-search-close aria-label="{{ 'general.close' | t | default: 'Close' }}">
        {{ 'general.close' | t | default: 'Close' }}
      </button>
    </form>

    <div class="search-modal__results" id="predictive-results" data-search-results role="listbox" aria-live="polite">
      <div class="search-modal__hint" data-search-hint>{{ 'search.hint' | t | default: 'Start typing to see suggestions.' }}</div>
    </div>
  </div>
</predictive-search>

{% schema %}
{
  "name": "Search modal",
  "tag": "section",
  "class": "section--search-modal",
  "settings": []
}
{% endschema %}

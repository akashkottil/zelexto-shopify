{%- comment -%}
  Zelexto v2 — sections/main-page.liquid
  Generic page. Apple-style narrow measure for body content. Optional
  hero image block + rich-text override of the page.content.
{%- endcomment -%}

<article class="page">
  <div class="container page__container">
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'image' -%}
            {%- if block.settings.image -%}
              <figure class="page__image" {{ block.shopify_attributes }}>
                {% render 'responsive-image',
                   image: block.settings.image,
                   alt: block.settings.image.alt | default: page.title,
                   sizes: '(min-width:1024px) 760px, 100vw',
                   loading: 'lazy' %}
                {%- if block.settings.caption != blank -%}
                  <figcaption>{{ block.settings.caption }}</figcaption>
                {%- endif -%}
              </figure>
            {%- endif -%}

          {%- when 'rich_text' -%}
            <div class="page__rich-text rte" {{ block.shopify_attributes }}>
              {{ block.settings.content }}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    {%- endif -%}

    <header class="page__header">
      {% render 'breadcrumb' %}
      <h1 class="page__title">{{ page.title }}</h1>
    </header>

    <div class="page__content rte">
      {{ page.content }}
    </div>
  </div>
</article>

{% schema %}
{
  "name": "Page",
  "tag": "section",
  "class": "section section--page",
  "settings": [],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "caption", "label": "Caption" }
      ]
    },
    {
      "type": "rich_text",
      "name": "Rich text",
      "settings": [
        { "type": "richtext", "id": "content", "label": "Content" }
      ]
    }
  ],
  "presets": [{ "name": "Page" }]
}
{% endschema %}

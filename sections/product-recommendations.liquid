{% comment %}
  ZELEXTO THEME — sections/product-recommendations.liquid
  Shopify Product Recommendations API — rendered server-side via Section Rendering.
  Uses intent: 'related' by default.
{% endcomment %}

{%- if recommendations.performed? and recommendations.products_count > 0 -%}

  <section class="product-recs section" id="product-recs-{{ section.id }}">
    <div class="container">
      <div class="section-header animate-fade-in" data-animate="animate-fade-in">
        <h2 class="section-header__title">{{ section.settings.heading | default: 'You may also like' }}</h2>
      </div>

      <div class="product-recs__grid grid grid--products" data-stagger>
        {%- for product in recommendations.products -%}
          {%- render 'product-card',
            product: product,
            animation: 'animate-slide-up',
            animation_delay: forloop.index0 | times: 60 -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

{%- endif -%}

{%- unless recommendations.performed? -%}
  <!-- Placeholder that gets replaced by Section Rendering API -->
  <div
    id="product-recs-{{ section.id }}"
    data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.products_to_show }}&intent=related">
  </div>

  <script>
    (function () {
      'use strict';
      const container = document.getElementById('product-recs-{{ section.id }}');
      if (!container) return;

      fetch(container.dataset.url, {
        headers: { 'Accept': 'text/html, */*' }
      })
      .then(r => r.text())
      .then(html => {
        const doc = new DOMParser().parseFromString(html, 'text/html');
        const newSection = doc.querySelector('.product-recs, #product-recs-{{ section.id }}');
        if (newSection) {
          container.replaceWith(newSection);
          if (window.ThemeAnimations) window.ThemeAnimations.refresh();
        }
      })
      .catch(err => console.warn('[ProductRecs]', err));
    })();
  </script>
{%- endunless -%}

{% schema %}
{
  "name": "Product recommendations",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Section heading", "default": "You may also like" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 8, "step": 1, "default": 4 }
  ],
  "presets": [{ "name": "Product recommendations" }]
}
{% endschema %}

{%- comment -%}
  Zelexto v2 — sections/product-recommendations.liquid
  Shopify Recommendations API. Hydrated by quick-add.js / fetch on the
  outer <product-recommendations> element using Section Rendering API.
{%- endcomment -%}

{%- liquid
  assign limit = section.settings.products_to_show | default: 4
  assign intent = section.settings.intent | default: 'related'
  assign heading = section.settings.heading | default: 'You may also like'
-%}

<product-recommendations
  class="recommendations"
  data-module="quick-add.js"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-limit="{{ limit }}"
  data-intent="{{ intent }}"
  data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ limit }}&intent={{ intent }}">

  {%- if recommendations.performed and recommendations.products_count > 0 -%}
    <div class="container recommendations__container">
      <h2 class="recommendations__heading">{{ heading }}</h2>
      <div class="recommendations__grid grid">
        {%- for p in recommendations.products -%}
          {% render 'product-card', product: p, index: forloop.index %}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</product-recommendations>

{% schema %}
{
  "name": "Product recommendations",
  "tag": "section",
  "class": "section section--recommendations",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "You may also like" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 12, "step": 1, "default": 4 },
    {
      "type": "select",
      "id": "intent",
      "label": "Recommendation intent",
      "options": [
        { "value": "related", "label": "Related" },
        { "value": "complementary", "label": "Complementary" }
      ],
      "default": "related"
    }
  ],
  "presets": [{ "name": "Product recommendations" }]
}
{% endschema %}

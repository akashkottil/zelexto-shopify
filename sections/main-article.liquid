{%- comment -%}
  Zelexto v2 — sections/main-article.liquid
  Single article reader. Apple-style typography, narrow measure, share row.
{%- endcomment -%}

<article class="article">
  <div class="container article__container">
    <header class="article__header">
      {% render 'breadcrumb' %}
      {%- if article.tags.size > 0 -%}
        <div class="article__tags">
          {%- for tag in article.tags limit: 4 -%}
            <a href="{{ blog.url }}/tagged/{{ tag | handleize }}" class="pill">{{ tag }}</a>
          {%- endfor -%}
        </div>
      {%- endif -%}
      <h1 class="article__title">{{ article.title }}</h1>
      <div class="article__meta">
        <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%B %d, %Y' }}</time>
        {%- if section.settings.show_author -%}
          {%- assign author_name = article.author -%}
          <span class="article__byline">{{ 'blog.posted_by' | t: author: author_name }}</span>
        {%- endif -%}
      </div>
    </header>

    {%- if article.image and section.settings.show_featured_image -%}
      <figure class="article__hero">
        {% render 'responsive-image',
           image: article.image,
           alt: article.image.alt | default: article.title,
           sizes: '(min-width:1024px) 760px, 100vw',
           loading: 'eager',
           fetchpriority: 'high' %}
      </figure>
    {%- endif -%}

    <div class="article__content rte">
      {{ article.content }}
    </div>

    <footer class="article__footer">
      {%- if section.settings.show_share -%}
        <div class="article__share">
          <span>{{ 'blog.share' | t | default: 'Share' }}</span>
          <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url | url_encode }}&text={{ article.title | url_encode }}" target="_blank" rel="noopener" aria-label="Share on Twitter">
            {% render 'icon', name: 'x' %}
          </a>
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url | url_encode }}" target="_blank" rel="noopener" aria-label="Share on Facebook">
            {% render 'icon', name: 'facebook' %}
          </a>
          <a href="https://www.pinterest.com/pin/create/button/?url={{ shop.url }}{{ article.url | url_encode }}" target="_blank" rel="noopener" aria-label="Share on Pinterest">
            {% render 'icon', name: 'pinterest' %}
          </a>
          <a href="mailto:?subject={{ article.title | url_encode }}&body={{ shop.url }}{{ article.url | url_encode }}" aria-label="Share by email">
            {% render 'icon', name: 'mail' %}
          </a>
        </div>
      {%- endif -%}

      <nav class="article__nav" aria-label="Article navigation">
        {%- if blog.previous_article -%}
          <a href="{{ blog.previous_article }}" class="article__nav-link">
            {% render 'icon', name: 'arrow-left' %}
            <span>{{ 'blog.previous' | t | default: 'Previous post' }}</span>
          </a>
        {%- endif -%}
        <a href="{{ blog.url }}" class="article__nav-link article__nav-link--center">
          {{ 'blog.back_to_blog' | t | default: 'All posts' }}
        </a>
        {%- if blog.next_article -%}
          <a href="{{ blog.next_article }}" class="article__nav-link">
            <span>{{ 'blog.next' | t | default: 'Next post' }}</span>
            {% render 'icon', name: 'arrow-right' %}
          </a>
        {%- endif -%}
      </nav>
    </footer>
  </div>
</article>

{% schema %}
{
  "name": "Article",
  "tag": "section",
  "class": "section section--article",
  "settings": [
    { "type": "checkbox", "id": "show_featured_image", "label": "Show featured image", "default": true },
    { "type": "checkbox", "id": "show_author", "label": "Show author", "default": true },
    { "type": "checkbox", "id": "show_share", "label": "Show share buttons", "default": true }
  ],
  "presets": [{ "name": "Article" }]
}
{% endschema %}

{%- comment -%}
  FAQ — accordion built with native <details>.
{%- endcomment -%}

{%- liquid
  assign theme = section.settings.theme | default: 'light'
-%}

<section class="faq faq--{{ theme }}" data-section-id="{{ section.id }}" itemscope itemtype="https://schema.org/FAQPage">
  <div class="container faq__inner">
    <header class="faq__header" data-reveal="up">
      {%- if section.settings.eyebrow != blank -%}
        <p class="faq__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="faq__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </header>

    <div class="faq__list" data-stagger>
      {%- for block in section.blocks -%}
        <details class="faq__item" data-reveal="up" {{ block.shopify_attributes }} itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
          <summary class="faq__summary">
            <span itemprop="name">{{ block.settings.question }}</span>
            <span class="faq__icon" aria-hidden="true">
              {%- render 'icon', name: 'plus', class: 'icon faq__icon-plus' -%}
              {%- render 'icon', name: 'minus', class: 'icon faq__icon-minus' -%}
            </span>
          </summary>
          <div class="faq__answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
            <div itemprop="text">{{ block.settings.answer }}</div>
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} { display: block; }

  .faq {
    padding-block: clamp(var(--s-9), 12vh, var(--s-10));
    background: var(--c-bg);
    color: var(--c-ink);
  }
  .faq--soft { background: var(--c-surface); }
  .faq--dark { background: var(--c-bg-inv); color: var(--c-ink-inv); }

  .faq__inner { max-width: 880px; margin-inline: auto; }

  .faq__header { text-align: center; margin-bottom: var(--s-9); }
  .faq__eyebrow {
    margin: 0 0 var(--s-3);
    font-size: var(--fs-14);
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-ink-muted);
  }
  .faq--dark .faq__eyebrow { color: var(--c-ink-muted-inv); }
  .faq__heading {
    margin: 0;
    font-size: clamp(var(--fs-28), 4vw, var(--fs-56));
    font-weight: var(--weight-semibold);
    letter-spacing: -0.022em;
    line-height: 1.06;
  }

  .faq__list { display: flex; flex-direction: column; }

  .faq__item {
    border-bottom: 1px solid var(--c-line);
  }
  .faq--dark .faq__item { border-color: var(--c-line-inv); }

  .faq__summary {
    list-style: none;
    cursor: pointer;
    padding-block: var(--s-5);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--s-4);
    font-size: var(--fs-19);
    font-weight: var(--weight-medium);
    line-height: 1.4;
    transition: color var(--dur-fast) var(--ease-soft);
  }
  .faq__summary::-webkit-details-marker { display: none; }
  .faq__summary:hover { color: var(--c-ink-muted); }
  .faq--dark .faq__summary:hover { color: var(--c-ink-muted-inv); }

  .faq__icon {
    position: relative;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }
  .faq__icon .icon { position: absolute; inset: 0; transition: opacity var(--dur-fast) var(--ease-soft), transform var(--dur-base) var(--ease-apple); }
  .faq__icon-minus { opacity: 0; transform: scale(0.6); }
  .faq__item[open] .faq__icon-plus  { opacity: 0; transform: scale(0.6); }
  .faq__item[open] .faq__icon-minus { opacity: 1; transform: scale(1); }

  .faq__answer {
    padding-bottom: var(--s-5);
    color: var(--c-ink-muted);
    font-size: var(--fs-16);
    line-height: 1.6;
    max-width: 70ch;
  }
  .faq--dark .faq__answer { color: var(--c-ink-muted-inv); }

  /* Smooth reveal of answer */
  .faq__item[open] .faq__answer { animation: faq-open var(--dur-base) var(--ease-apple); }
  @keyframes faq-open {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .faq__item[open] .faq__answer { animation: none; }
  }
</style>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "select", "id": "theme", "label": "Theme",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "soft",  "label": "Soft" },
        { "value": "dark",  "label": "Dark" }
      ], "default": "light" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Frequently asked" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Questions, answered." }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Question",
      "settings": [
        { "type": "text",     "id": "question", "label": "Question", "default": "How long does shipping take?" },
        { "type": "richtext", "id": "answer",   "label": "Answer",   "default": "<p>Standard delivery in 2–4 business days within India. Free over ₹999.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "qa", "settings": { "question": "How long does shipping take?",         "answer": "<p>Standard delivery in 2–4 business days within India. Free over ₹999.</p>" } },
        { "type": "qa", "settings": { "question": "What's your return policy?",           "answer": "<p>30-day returns on unused items. We'll arrange the pickup at no charge.</p>" } },
        { "type": "qa", "settings": { "question": "Do you offer Cash on Delivery?",      "answer": "<p>Yes — COD is available on most pincodes in India. Enter your pincode on the product page to check.</p>" } },
        { "type": "qa", "settings": { "question": "Can I pay via UPI / Razorpay?",       "answer": "<p>Absolutely. UPI, all major cards, RuPay, netbanking, and EMI are supported via Razorpay.</p>" } },
        { "type": "qa", "settings": { "question": "Is partial payment available?",      "answer": "<p>Yes. Pay 20% now, the rest on delivery — available on orders above ₹999.</p>" } }
      ]
    }
  ]
}
{% endschema %}

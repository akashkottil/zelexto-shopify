{%- liquid
  assign bg = section.settings.bg | default: 'bg'
-%}

<section class="faq faq--{{ bg }} section" data-section-id="{{ section.id }}">
  <div class="container faq__container">
    <header class="faq__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="faq__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="faq__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="faq__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </header>

    <div class="faq__list" itemscope itemtype="https://schema.org/FAQPage">
      {%- for block in section.blocks -%}
        {%- if block.type == 'qa' -%}
          <details
            class="faq__item"
            itemscope
            itemprop="mainEntity"
            itemtype="https://schema.org/Question"
            {{ block.shopify_attributes }}
            {% if block.settings.open_by_default %}open{% endif %}>
            <summary class="faq__question" itemprop="name">
              <span>{{ block.settings.question }}</span>
              <span class="faq__icon" aria-hidden="true">
                <span class="faq__icon-bar"></span>
                <span class="faq__icon-bar"></span>
              </span>
            </summary>
            <div
              class="faq__answer"
              itemscope
              itemprop="acceptedAnswer"
              itemtype="https://schema.org/Answer">
              <div itemprop="text">{{ block.settings.answer }}</div>
            </div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .faq--bg{background:var(--c-bg)}
  #shopify-section-{{ section.id }} .faq--surface{background:var(--c-surface)}
  #shopify-section-{{ section.id }} .faq--elev{background:var(--c-elev)}

  #shopify-section-{{ section.id }} .faq__container{max-width:880px}
  #shopify-section-{{ section.id }} .faq__header{margin-bottom:var(--s-7);text-align:center}
  #shopify-section-{{ section.id }} .faq__eyebrow{
    font-size:var(--fs-14);font-weight:var(--weight-medium);
    letter-spacing:.04em;text-transform:uppercase;
    color:var(--c-ink-muted);margin-bottom:var(--s-2);
  }
  #shopify-section-{{ section.id }} .faq__heading{
    font-size:clamp(var(--fs-28), 4vw, var(--fs-56));
    line-height:var(--lh-snug);
  }
  #shopify-section-{{ section.id }} .faq__sub{
    margin-top:var(--s-3);color:var(--c-ink-muted);font-size:var(--fs-19);
  }

  #shopify-section-{{ section.id }} .faq__list{display:flex;flex-direction:column;gap:0}
  #shopify-section-{{ section.id }} .faq__item{
    border-top:1px solid var(--c-line);padding:var(--s-5) 0;
  }
  #shopify-section-{{ section.id }} .faq__item:last-child{border-bottom:1px solid var(--c-line)}
  #shopify-section-{{ section.id }} .faq__question{
    display:flex;align-items:center;justify-content:space-between;
    gap:var(--s-4);
    font-size:var(--fs-19);font-weight:var(--weight-medium);
    cursor:pointer;list-style:none;
    color:var(--c-ink);min-height:48px;
  }
  #shopify-section-{{ section.id }} .faq__question::-webkit-details-marker{display:none}
  #shopify-section-{{ section.id }} .faq__icon{
    position:relative;width:18px;height:18px;flex-shrink:0;
  }
  #shopify-section-{{ section.id }} .faq__icon-bar{
    position:absolute;left:50%;top:50%;width:18px;height:2px;
    background:var(--c-ink);border-radius:1px;
    transition:transform var(--dur-fast) var(--ease-standard);
  }
  #shopify-section-{{ section.id }} .faq__icon-bar:nth-child(1){transform:translate(-50%,-50%)}
  #shopify-section-{{ section.id }} .faq__icon-bar:nth-child(2){transform:translate(-50%,-50%) rotate(90deg)}
  #shopify-section-{{ section.id }} details[open] .faq__icon-bar:nth-child(2){transform:translate(-50%,-50%) rotate(0deg)}
  #shopify-section-{{ section.id }} .faq__answer{
    margin-top:var(--s-3);font-size:var(--fs-16);
    color:var(--c-ink-muted);line-height:var(--lh-body);
    max-width:72ch;
  }
  #shopify-section-{{ section.id }} .faq__answer p{margin:0 0 var(--s-3)}
  #shopify-section-{{ section.id }} .faq__answer p:last-child{margin:0}
</style>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Help" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    {
      "type": "select", "id": "bg", "label": "Background",
      "options": [
        { "value": "bg",      "label": "White" },
        { "value": "surface", "label": "Surface" },
        { "value": "elev",    "label": "Elevated" }
      ],
      "default": "bg"
    }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "What is your shipping policy?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>We deliver across India in 3–7 business days. Free shipping on orders over ₹999.</p>" },
        { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": false }
      ]
    }
  ],
  "max_blocks": 24,
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "qa", "settings": { "question": "When will my order arrive?",          "answer": "<p>Most orders ship within 24 hours and arrive in 3–7 business days.</p>" } },
        { "type": "qa", "settings": { "question": "Do you accept Cash on Delivery?",      "answer": "<p>Yes — COD is available across most pincodes in India. A small fee may apply.</p>" } },
        { "type": "qa", "settings": { "question": "Can I get a GST invoice?",             "answer": "<p>Absolutely. Add your GSTIN at checkout and we’ll email a tax invoice.</p>" } },
        { "type": "qa", "settings": { "question": "What is your return policy?",          "answer": "<p>30-day returns on unused items in original packaging. Refunds in 5–7 business days.</p>" } }
      ]
    }
  ]
}
{% endschema %}

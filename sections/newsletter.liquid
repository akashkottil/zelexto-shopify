{%- liquid
  assign bg = section.settings.background | default: 'elev'
-%}

<section class="newsletter newsletter--{{ bg }} section" data-section-id="{{ section.id }}">
  <div class="container newsletter__container">
    {%- if section.settings.eyebrow != blank -%}
      <p class="newsletter__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="newsletter__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <p class="newsletter__body">{{ section.settings.body }}</p>
    {%- endif -%}

    {%- form 'customer', class: 'newsletter__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="hidden" name="contact[accepts_marketing]" value="true">

      <div class="newsletter__field">
        <label class="sr-only" for="newsletter-{{ section.id }}-email">{{ section.settings.placeholder | default: 'Email address' }}</label>
        <input
          type="email"
          id="newsletter-{{ section.id }}-email"
          name="contact[email]"
          class="newsletter__input"
          placeholder="{{ section.settings.placeholder | default: 'Email address' }}"
          autocomplete="email"
          required
          aria-required="true">
        <button type="submit" class="btn btn--primary newsletter__submit">
          {{ section.settings.submit_label | default: 'Subscribe' }}
        </button>
      </div>

      {%- if form.errors -%}
        <p class="newsletter__error" role="alert">{{ form.errors | default_errors }}</p>
      {%- endif -%}
      {%- if form.posted_successfully? -%}
        <p class="newsletter__success" role="status">{{ section.settings.success_message | default: 'Thanks for subscribing.' }}</p>
      {%- endif -%}

      {%- if section.settings.disclaimer != blank -%}
        <p class="newsletter__disclaimer">{{ section.settings.disclaimer }}</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .newsletter--bg{background:var(--c-bg)}
  #shopify-section-{{ section.id }} .newsletter--surface{background:var(--c-surface)}
  #shopify-section-{{ section.id }} .newsletter--elev{background:var(--c-elev)}
  #shopify-section-{{ section.id }} .newsletter--ink{background:var(--c-ink);color:var(--c-bg)}

  #shopify-section-{{ section.id }} .newsletter__container{
    max-width:680px;text-align:center;
  }
  #shopify-section-{{ section.id }} .newsletter__eyebrow{
    font-size:var(--fs-14);font-weight:var(--weight-medium);
    letter-spacing:.04em;text-transform:uppercase;
    color:var(--c-ink-muted);margin-bottom:var(--s-2);
  }
  #shopify-section-{{ section.id }} .newsletter--ink .newsletter__eyebrow{color:rgba(255,255,255,.7)}
  #shopify-section-{{ section.id }} .newsletter__heading{
    font-size:clamp(var(--fs-28), 4vw, var(--fs-56));
    line-height:var(--lh-snug);
  }
  #shopify-section-{{ section.id }} .newsletter__body{
    margin-top:var(--s-3);font-size:var(--fs-19);
    color:var(--c-ink-muted);max-width:60ch;margin-inline:auto;
  }
  #shopify-section-{{ section.id }} .newsletter--ink .newsletter__body{color:rgba(255,255,255,.78)}

  #shopify-section-{{ section.id }} .newsletter__form{margin-top:var(--s-5)}
  #shopify-section-{{ section.id }} .newsletter__field{
    display:flex;gap:var(--s-2);
    background:var(--c-bg);border:1px solid var(--c-line);
    border-radius:var(--radius-pill);padding:var(--s-1);
    max-width:480px;margin-inline:auto;
  }
  #shopify-section-{{ section.id }} .newsletter--ink .newsletter__field{
    background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.18);
  }
  #shopify-section-{{ section.id }} .newsletter__input{
    flex:1;background:transparent;border:0;outline:none;
    padding:var(--s-2) var(--s-4);min-height:44px;
    font-size:var(--fs-16);color:inherit;
  }
  #shopify-section-{{ section.id }} .newsletter__submit{flex-shrink:0}
  #shopify-section-{{ section.id }} .newsletter__error{
    color:var(--c-danger);font-size:var(--fs-14);margin-top:var(--s-3);
  }
  #shopify-section-{{ section.id }} .newsletter__success{
    color:var(--c-success);font-size:var(--fs-14);margin-top:var(--s-3);
  }
  #shopify-section-{{ section.id }} .newsletter__disclaimer{
    margin-top:var(--s-3);font-size:var(--fs-12);
    color:var(--c-ink-muted);
  }
  #shopify-section-{{ section.id }} .newsletter--ink .newsletter__disclaimer{color:rgba(255,255,255,.6)}
</style>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Stay in touch" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Be first to know." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Subscribe for early access to new launches, members-only offers and the occasional well-written email." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Email address" },
    { "type": "text", "id": "submit_label", "label": "Submit label", "default": "Subscribe" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Thanks — check your inbox." },
    { "type": "richtext", "id": "disclaimer", "label": "Disclaimer", "default": "<p>By subscribing you agree to receive marketing emails. Unsubscribe anytime.</p>" },
    {
      "type": "select", "id": "background", "label": "Background",
      "options": [
        { "value": "bg",      "label": "White" },
        { "value": "surface", "label": "Surface" },
        { "value": "elev",    "label": "Elevated" },
        { "value": "ink",     "label": "Dark" }
      ],
      "default": "elev"
    }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}

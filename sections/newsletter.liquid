{%- comment -%}
  Newsletter — large, centred email-capture block.
{%- endcomment -%}

{%- liquid
  assign theme = section.settings.theme | default: 'dark'
-%}

<section class="newsletter newsletter--{{ theme }}" data-section-id="{{ section.id }}">
  <div class="container newsletter__inner" data-stagger>
    {%- if section.settings.eyebrow != blank -%}
      <p class="newsletter__eyebrow" data-reveal="up">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="newsletter__heading" data-reveal="up">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="newsletter__body" data-reveal="up">{{ section.settings.body }}</div>
    {%- endif -%}

    <div data-reveal="up" class="newsletter__form-wrap">
    {%- form 'customer', class: 'newsletter__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <label class="sr-only" for="newsletter-email-{{ section.id }}">{{ 'newsletter.placeholder' | t }}</label>
      <div class="newsletter__field">
        <input
          type="email"
          name="contact[email]"
          id="newsletter-email-{{ section.id }}"
          class="newsletter__input"
          placeholder="{{ 'newsletter.placeholder' | t }}"
          required
          autocomplete="email"
        >
        <button type="submit" class="newsletter__submit btn btn--primary">
          <span>{{ section.settings.button_label | default: 'newsletter.submit' | t }}</span>
          {%- render 'icon', name: 'arrow-right', class: 'icon icon--sm' -%}
        </button>
      </div>

      {%- if form.posted_successfully? -%}
        <p class="newsletter__success" role="status">{{ 'newsletter.success' | t }}</p>
      {%- elsif form.errors -%}
        <p class="newsletter__error" role="alert">{{ 'newsletter.error' | t }}</p>
      {%- endif -%}
    {%- endform -%}
    </div>

    {%- if section.settings.fineprint != blank -%}
      <p class="newsletter__fineprint" data-reveal="up">{{ section.settings.fineprint }}</p>
    {%- endif -%}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} { display: block; }

  .newsletter {
    padding-block: clamp(var(--s-9), 14vh, var(--s-10));
    background: var(--c-bg);
    color: var(--c-ink);
  }
  .newsletter--soft { background: var(--c-surface); }
  .newsletter--dark { background: var(--c-bg-inv); color: var(--c-ink-inv); }

  .newsletter__inner {
    max-width: 720px;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
    align-items: center;
  }
  .newsletter__eyebrow {
    margin: 0;
    font-size: var(--fs-14);
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-ink-muted);
  }
  .newsletter--dark .newsletter__eyebrow { color: var(--c-ink-muted-inv); }
  .newsletter__heading {
    margin: 0;
    font-size: clamp(var(--fs-28), 4vw, var(--fs-56));
    font-weight: var(--weight-semibold);
    letter-spacing: -0.022em;
    line-height: 1.06;
    max-width: 22ch;
  }
  .newsletter__body {
    margin: 0;
    color: var(--c-ink-muted);
    font-size: var(--fs-19);
    line-height: 1.5;
    max-width: 56ch;
  }
  .newsletter--dark .newsletter__body { color: var(--c-ink-muted-inv); }

  .newsletter__form {
    width: 100%;
    max-width: 520px;
    margin-top: var(--s-4);
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }
  .newsletter__field {
    display: flex;
    background: var(--c-bg);
    border: 1px solid var(--c-line);
    border-radius: var(--radius-pill);
    overflow: hidden;
    transition: border-color var(--dur-fast) var(--ease-soft), box-shadow var(--dur-fast) var(--ease-soft);
  }
  .newsletter--dark .newsletter__field { background: var(--c-elev-inv); border-color: var(--c-line-inv); }
  .newsletter__field:focus-within {
    border-color: var(--c-ink);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--c-ink) 10%, transparent);
  }
  .newsletter--dark .newsletter__field:focus-within {
    border-color: var(--c-ink-inv);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--c-ink-inv) 18%, transparent);
  }
  .newsletter__input {
    flex: 1;
    border: 0;
    background: transparent;
    padding: 0 var(--s-5);
    height: 56px;
    font-size: var(--fs-16);
    color: inherit;
  }
  .newsletter__input::placeholder { color: var(--c-ink-muted); }
  .newsletter__input:focus { outline: none; }
  .newsletter__submit {
    border-radius: 0;
    padding-inline: var(--s-5);
    margin: 4px;
    border-radius: var(--radius-pill);
  }
  .newsletter--dark .btn--primary { background: #fff; color: #000; }
  .newsletter--dark .btn--primary:hover { background: #e8e8ed; }

  .newsletter__success { color: var(--c-success); font-weight: var(--weight-medium); }
  .newsletter__error   { color: var(--c-danger);  font-weight: var(--weight-medium); }
  .newsletter__fineprint {
    margin: var(--s-2) 0 0;
    font-size: var(--fs-14);
    color: var(--c-ink-muted);
  }
  .newsletter--dark .newsletter__fineprint { color: var(--c-ink-muted-inv); }
</style>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "select", "id": "theme", "label": "Theme",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "soft",  "label": "Soft" },
        { "value": "dark",  "label": "Dark" }
      ], "default": "dark" },
    { "type": "text",     "id": "eyebrow", "label": "Eyebrow", "default": "Stay close" },
    { "type": "text",     "id": "heading", "label": "Heading", "default": "Be the first to know." },
    { "type": "richtext", "id": "body",    "label": "Body",    "default": "<p>Drops, restocks, and stories — straight to your inbox.</p>" },
    { "type": "text",     "id": "button_label", "label": "Button label", "default": "Subscribe" },
    { "type": "richtext", "id": "fineprint", "label": "Fine print",
      "default": "<p>By subscribing you agree to our privacy policy. Unsubscribe anytime.</p>" }
  ],
  "presets": [
    { "name": "Newsletter" }
  ]
}
{% endschema %}

{%- comment -%}
  Zelexto v2 — sections/customers-account.liquid
  Customer dashboard: orders + addresses + account details.
{%- endcomment -%}

<div class="account container">
  <header class="account__header">
    <div>
      {%- liquid
        assign greeting_name = customer.first_name | default: customer.email
      -%}
      <p class="account__greeting">{{ 'account.welcome' | t: name: greeting_name }}</p>
      <h1 class="account__title">{{ 'account.title' | t | default: 'Account' }}</h1>
    </div>
    <a href="{{ routes.account_logout_url }}" class="btn btn--ghost btn--sm">{{ 'account.logout' | t | default: 'Sign out' }}</a>
  </header>

  <section class="account__section">
    <h2 class="account__section-title">{{ 'account.order_history' | t | default: 'Orders' }}</h2>
    {%- if customer.orders.size > 0 -%}
      <div class="account-orders">
        {%- for order in customer.orders -%}
          <a href="{{ order.customer_url }}" class="account-order">
            <div class="account-order__top">
              <strong>{{ 'account.order_number' | t: number: order.name }}</strong>
              <span class="pill">{{ order.financial_status_label }}</span>
            </div>
            <div class="account-order__meta">
              {%- assign order_date = order.created_at | date: '%b %d, %Y' -%}
              <time datetime="{{ order.created_at | date: '%Y-%m-%d' }}">{{ 'account.order_date' | t: date: order_date }}</time>
              <span data-money-cents="{{ order.total_price }}">{{ order.total_price | money }}</span>
            </div>
            <ul class="account-order__lines" role="list">
              {%- for li in order.line_items limit: 3 -%}
                <li>{{ li.title | truncate: 48 }} × {{ li.quantity }}</li>
              {%- endfor -%}
              {%- if order.line_items.size > 3 -%}
                <li>+ {{ order.line_items.size | minus: 3 }} more</li>
              {%- endif -%}
            </ul>
          </a>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="account__empty">
        <p>{{ 'account.no_orders' | t | default: 'You haven\'t placed any orders yet.' }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">{{ 'account.shop_now' | t | default: 'Start shopping' }}</a>
      </div>
    {%- endif -%}
  </section>

  <section class="account__section">
    <div class="account__section-head">
      <h2 class="account__section-title">{{ 'account.addresses' | t | default: 'Addresses' }}</h2>
      <a href="{{ routes.account_addresses_url }}" class="btn btn--ghost btn--sm">{{ 'account.manage' | t | default: 'Manage' }}</a>
    </div>
    {%- if customer.addresses.size > 0 -%}
      <div class="account-addresses">
        {%- for address in customer.addresses -%}
          <article class="account-address{% if address == customer.default_address %} is-default{% endif %}">
            {%- if address == customer.default_address -%}
              <span class="pill account-address__pill">{{ 'account.default' | t | default: 'Default' }}</span>
            {%- endif -%}
            <div class="account-address__body">{{ address | format_address }}</div>
          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="account__muted">{{ 'account.no_addresses' | t | default: 'No saved addresses.' }}</p>
    {%- endif -%}
  </section>

  <section class="account__section">
    <h2 class="account__section-title">{{ 'account.account_details' | t | default: 'Account details' }}</h2>
    <dl class="account-details">
      <div><dt>{{ 'account.name' | t | default: 'Name' }}</dt><dd>{{ customer.name | default: '—' }}</dd></div>
      <div><dt>{{ 'account.email' | t | default: 'Email' }}</dt><dd>{{ customer.email }}</dd></div>
      {%- if customer.phone != blank -%}
        <div><dt>{{ 'account.phone' | t | default: 'Phone' }}</dt><dd>{{ customer.phone }}</dd></div>
      {%- endif -%}
    </dl>
  </section>
</div>

{% schema %}
{
  "name": "Customer account",
  "tag": "section",
  "class": "section section--account",
  "settings": [],
  "presets": [{ "name": "Customer account" }]
}
{% endschema %}

{%- comment -%}
  Zelexto v2 — sections/main-blog.liquid
  Blog listing. Apple-style article cards in a responsive grid.
{%- endcomment -%}

{%- liquid
  assign per_page = section.settings.posts_per_page | default: 12
-%}

<div class="blog">
  <div class="container">
    <header class="blog__header">
      {% render 'breadcrumb' %}
      <h1 class="blog__title">{{ blog.title }}</h1>
      {%- if section.settings.subheading != blank -%}
        <p class="blog__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </header>

    {%- paginate blog.articles by per_page -%}
      {%- if blog.articles.size > 0 -%}
        <ul class="blog__grid grid" role="list">
          {%- for article in blog.articles -%}
            <li class="article-card">
              {%- if article.image -%}
                <a href="{{ article.url }}" class="article-card__media aspect" style="aspect-ratio: 16/10;" tabindex="-1">
                  {% render 'responsive-image',
                     image: article.image,
                     alt: article.image.alt | default: article.title,
                     sizes: '(min-width:1024px) 33vw, (min-width:640px) 50vw, 100vw',
                     loading: 'lazy',
                     aspect_ratio: '16/10' %}
                </a>
              {%- endif -%}
              <div class="article-card__body">
                {%- if article.tags.size > 0 -%}
                  <div class="article-card__tags">
                    {%- for tag in article.tags limit: 2 -%}
                      <span class="pill">{{ tag }}</span>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
                <h2 class="article-card__title">
                  <a href="{{ article.url }}">{{ article.title }}</a>
                </h2>
                {%- if article.excerpt_or_content != blank -%}
                  <p class="article-card__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 140 }}</p>
                {%- endif -%}
                <div class="article-card__meta">
                  <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%b %d, %Y' }}</time>
                  {%- if section.settings.show_author -%}<span> · {{ article.author }}</span>{%- endif -%}
                </div>
              </div>
            </li>
          {%- endfor -%}
        </ul>
        {% render 'pagination', paginate: paginate %}
      {%- else -%}
        <p class="blog__empty">{{ 'blog.empty' | t | default: 'No posts yet.' }}</p>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.blog.name",
  "tag": "section",
  "class": "section section--blog",
  "settings": [
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "checkbox", "id": "show_author", "label": "Show author", "default": true },
    { "type": "range", "id": "posts_per_page", "label": "Posts per page", "min": 3, "max": 24, "step": 3, "default": 12 }
  ],
  "presets": [{ "name": "Blog" }]
}
{% endschema %}

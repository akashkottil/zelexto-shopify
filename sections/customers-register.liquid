{%- comment -%}
  Zelexto v2 — sections/customers-register.liquid
  Create-account form.
{%- endcomment -%}

<div class="auth container">
  <div class="auth__card">
    <header class="auth__header">
      <h1 class="auth__title">{{ 'account.register' | t | default: 'Create account' }}</h1>
      <p class="auth__sub">{{ 'account.register_sub' | t | default: 'Faster checkout, order history, and saved addresses.' }}</p>
    </header>

    {%- form 'create_customer', class: 'auth__form' -%}
      {%- if form.errors -%}
        <div class="auth__errors" role="alert">{{ form.errors | default_errors }}</div>
      {%- endif -%}

      <div class="auth__row">
        <label class="field">
          <span class="field__label">{{ 'account.first_name' | t | default: 'First name' }}</span>
          <input type="text" class="field__input" name="customer[first_name]" autocomplete="given-name" required>
        </label>
        <label class="field">
          <span class="field__label">{{ 'account.last_name' | t | default: 'Last name' }}</span>
          <input type="text" class="field__input" name="customer[last_name]" autocomplete="family-name" required>
        </label>
      </div>

      <label class="field">
        <span class="field__label">{{ 'account.email' | t | default: 'Email' }}</span>
        <input type="email" class="field__input" name="customer[email]" autocomplete="email" autocapitalize="off" required>
      </label>

      <label class="field">
        <span class="field__label">{{ 'account.password' | t | default: 'Password' }}</span>
        <input type="password" class="field__input" name="customer[password]" autocomplete="new-password" required>
      </label>

      <button type="submit" class="btn btn--primary btn--full">{{ 'account.register' | t | default: 'Create account' }}</button>

      <p class="auth__links">
        {{ 'account.have_account' | t | default: 'Already have an account?' }}
        <a href="{{ routes.account_login_url }}">{{ 'account.login' | t | default: 'Sign in' }}</a>
      </p>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Customer register",
  "tag": "section",
  "class": "section section--auth",
  "settings": [],
  "presets": [{ "name": "Customer register" }]
}
{% endschema %}

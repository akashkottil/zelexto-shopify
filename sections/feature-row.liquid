{%- liquid
  assign bg = section.settings.bg | default: 'bg'
-%}

<section class="feature-row feature-row--{{ bg }} section" data-section-id="{{ section.id }}">
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.eyebrow != blank -%}
      <header class="feature-row__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="feature-row__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="feature-row__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="feature-row__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="feature-row__list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign reverse = forloop.index | modulo: 2 | minus: 1 | abs
          assign image_side = block.settings.image_side
          if image_side == 'auto'
            if reverse == 0
              assign image_side = 'left'
            else
              assign image_side = 'right'
            endif
          endif
        -%}
        <article
          class="feature-row__item feature-row__item--image-{{ image_side }}"
          {{ block.shopify_attributes }}>

          <div class="feature-row__media">
            {%- if block.settings.image != blank -%}
              <div class="aspect aspect--4/3">
                {%- render 'responsive-image',
                  image: block.settings.image,
                  alt: block.settings.image.alt | default: block.settings.heading,
                  sizes: '(min-width: 769px) 50vw, 100vw',
                  loading: 'lazy'
                -%}
              </div>
            {%- else -%}
              <div class="aspect aspect--4/3 feature-row__placeholder" aria-hidden="true">
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>

          <div class="feature-row__body">
            {%- if block.settings.eyebrow != blank -%}
              <p class="feature-row__item-eyebrow">{{ block.settings.eyebrow }}</p>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h3 class="feature-row__item-heading">{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <div class="feature-row__item-body">{{ block.settings.body }}</div>
            {%- endif -%}
            {%- if block.settings.cta_label != blank -%}
              <a href="{{ block.settings.cta_url | default: '#' }}" class="feature-row__cta">
                {{ block.settings.cta_label }} {%- render 'icon', name: 'arrow-right', class: 'icon icon--xs' -%}
              </a>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .feature-row--bg{background:var(--c-bg);color:var(--c-ink)}
  #shopify-section-{{ section.id }} .feature-row--surface{background:var(--c-surface);color:var(--c-ink)}
  #shopify-section-{{ section.id }} .feature-row--elev{background:var(--c-elev);color:var(--c-ink)}
  #shopify-section-{{ section.id }} .feature-row--ink{background:var(--c-ink);color:var(--c-bg)}

  #shopify-section-{{ section.id }} .feature-row__header{
    max-width:760px;margin:0 auto var(--s-7);text-align:center;
  }
  #shopify-section-{{ section.id }} .feature-row__eyebrow{
    font-size:var(--fs-14);font-weight:var(--weight-medium);
    letter-spacing:.04em;text-transform:uppercase;
    color:var(--c-ink-muted);margin-bottom:var(--s-2);
  }
  #shopify-section-{{ section.id }} .feature-row--ink .feature-row__eyebrow{color:rgba(255,255,255,.7)}
  #shopify-section-{{ section.id }} .feature-row__heading{
    font-size:clamp(var(--fs-28), 4vw, var(--fs-56));
    line-height:var(--lh-snug);
  }
  #shopify-section-{{ section.id }} .feature-row__subheading{
    margin-top:var(--s-3);font-size:var(--fs-19);color:var(--c-ink-muted);
  }
  #shopify-section-{{ section.id }} .feature-row--ink .feature-row__subheading{color:rgba(255,255,255,.7)}

  #shopify-section-{{ section.id }} .feature-row__list{display:grid;gap:var(--s-8)}

  #shopify-section-{{ section.id }} .feature-row__item{
    display:grid;grid-template-columns:1fr 1fr;
    gap:clamp(var(--s-5), 6vw, var(--s-8));
    align-items:center;
  }
  #shopify-section-{{ section.id }} .feature-row__item--image-right .feature-row__media{order:2}
  #shopify-section-{{ section.id }} .feature-row__item--image-right .feature-row__body{order:1}

  @media (max-width: 768px){
    #shopify-section-{{ section.id }} .feature-row__item,
    #shopify-section-{{ section.id }} .feature-row__item--image-right{
      grid-template-columns:1fr;
    }
    #shopify-section-{{ section.id }} .feature-row__item--image-right .feature-row__media{order:0}
    #shopify-section-{{ section.id }} .feature-row__item--image-right .feature-row__body{order:0}
  }

  #shopify-section-{{ section.id }} .feature-row__media{border-radius:var(--radius-lg);overflow:hidden}
  #shopify-section-{{ section.id }} .feature-row__placeholder{background:var(--c-elev);color:var(--c-ink-muted)}
  #shopify-section-{{ section.id }} .feature-row__placeholder svg{width:100%;height:100%}

  #shopify-section-{{ section.id }} .feature-row__item-eyebrow{
    font-size:var(--fs-12);font-weight:var(--weight-medium);
    letter-spacing:.06em;text-transform:uppercase;
    color:var(--c-ink-muted);margin-bottom:var(--s-2);
  }
  #shopify-section-{{ section.id }} .feature-row__item-heading{
    font-size:clamp(var(--fs-21), 3vw, var(--fs-40));
    line-height:var(--lh-snug);margin-bottom:var(--s-3);
  }
  #shopify-section-{{ section.id }} .feature-row__item-body{
    font-size:var(--fs-16);line-height:var(--lh-body);
    color:var(--c-ink-muted);max-width:60ch;
  }
  #shopify-section-{{ section.id }} .feature-row--ink .feature-row__item-body,
  #shopify-section-{{ section.id }} .feature-row--ink .feature-row__item-eyebrow{color:rgba(255,255,255,.78)}
  #shopify-section-{{ section.id }} .feature-row__item-body p{margin:0 0 var(--s-3)}
  #shopify-section-{{ section.id }} .feature-row__item-body p:last-child{margin:0}

  #shopify-section-{{ section.id }} .feature-row__cta{
    display:inline-flex;align-items:center;gap:var(--s-1);
    margin-top:var(--s-4);
    color:var(--c-accent);font-weight:var(--weight-medium);
  }
  #shopify-section-{{ section.id }} .feature-row__cta:hover{text-decoration:underline}
  #shopify-section-{{ section.id }} .feature-row--ink .feature-row__cta{color:#fff}
</style>

{% schema %}
{
  "name": "Feature row",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built better, on purpose." },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    {
      "type": "select", "id": "bg", "label": "Background",
      "options": [
        { "value": "bg",      "label": "White" },
        { "value": "surface", "label": "Surface" },
        { "value": "elev",    "label": "Elevated" },
        { "value": "ink",     "label": "Dark" }
      ],
      "default": "bg"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Made with care." },
        { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Tell the story behind this section. Use simple, generous copy.</p>" },
        { "type": "text", "id": "cta_label", "label": "CTA label" },
        { "type": "url",  "id": "cta_url",   "label": "CTA link" },
        {
          "type": "select", "id": "image_side", "label": "Image position",
          "options": [
            { "value": "auto",  "label": "Auto-alternate" },
            { "value": "left",  "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "auto"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Feature row",
      "blocks": [
        { "type": "row" },
        { "type": "row" }
      ]
    }
  ]
}
{% endschema %}

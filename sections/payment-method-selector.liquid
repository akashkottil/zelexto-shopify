{%- comment -%}
  Payment method selector — section wrapper.

  Delegates rendering to snippets/payment-method-selector.liquid so the same UI
  can be rendered inside the cart drawer (via {% render %}) or placed onto a
  template by a merchant via the theme editor.

  All shared CSS lives in this section so the markup can also be rendered
  standalone via the snippet without losing styling on its first appearance.
{%- endcomment -%}

{%- render 'payment-method-selector',
    context: section.settings.context,
    show_when_eligible_only: section.settings.show_when_eligible_only,
    id: section.id
-%}

<style>
  .payment-selector { display: block; }
  .payment-selector__legend {
    font-family: var(--font-display);
    font-size: var(--fs-19);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--s-3);
    padding: 0;
  }
  .payment-selector__group {
    border: 0;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .payment-selector__card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--s-3);
    padding: var(--s-4);
    border: 1px solid var(--c-line);
    border-radius: var(--radius-md);
    background: var(--c-bg);
    cursor: pointer;
    transition: border-color var(--dur-fast) var(--ease-standard),
                background var(--dur-fast) var(--ease-standard);
  }
  .payment-selector__card:hover { background: var(--c-elev); }
  .payment-selector__card:has(.payment-selector__radio:checked) {
    border-color: var(--c-accent);
    background: color-mix(in srgb, var(--c-accent) 6%, var(--c-bg));
  }
  .payment-selector__radio {
    width: 18px;
    height: 18px;
    accent-color: var(--c-accent);
  }
  .payment-selector__body {
    display: flex;
    flex-direction: column;
    gap: var(--s-1);
  }
  .payment-selector__title {
    font-weight: var(--weight-medium);
    color: var(--c-ink);
  }
  .payment-selector__desc {
    font-size: var(--fs-14);
    color: var(--c-ink-muted);
  }
  .payment-selector__amount {
    font-family: var(--font-display);
    font-weight: var(--weight-semibold);
    color: var(--c-ink);
  }
  .payment-selector__status {
    margin-top: var(--s-3);
    font-size: var(--fs-14);
    color: var(--c-success);
  }
</style>

{% schema %}
{
  "name": "Payment method selector",
  "settings": [
    {
      "type": "select",
      "id": "context",
      "label": "Context",
      "options": [
        { "value": "cart", "label": "Cart page" },
        { "value": "drawer", "label": "Cart drawer" },
        { "value": "checkout", "label": "Pre-checkout block" }
      ],
      "default": "cart"
    },
    {
      "type": "checkbox",
      "id": "show_when_eligible_only",
      "label": "Show partial only when cart total meets minimum",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Payment method selector"
    }
  ]
}
{% endschema %}

{%- comment -%}
  Hero — Apple-style full-bleed showpiece.

  - Optional background image (or rich SVG fallback)
  - Optional theme: light (white bg) or dark (black bg, white text)
  - Eyebrow / Headline / Body / dual CTAs
  - Scroll-revealed copy with stagger
{%- endcomment -%}

{%- liquid
  assign theme = section.settings.theme | default: 'light'
  assign height = section.settings.height | default: 'large'
  assign overlay = section.settings.overlay_opacity | default: 0
  assign content_align = section.settings.content_align | default: 'center'
  assign img = section.settings.image
  assign img_mobile = section.settings.image_mobile
-%}

<section
  class="hero hero--{{ theme }} hero--{{ height }} hero--align-{{ content_align }}"
  data-section-id="{{ section.id }}"
>
  <div class="hero__media" aria-hidden="true">
    {%- if img != blank -%}
      {%- render 'responsive-image',
          image: img,
          alt: '',
          sizes: '100vw',
          widths: '750,1100,1500,1900,2400',
          loading: 'eager',
          fetchpriority: 'high',
          class: 'hero__image hero__image--desktop' -%}
      {%- if img_mobile != blank -%}
        {%- render 'responsive-image',
            image: img_mobile,
            alt: '',
            sizes: '100vw',
            widths: '480,750,900,1100',
            loading: 'eager',
            fetchpriority: 'high',
            class: 'hero__image hero__image--mobile' -%}
      {%- endif -%}
    {%- else -%}
      {%- render 'demo-image', kind: 'hero', class: 'hero__image hero__image--demo' -%}
    {%- endif -%}

    {%- if overlay > 0 -%}
      <div class="hero__overlay" style="--overlay:{{ overlay | divided_by: 100.0 }};"></div>
    {%- endif -%}
  </div>

  <div class="hero__inner container" data-stagger>
    {%- if section.settings.eyebrow != blank -%}
      <p class="hero__eyebrow" data-reveal="up">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="hero__headline" data-reveal="up">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="hero__body" data-reveal="up">{{ section.settings.body }}</div>
    {%- endif -%}
    {%- if section.settings.cta_primary_label != blank or section.settings.cta_secondary_label != blank -%}
      <div class="hero__ctas" data-reveal="up">
        {%- if section.settings.cta_primary_label != blank -%}
          <a href="{{ section.settings.cta_primary_url | default: '#' }}" class="btn btn--primary hero__cta">
            {{ section.settings.cta_primary_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_label != blank -%}
          <a href="{{ section.settings.cta_secondary_url | default: '#' }}" class="hero__link">
            {{ section.settings.cta_secondary_label }}
            {%- render 'icon', name: 'arrow-right', class: 'icon icon--sm' -%}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} { display: block; }

  .hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    color: var(--c-ink);
    background: var(--c-bg);
    display: flex;
    align-items: center;
  }
  .hero--dark   { color: var(--c-ink-inv); background: var(--c-bg-inv); }
  .hero--light  { color: var(--c-ink);     background: var(--c-surface); }

  .hero--small  { min-height: 60vh; }
  .hero--medium { min-height: 75vh; }
  .hero--large  { min-height: 92vh; }
  .hero--full   { min-height: 100svh; }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .hero__media svg,
  .hero__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__image--mobile { display: none; }
  @media (max-width: 749px) {
    .hero__image--desktop { display: none; }
    .hero__image--mobile  { display: block; }
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: #000;
    opacity: var(--overlay, 0);
  }

  .hero__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
    padding-block: clamp(var(--s-9), 16vh, var(--s-10));
    max-width: 920px;
    width: 100%;
  }
  .hero--align-center .hero__inner { text-align: center; margin-inline: auto; align-items: center; }
  .hero--align-left   .hero__inner { text-align: left; align-items: flex-start; }
  .hero--align-right  .hero__inner { text-align: right; margin-left: auto; align-items: flex-end; }

  .hero__eyebrow {
    margin: 0;
    font-size: var(--fs-14);
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-ink-muted);
  }
  .hero--dark .hero__eyebrow { color: var(--c-ink-muted-inv); }

  .hero__headline {
    margin: 0;
    font-family: var(--font-display);
    font-weight: var(--weight-semibold);
    font-size: clamp(2.5rem, 6vw, 5.25rem);
    line-height: 1.04;
    letter-spacing: -0.025em;
  }

  .hero__body {
    max-width: 60ch;
    font-size: clamp(var(--fs-19), 1.6vw, var(--fs-21));
    line-height: 1.5;
    color: var(--c-ink-muted);
  }
  .hero--dark .hero__body { color: var(--c-ink-muted-inv); }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-4);
    align-items: center;
    margin-top: var(--s-3);
  }
  .hero--align-center .hero__ctas { justify-content: center; }
  .hero--align-right  .hero__ctas { justify-content: flex-end; }

  .hero__cta {
    min-height: 50px;
    padding-inline: var(--s-6);
    font-size: var(--fs-16);
  }
  .hero--dark .btn--primary { background: #fff; color: #000; }
  .hero--dark .btn--primary:hover { background: #e8e8ed; }

  .hero__link {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    font-size: var(--fs-16);
    font-weight: var(--weight-medium);
    color: inherit;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    transition: opacity var(--dur-fast) var(--ease-soft);
  }
  .hero__link:hover { opacity: 0.7; }
  .hero__link .icon {
    transition: transform var(--dur-base) var(--ease-apple);
  }
  .hero__link:hover .icon { transform: translateX(4px); }
</style>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "select",
      "id": "theme",
      "label": "Theme",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "dark",  "label": "Dark"  }
      ],
      "default": "light"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Height",
      "options": [
        { "value": "small",  "label": "Small (60vh)"  },
        { "value": "medium", "label": "Medium (75vh)" },
        { "value": "large",  "label": "Large (92vh)"  },
        { "value": "full",   "label": "Full screen"   }
      ],
      "default": "large"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Content alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ],
      "default": "center"
    },
    { "type": "header", "content": "Background" },
    { "type": "image_picker", "id": "image",        "label": "Desktop image" },
    { "type": "image_picker", "id": "image_mobile", "label": "Mobile image" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay darken", "min": 0, "max": 80, "step": 5, "unit": "%", "default": 0 },
    { "type": "header", "content": "Content" },
    { "type": "text",     "id": "eyebrow",  "label": "Eyebrow",  "default": "New collection" },
    { "type": "text",     "id": "heading",  "label": "Headline", "default": "Designed for everyday performance." },
    { "type": "richtext", "id": "body",     "label": "Body",     "default": "<p>Crafted from premium materials. Engineered for the way you actually live.</p>" },
    { "type": "text", "id": "cta_primary_label",   "label": "Primary CTA label",   "default": "Shop the collection" },
    { "type": "url",  "id": "cta_primary_url",     "label": "Primary CTA URL" },
    { "type": "text", "id": "cta_secondary_label", "label": "Secondary CTA label", "default": "Learn more" },
    { "type": "url",  "id": "cta_secondary_url",   "label": "Secondary CTA URL" }
  ],
  "presets": [
    { "name": "Hero" }
  ]
}
{% endschema %}

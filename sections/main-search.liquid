{%- comment -%}
  Zelexto v2 — sections/main-search.liquid
  Search results page. Reuses filter-sidebar + product-card + pagination.
  Native Shopify search results (search.results).
{%- endcomment -%}

{%- liquid
  assign per_page = section.settings.products_per_page | default: 24
-%}

<div class="search-results">
  <div class="container">
    <header class="search-results__header">
      {% render 'breadcrumb' %}
      <h1 class="search-results__title">
        {%- if search.performed -%}
          {{ 'search.results_for' | t: terms: search.terms }}
        {%- else -%}
          {{ 'search.title' | t | default: 'Search' }}
        {%- endif -%}
      </h1>

      <form action="{{ routes.search_url }}" method="get" class="search-results__form" role="search">
        <input type="hidden" name="type" value="product,article,page">
        <label class="field search-results__field">
          <span class="sr-only">{{ 'search.placeholder' | t }}</span>
          {% render 'icon', name: 'search', class: 'search-results__icon' %}
          <input
            type="search"
            name="q"
            value="{{ search.terms | escape }}"
            class="field__input"
            placeholder="{{ 'search.placeholder' | t }}"
            autocomplete="off">
        </label>
        <button type="submit" class="btn btn--primary">{{ 'search.submit' | t | default: 'Search' }}</button>
      </form>
    </header>

    {%- if search.performed -%}
      {%- paginate search.results by per_page -%}
        {%- if search.results.size > 0 -%}
          {%- assign results_count = search.results_count -%}
          <p class="search-results__summary" aria-live="polite">
            {{ 'search.results_count' | t: count: results_count | default: results_count | append: ' results' }}
          </p>

          <div class="search-results__layout">
            {%- if section.settings.enable_filters -%}
              <aside class="search-results__facets">
                {% render 'filter-sidebar', collection: search, section: section %}
              </aside>
            {%- endif -%}

            <div class="search-results__main">
              <div class="search-results__grid grid">
                {%- for item in search.results -%}
                  {%- case item.object_type -%}
                    {%- when 'product' -%}
                      {% render 'product-card', product: item, index: forloop.index %}
                    {%- when 'article' -%}
                      <article class="article-card article-card--search">
                        {%- if item.image -%}
                          <a href="{{ item.url }}" class="article-card__media aspect" style="aspect-ratio: 16/10;">
                            {% render 'responsive-image', image: item.image, alt: item.title, sizes: '(min-width:1024px) 33vw, 50vw', loading: 'lazy' %}
                          </a>
                        {%- endif -%}
                        <div class="article-card__body">
                          <span class="pill">{{ 'search.articles' | t | default: 'Article' }}</span>
                          <h2 class="article-card__title"><a href="{{ item.url }}">{{ item.title }}</a></h2>
                          {%- if item.excerpt_or_content -%}<p>{{ item.excerpt_or_content | strip_html | truncate: 120 }}</p>{%- endif -%}
                        </div>
                      </article>
                    {%- when 'page' -%}
                      <a href="{{ item.url }}" class="search-page-result">
                        <span class="pill">{{ 'search.pages' | t | default: 'Page' }}</span>
                        <strong>{{ item.title }}</strong>
                        {%- if item.content -%}<p>{{ item.content | strip_html | truncate: 140 }}</p>{%- endif -%}
                      </a>
                  {%- endcase -%}
                {%- endfor -%}
              </div>
              {% render 'pagination', paginate: paginate %}
            </div>
          </div>
        {%- else -%}
          <div class="search-results__empty">
            <h2>{{ 'search.no_results' | t: terms: search.terms }}</h2>
            <p>{{ 'search.try_again' | t | default: 'Try different keywords or browse all products.' }}</p>
            <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">{{ 'general.browse_all' | t | default: 'Browse all products' }}</a>
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    {%- else -%}
      <p class="search-results__prompt">{{ 'search.prompt' | t | default: 'Enter a search term to begin.' }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.search.name",
  "tag": "section",
  "class": "section section--search",
  "settings": [
    { "type": "checkbox", "id": "enable_filters", "label": "Enable filters", "default": true },
    { "type": "checkbox", "id": "show_filter_count", "label": "Show count per filter", "default": true },
    { "type": "range", "id": "products_per_page", "label": "Results per page", "min": 8, "max": 48, "step": 4, "default": 24 }
  ],
  "presets": [{ "name": "Search" }]
}
{% endschema %}

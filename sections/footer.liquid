{% comment %}
  ZELEXTO THEME — sections/footer.liquid
  Site footer with navigation, newsletter, social links, locale selectors.
{% endcomment %}

<footer class="site-footer" role="contentinfo">

  <div class="container">
    <div class="footer-grid">

      <!-- Brand column -->
      <div class="footer-brand">
        {%- if section.settings.logo -%}
          <img
            src="{{ section.settings.logo | image_url: width: 120 }}"
            alt="{{ shop.name }}"
            width="120" height="40"
            loading="lazy"
            decoding="async">
        {%- else -%}
          <span class="footer-brand__name">{{ shop.name }}</span>
        {%- endif -%}

        {%- if section.settings.tagline != blank -%}
          <p class="footer-brand__tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}

        <!-- Social links -->
        <div class="footer-social" aria-label="Social media links">
          {%- if settings.social_instagram -%}
            <a href="{{ settings.social_instagram }}" class="footer-social__link" aria-label="Instagram" target="_blank" rel="noopener">
              {%- render 'icon', name: 'instagram', size: 20 -%}
            </a>
          {%- endif -%}
          {%- if settings.social_facebook -%}
            <a href="{{ settings.social_facebook }}" class="footer-social__link" aria-label="Facebook" target="_blank" rel="noopener">
              {%- render 'icon', name: 'facebook', size: 20 -%}
            </a>
          {%- endif -%}
          {%- if settings.social_tiktok -%}
            <a href="{{ settings.social_tiktok }}" class="footer-social__link" aria-label="TikTok" target="_blank" rel="noopener">
              {%- render 'icon', name: 'tiktok', size: 20 -%}
            </a>
          {%- endif -%}
          {%- if settings.social_youtube -%}
            <a href="{{ settings.social_youtube }}" class="footer-social__link" aria-label="YouTube" target="_blank" rel="noopener">
              {%- render 'icon', name: 'youtube', size: 20 -%}
            </a>
          {%- endif -%}
          {%- if settings.social_twitter -%}
            <a href="{{ settings.social_twitter }}" class="footer-social__link" aria-label="Twitter" target="_blank" rel="noopener">
              {%- render 'icon', name: 'twitter', size: 20 -%}
            </a>
          {%- endif -%}
          {%- if settings.social_pinterest -%}
            <a href="{{ settings.social_pinterest }}" class="footer-social__link" aria-label="Pinterest" target="_blank" rel="noopener">
              {%- render 'icon', name: 'pinterest', size: 20 -%}
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Navigation columns (up to 3) -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          <div class="footer-nav-col" {{ block.shopify_attributes }}>
            <h3 class="footer-nav-col__title">{{ block.settings.heading }}</h3>
            {%- liquid assign footer_menu = linklists[block.settings.menu] -%}
            {%- if footer_menu != blank -%}
              <ul class="footer-nav-col__list" role="list">
                {%- for link in footer_menu.links -%}
                  <li>
                    <a href="{{ link.url }}" class="footer-nav-col__link">{{ link.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

      <!-- Newsletter -->
      {%- if section.settings.show_newsletter -%}
        <div class="footer-newsletter">
          <h3 class="footer-newsletter__title">{{ section.settings.newsletter_heading | default: 'Stay in the loop' }}</h3>
          {%- if section.settings.newsletter_subheading != blank -%}
            <p class="footer-newsletter__sub">{{ section.settings.newsletter_subheading }}</p>
          {%- endif -%}
          {%- form 'customer', class: 'footer-newsletter__form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="footer-newsletter__field">
              <label for="footer-email" class="visually-hidden">{{ 'footer.email_placeholder' | t }}</label>
              <input
                type="email"
                name="contact[email]"
                id="footer-email"
                class="footer-newsletter__input"
                placeholder="{{ 'footer.email_placeholder' | t }}"
                required
                aria-required="true">
              <button type="submit" class="btn btn--primary footer-newsletter__submit">
                {{ 'footer.subscribe' | t }}
              </button>
            </div>
            {%- if form.posted_successfully? -%}
              <p class="footer-newsletter__success">{{ 'footer.subscribe_success' | t }}</p>
            {%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}

    </div>
  </div>

  <!-- Footer bottom bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom__inner">
      <p class="footer-bottom__copy">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
        {{ 'footer.copyright' | t }}
      </p>
      {%- if section.settings.show_payment_icons -%}
        <div class="footer-payment" aria-label="{{ 'footer.payment' | t }}">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'footer-payment__icon' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>

</footer>

<style>
  .site-footer {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-16);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 1fr) 1.5fr;
    gap: var(--space-8);
    padding-bottom: var(--space-16);
  }

  @media (max-width: 1024px) {
    .footer-grid { grid-template-columns: 1fr 1fr 1fr; }
    .footer-brand, .footer-newsletter { grid-column: 1 / -1; }
  }

  @media (max-width: 640px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: var(--space-6); }
    .footer-brand, .footer-newsletter { grid-column: 1 / -1; }
  }

  /* Brand */
  .footer-brand__name { font-family: var(--font-heading); font-weight: var(--font-weight-bold); font-size: var(--font-size-xl); }
  .footer-brand__tagline { font-size: var(--font-size-sm); opacity: 0.7; margin-top: var(--space-2); max-width: 260px; line-height: var(--line-height-relaxed); }

  /* Social */
  .footer-social { display: flex; gap: var(--space-3); margin-top: var(--space-5); }
  .footer-social__link {
    display: flex; align-items: center; justify-content: center;
    width: 40px; height: 40px;
    border-radius: var(--radius-full);
    background: rgba(255,255,255,0.08);
    color: inherit; text-decoration: none;
    transition: background-color var(--transition-fast), transform var(--transition-fast);
  }
  .footer-social__link:hover { background: rgba(255,255,255,0.16); transform: translateY(-2px); }

  /* Nav columns */
  .footer-nav-col__title {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.6;
    margin-bottom: var(--space-4);
  }
  .footer-nav-col__list { list-style: none; display: flex; flex-direction: column; gap: var(--space-3); }
  .footer-nav-col__link { font-size: var(--font-size-sm); color: inherit; text-decoration: none; opacity: 0.8; transition: opacity var(--transition-fast); }
  .footer-nav-col__link:hover { opacity: 1; }

  /* Newsletter */
  .footer-newsletter__title { font-size: var(--font-size-md); font-weight: var(--font-weight-semibold); margin-bottom: var(--space-2); }
  .footer-newsletter__sub { font-size: var(--font-size-sm); opacity: 0.75; margin-bottom: var(--space-4); }
  .footer-newsletter__field {
    display: flex; gap: var(--space-2);
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .footer-newsletter__input {
    flex: 1; background: none; border: none; outline: none;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-body); font-size: var(--font-size-sm);
    color: inherit;
  }
  .footer-newsletter__input::placeholder { opacity: 0.5; }
  .footer-newsletter__submit { flex-shrink: 0; border-radius: 0; }
  .footer-newsletter__success { font-size: var(--font-size-sm); color: #4ade80; margin-top: var(--space-2); }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-block: var(--space-5);
  }
  .footer-bottom__inner { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: var(--space-4); }
  .footer-bottom__copy { font-size: var(--font-size-xs); opacity: 0.6; }
  .footer-payment { display: flex; gap: var(--space-2); flex-wrap: wrap; }
  .footer-payment__icon { height: 24px; width: auto; opacity: 0.6; }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Footer logo" },
    { "type": "text", "id": "tagline", "label": "Brand tagline" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#111827" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#f9fafb" },
    { "type": "header", "content": "Newsletter" },
    { "type": "checkbox", "id": "show_newsletter", "label": "Show newsletter form", "default": true },
    { "type": "text", "id": "newsletter_heading", "label": "Newsletter heading", "default": "Stay in the loop" },
    { "type": "text", "id": "newsletter_subheading", "label": "Newsletter subheading" },
    { "type": "header", "content": "Settings" },
    { "type": "checkbox", "id": "show_payment_icons", "label": "Show payment icons", "default": true }
  ],
  "blocks": [{
    "type": "link_list",
    "name": "Navigation column",
    "limit": 3,
    "settings": [
      { "type": "text", "id": "heading", "label": "Column heading", "default": "Shop" },
      { "type": "link_list", "id": "menu", "label": "Navigation menu" }
    ]
  }],
  "max_blocks": 3,
  "presets": [{ "name": "Footer" }]
}
{% endschema %}

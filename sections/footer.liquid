{%- liquid
  assign nav_blocks = section.blocks | where: 'type', 'link_list'
-%}

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer__grid">

      <div class="site-footer__brand">
        {%- if section.settings.logo != blank -%}
          <a href="{{ routes.root_url }}" class="site-footer__brand-link" aria-label="{{ shop.name }}">
            <img
              src="{{ section.settings.logo | image_url: width: 160 }}"
              srcset="{{ section.settings.logo | image_url: width: 160 }} 1x, {{ section.settings.logo | image_url: width: 320 }} 2x"
              alt="{{ shop.name | escape }}"
              width="160"
              height="{{ section.settings.logo.height | times: 160 | divided_by: section.settings.logo.width }}"
              loading="lazy"
              decoding="async">
          </a>
        {%- else -%}
          <a href="{{ routes.root_url }}" class="site-footer__brand-text">{{ shop.name }}</a>
        {%- endif -%}

        {%- if section.settings.tagline != blank -%}
          <p class="site-footer__tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}

        <div class="site-footer__social" aria-label="Social media">
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" class="site-footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">{%- render 'icon', name: 'instagram', class: 'icon' -%}</a>
          {%- endif -%}
          {%- if settings.social_facebook != blank -%}
            <a href="{{ settings.social_facebook }}" class="site-footer__social-link" aria-label="Facebook" target="_blank" rel="noopener">{%- render 'icon', name: 'facebook', class: 'icon' -%}</a>
          {%- endif -%}
          {%- if settings.social_youtube != blank -%}
            <a href="{{ settings.social_youtube }}" class="site-footer__social-link" aria-label="YouTube" target="_blank" rel="noopener">{%- render 'icon', name: 'youtube', class: 'icon' -%}</a>
          {%- endif -%}
          {%- if settings.social_tiktok != blank -%}
            <a href="{{ settings.social_tiktok }}" class="site-footer__social-link" aria-label="TikTok" target="_blank" rel="noopener">{%- render 'icon', name: 'tiktok', class: 'icon' -%}</a>
          {%- endif -%}
          {%- if settings.social_twitter != blank -%}
            <a href="{{ settings.social_twitter }}" class="site-footer__social-link" aria-label="Twitter" target="_blank" rel="noopener">{%- render 'icon', name: 'twitter', class: 'icon' -%}</a>
          {%- endif -%}
          {%- if settings.social_pinterest != blank -%}
            <a href="{{ settings.social_pinterest }}" class="site-footer__social-link" aria-label="Pinterest" target="_blank" rel="noopener">{%- render 'icon', name: 'pinterest', class: 'icon' -%}</a>
          {%- endif -%}
          {%- if settings.social_whatsapp != blank -%}
            <a href="{{ settings.social_whatsapp }}" class="site-footer__social-link" aria-label="WhatsApp" target="_blank" rel="noopener">{%- render 'icon', name: 'whatsapp', class: 'icon' -%}</a>
          {%- endif -%}
        </div>
      </div>

      {%- for block in nav_blocks -%}
        <div class="site-footer__col" {{ block.shopify_attributes }}>
          <h2 class="site-footer__col-title">{{ block.settings.heading }}</h2>
          {%- assign foot_menu = linklists[block.settings.menu] -%}
          {%- if foot_menu != blank and foot_menu.links.size > 0 -%}
            <ul class="site-footer__col-list" role="list">
              {%- for link in foot_menu.links -%}
                <li><a href="{{ link.url }}" class="site-footer__col-link">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endfor -%}

      <div class="site-footer__contact">
        <h2 class="site-footer__col-title">{{ section.settings.contact_heading | default: 'Contact' }}</h2>
        {%- if section.settings.contact_email != blank -%}
          <a href="mailto:{{ section.settings.contact_email }}" class="site-footer__contact-link">
            {%- render 'icon', name: 'mail', class: 'icon icon--sm' -%}
            <span>{{ section.settings.contact_email }}</span>
          </a>
        {%- endif -%}
        {%- if section.settings.contact_phone != blank -%}
          <a href="tel:{{ section.settings.contact_phone | replace: ' ', '' }}" class="site-footer__contact-link">
            <span>{{ section.settings.contact_phone }}</span>
          </a>
        {%- endif -%}
      </div>

    </div>

    {%- if section.settings.show_legal_footer -%}
      {%- render 'legal-footer' -%}
    {%- endif -%}

    <div class="site-footer__bottom">
      <p class="site-footer__copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright_suffix | default: 'All rights reserved.' }}</p>
      {%- if section.settings.show_payment_icons -%}
        <div class="site-footer__payments" aria-label="Accepted payment methods">
          {%- render 'payment-badges' -%}
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'site-footer__payment-icon' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

<style>
  .site-footer{
    background:var(--c-elev);color:var(--c-ink);
    padding-block:var(--s-8) var(--s-5);
    margin-top:var(--s-9);
  }
  .site-footer__grid{
    display:grid;gap:var(--s-7);
    grid-template-columns:repeat(auto-fit, minmax(180px, 1fr));
  }
  @media (min-width:990px){
    .site-footer__grid{
      grid-template-columns:1.6fr repeat(auto-fit, minmax(160px, 1fr)) 1fr;
    }
    .site-footer__brand{grid-column:1}
    .site-footer__contact{grid-column:-2 / -1}
  }
  @media (max-width:640px){
    .site-footer__grid{grid-template-columns:1fr 1fr;gap:var(--s-6)}
    .site-footer__brand,.site-footer__contact{grid-column:1/-1}
  }
  .site-footer__brand-text,.site-footer__brand-link{
    font-family:var(--font-display);font-weight:var(--weight-semibold);
    font-size:var(--fs-21);color:var(--c-ink);
  }
  .site-footer__tagline{
    margin-top:var(--s-3);max-width:36ch;
    color:var(--c-ink-muted);font-size:var(--fs-14);
  }
  .site-footer__social{display:flex;gap:var(--s-2);margin-top:var(--s-4);flex-wrap:wrap}
  .site-footer__social-link{
    display:inline-flex;align-items:center;justify-content:center;
    width:40px;height:40px;border-radius:var(--radius-pill);
    background:var(--c-bg);border:1px solid var(--c-line);
    transition:background-color var(--dur-fast) var(--ease-standard),
               transform var(--dur-fast) var(--ease-standard);
  }
  .site-footer__social-link:hover{background:var(--c-ink);color:var(--c-bg);transform:translateY(-1px)}
  .site-footer__col-title{
    font-size:var(--fs-12);font-weight:var(--weight-semibold);
    letter-spacing:.08em;text-transform:uppercase;
    color:var(--c-ink-muted);margin-bottom:var(--s-3);
  }
  .site-footer__col-list{display:flex;flex-direction:column;gap:var(--s-2);list-style:none;padding:0;margin:0}
  .site-footer__col-link{
    font-size:var(--fs-14);color:var(--c-ink-muted);
    transition:color var(--dur-fast) var(--ease-soft);
  }
  .site-footer__col-link:hover{color:var(--c-ink)}
  .site-footer__contact-link{
    display:flex;align-items:center;gap:var(--s-2);
    font-size:var(--fs-14);color:var(--c-ink-muted);margin-bottom:var(--s-2);
    transition:color var(--dur-fast) var(--ease-soft);
  }
  .site-footer__contact-link:hover{color:var(--c-ink)}
  .site-footer__bottom{
    display:flex;align-items:center;justify-content:space-between;
    flex-wrap:wrap;gap:var(--s-4);
    margin-top:var(--s-7);padding-top:var(--s-5);
    border-top:1px solid var(--c-line);
  }
  .site-footer__copy{font-size:var(--fs-12);color:var(--c-ink-muted)}
  .site-footer__payments{display:flex;align-items:center;gap:var(--s-2);flex-wrap:wrap}
  .site-footer__payment-icon{height:24px;width:auto;opacity:.7}
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Designed in India. Built for the world." },
    { "type": "header", "content": "Contact column" },
    { "type": "text", "id": "contact_heading", "label": "Heading", "default": "Contact" },
    { "type": "text", "id": "contact_email", "label": "Email", "default": "support@example.com" },
    { "type": "text", "id": "contact_phone", "label": "Phone" },
    { "type": "header", "content": "Legal" },
    { "type": "checkbox", "id": "show_legal_footer", "label": "Show legal footer (CIN/GSTIN)", "default": true },
    { "type": "checkbox", "id": "show_payment_icons", "label": "Show payment methods", "default": true },
    { "type": "text", "id": "copyright_suffix", "label": "Copyright suffix", "default": "All rights reserved." }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Navigation column",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [{ "name": "Footer" }]
}
{% endschema %}

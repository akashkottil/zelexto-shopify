{% comment %}
  ZELEXTO THEME — sections/story-feature.liquid
  Two-column feature highlight section. Image + text, toggleable sides.
{% endcomment %}

{%- liquid
  assign enable_anim = section.settings.enable_animation
  assign img_side    = section.settings.image_side | default: 'left'
-%}

<section
  class="story-feature section"
  id="story-feat-{{ section.id }}"
  style="background-color: {{ section.settings.bg_color }};">

  <div class="container">
    <div class="story-feature__grid story-feature__grid--image-{{ img_side }}">

      <!-- Media column -->
      <div class="story-feature__media{% if enable_anim %} {% if img_side == 'left' %}animate-slide-left{% else %}animate-slide-right{% endif %}{% endif %}"
        {% if enable_anim %}data-animate="{% if img_side == 'left' %}animate-slide-left{% else %}animate-slide-right{% endif %}"{% endif %}>

        {%- if section.settings.image != blank -%}
          <div class="story-feature__image-wrap">
            <img
              src="{{ section.settings.image | image_url: width: 700 }}"
              srcset="{{ section.settings.image | image_url: width: 400 }} 400w,
                      {{ section.settings.image | image_url: width: 700 }} 700w"
              sizes="(max-width: 768px) 100vw, 50vw"
              alt="{{ section.settings.image.alt | escape | default: section.settings.heading }}"
              width="700"
              height="{{ 700 | divided_by: section.settings.image.aspect_ratio | round }}"
              loading="lazy"
              decoding="async"
              class="story-feature__image">
          </div>
        {%- elsif section.settings.label_image != blank -%}
          <div class="story-feature__label-image">{{ section.settings.label_image }}</div>
        {%- endif -%}

      </div>

      <!-- Text column -->
      <div class="story-feature__text{% if enable_anim %} animate-fade-in{% endif %}"
        {% if enable_anim %}data-animate="animate-fade-in" style="--animation-delay: 150ms;"{% endif %}>

        {%- if section.settings.eyebrow != blank -%}
          <p class="story-feature__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        <h2 class="story-feature__heading" style="color: {{ section.settings.text_color }};">
          {{ section.settings.heading }}
        </h2>

        {%- if section.settings.description != blank -%}
          <div class="story-feature__description" style="color: {{ section.settings.desc_color }};">
            {{ section.settings.description }}
          </div>
        {%- endif -%}

        <!-- Feature list blocks -->
        {%- if section.blocks.size > 0 -%}
          <ul class="story-feature__list" role="list">
            {%- for block in section.blocks -%}
              <li class="story-feature__list-item" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  <span class="story-feature__list-icon">
                    {%- render 'icon', name: block.settings.icon, size: 20 -%}
                  </span>
                {%- endif -%}
                <div>
                  {%- if block.settings.label != blank -%}
                    <strong>{{ block.settings.label }}</strong>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <span> {{ block.settings.text }}</span>
                  {%- endif -%}
                </div>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <div class="story-feature__cta" style="margin-top: var(--space-8);">
            <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn--primary">
              {{ section.settings.button_label }}
            </a>
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>
</section>

<style>
  .story-feature { overflow: hidden; }

  .story-feature__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  .story-feature__grid--image-right {
    direction: rtl;
  }
  .story-feature__grid--image-right > * {
    direction: ltr;
  }

  @media (max-width: 768px) {
    .story-feature__grid { grid-template-columns: 1fr; gap: var(--space-8); direction: ltr !important; }
    .story-feature__grid > * { direction: ltr !important; }
  }

  .story-feature__image-wrap {
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
  }

  .story-feature__image { width: 100%; height: auto; display: block; }

  .story-feature__eyebrow {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }

  .story-feature__heading {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: var(--space-5);
    line-height: 1.15;
  }

  .story-feature__description {
    font-size: var(--font-size-lg);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-6);
  }

  .story-feature__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .story-feature__list-item {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
    font-size: var(--font-size-sm);
  }

  .story-feature__list-icon {
    flex-shrink: 0;
    width: 36px; height: 36px;
    background: var(--color-surface);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
  }
</style>

{% schema %}
{
  "name": "Story — Feature",
  "tag": "section",
  "settings": [
    { "type": "select", "id": "image_side", "label": "Image position", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "left" },
    { "type": "image_picker", "id": "image", "label": "Feature image" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#ffffff" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Zelexto?" },
    { "type": "richtext", "id": "description", "label": "Description" },
    { "type": "color", "id": "text_color", "label": "Heading color", "default": "#111827" },
    { "type": "color", "id": "desc_color", "label": "Description color", "default": "#6b7280" },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    { "type": "header", "content": "Animation" },
    { "type": "checkbox", "id": "enable_animation", "label": "Enable animation", "default": true }
  ],
  "blocks": [
    {
      "type": "feature_item",
      "name": "Feature item",
      "limit": 6,
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [{"value":"check","label":"Checkmark"},{"value":"shield","label":"Shield"},{"value":"truck","label":"Truck"},{"value":"star","label":"Star"},{"value":"heart","label":"Heart"}], "default": "check" },
        { "type": "text", "id": "label", "label": "Bold label" },
        { "type": "text", "id": "text", "label": "Description" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{ "name": "Story — Feature", "settings": { "heading": "Why Zelexto?" }, "blocks": [{"type":"feature_item","settings":{"icon":"check","label":"Fast shipping","text":"Orders ship within 24 hours."}},{"type":"feature_item","settings":{"icon":"shield","label":"Secure payments","text":"256-bit SSL encryption."}}] }]
}
{% endschema %}

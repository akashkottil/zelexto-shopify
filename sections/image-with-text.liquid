{%- comment -%}
  Image with text — single block of image + copy.
{%- endcomment -%}

{%- liquid
  assign theme = section.settings.theme | default: 'light'
  assign image_side = section.settings.image_side | default: 'left'
-%}

<section class="iwt iwt--{{ theme }} iwt--image-{{ image_side }}" data-section-id="{{ section.id }}">
  <div class="container iwt__grid">
    <div class="iwt__media zoomable" data-reveal="{% if image_side == 'left' %}left{% else %}right{% endif %}">
      {%- if section.settings.image != blank -%}
        {%- render 'responsive-image',
            image: section.settings.image,
            alt: section.settings.heading,
            sizes: '(min-width: 990px) 50vw, 100vw',
            widths: '480,750,900,1100,1400,1800',
            loading: 'lazy',
            aspect_ratio: '4/5',
            class: 'iwt__image' -%}
      {%- else -%}
        <div class="iwt__image-wrap">
          {%- render 'demo-image', kind: 'lifestyle', class: 'iwt__image' -%}
        </div>
      {%- endif -%}
    </div>

    <div class="iwt__copy" data-stagger>
      {%- if section.settings.eyebrow != blank -%}
        <p class="iwt__eyebrow" data-reveal="up">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="iwt__heading" data-reveal="up">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <div class="iwt__body" data-reveal="up">{{ section.settings.body }}</div>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <div class="iwt__ctas" data-reveal="up">
          <a href="{{ section.settings.cta_url | default: '#' }}" class="btn btn--primary">{{ section.settings.cta_label }}</a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} { display: block; }

  .iwt {
    padding-block: clamp(var(--s-9), 12vh, var(--s-10));
    background: var(--c-bg);
    color: var(--c-ink);
  }
  .iwt--soft { background: var(--c-surface); }
  .iwt--dark { background: var(--c-bg-inv); color: var(--c-ink-inv); }

  .iwt__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-7);
    align-items: center;
  }
  @media (min-width: 990px) {
    .iwt__grid { grid-template-columns: 1fr 1fr; gap: clamp(var(--s-7), 6vw, var(--s-9)); }
    .iwt--image-right .iwt__media { order: 2; }
    .iwt--image-right .iwt__copy  { order: 1; }
  }

  .iwt__media {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--c-elev);
  }
  .iwt__image-wrap { aspect-ratio: 4 / 5; }
  .iwt__media svg,
  .iwt__media img { width: 100%; height: 100%; object-fit: cover; }

  .iwt__copy {
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
    max-width: 52ch;
  }
  .iwt__eyebrow {
    margin: 0;
    font-size: var(--fs-14);
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-ink-muted);
  }
  .iwt--dark .iwt__eyebrow { color: var(--c-ink-muted-inv); }
  .iwt__heading {
    margin: 0;
    font-size: clamp(var(--fs-28), 3.5vw, var(--fs-56));
    font-weight: var(--weight-semibold);
    letter-spacing: -0.022em;
    line-height: 1.06;
  }
  .iwt__body { font-size: var(--fs-19); line-height: 1.5; color: var(--c-ink-muted); }
  .iwt--dark .iwt__body { color: var(--c-ink-muted-inv); }
  .iwt__ctas { margin-top: var(--s-2); }
  .iwt--dark .btn--primary { background: #fff; color: #000; }
  .iwt--dark .btn--primary:hover { background: #e8e8ed; }
</style>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    { "type": "select", "id": "theme",      "label": "Theme",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "soft",  "label": "Soft" },
        { "value": "dark",  "label": "Dark" }
      ], "default": "light" },
    { "type": "select", "id": "image_side", "label": "Image side",
      "options": [
        { "value": "left",  "label": "Left" },
        { "value": "right", "label": "Right" }
      ], "default": "left" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "More than a product. A point of view." },
    { "type": "richtext", "id": "body", "label": "Body",
      "default": "<p>We make things we'd want to own — built to last, considered to the millimetre.</p>" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "About us" },
    { "type": "url",  "id": "cta_url",   "label": "CTA URL" }
  ],
  "presets": [
    { "name": "Image with text" }
  ]
}
{% endschema %}

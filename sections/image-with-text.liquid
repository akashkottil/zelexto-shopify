{%- liquid
  assign bg = section.settings.bg | default: 'bg'
  assign image_side = section.settings.image_side | default: 'left'
-%}

<section class="image-text image-text--{{ bg }} image-text--image-{{ image_side }} section" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="image-text__grid">
      <div class="image-text__media">
        {%- if section.settings.image != blank -%}
          <div class="aspect aspect--4/3">
            {%- render 'responsive-image',
              image: section.settings.image,
              alt: section.settings.image.alt | default: section.settings.heading,
              sizes: '(min-width: 769px) 50vw, 100vw',
              loading: 'lazy'
            -%}
          </div>
        {%- else -%}
          <div class="aspect aspect--4/3 image-text__placeholder">
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>
      <div class="image-text__body">
        {%- if section.settings.eyebrow != blank -%}
          <p class="image-text__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="image-text__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.body != blank -%}
          <div class="image-text__body-text">{{ section.settings.body }}</div>
        {%- endif -%}
        {%- if section.settings.cta_label != blank -%}
          <div class="image-text__actions">
            <a href="{{ section.settings.cta_url | default: '#' }}" class="btn btn--{{ section.settings.cta_style | default: 'primary' }}">
              {{ section.settings.cta_label }}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .image-text--bg{background:var(--c-bg);color:var(--c-ink)}
  #shopify-section-{{ section.id }} .image-text--surface{background:var(--c-surface);color:var(--c-ink)}
  #shopify-section-{{ section.id }} .image-text--elev{background:var(--c-elev);color:var(--c-ink)}
  #shopify-section-{{ section.id }} .image-text--ink{background:var(--c-ink);color:var(--c-bg)}

  #shopify-section-{{ section.id }} .image-text__grid{
    display:grid;grid-template-columns:1fr 1fr;
    gap:clamp(var(--s-5), 6vw, var(--s-8));
    align-items:center;
  }
  @media (max-width:768px){
    #shopify-section-{{ section.id }} .image-text__grid{grid-template-columns:1fr}
  }
  #shopify-section-{{ section.id }} .image-text--image-right .image-text__media{order:2}
  #shopify-section-{{ section.id }} .image-text--image-right .image-text__body{order:1}
  @media (max-width:768px){
    #shopify-section-{{ section.id }} .image-text--image-right .image-text__media,
    #shopify-section-{{ section.id }} .image-text--image-right .image-text__body{order:0}
  }

  #shopify-section-{{ section.id }} .image-text__media{
    border-radius:var(--radius-lg);overflow:hidden;
  }
  #shopify-section-{{ section.id }} .image-text__placeholder{background:var(--c-elev)}
  #shopify-section-{{ section.id }} .image-text__placeholder svg{width:100%;height:100%}

  #shopify-section-{{ section.id }} .image-text__body{max-width:560px}
  #shopify-section-{{ section.id }} .image-text__eyebrow{
    font-size:var(--fs-14);font-weight:var(--weight-medium);
    letter-spacing:.04em;text-transform:uppercase;
    color:var(--c-ink-muted);margin-bottom:var(--s-2);
  }
  #shopify-section-{{ section.id }} .image-text--ink .image-text__eyebrow{color:rgba(255,255,255,.7)}
  #shopify-section-{{ section.id }} .image-text__heading{
    font-size:clamp(var(--fs-28), 4vw, var(--fs-56));
    line-height:var(--lh-snug);
  }
  #shopify-section-{{ section.id }} .image-text__body-text{
    margin-top:var(--s-4);font-size:var(--fs-16);
    color:var(--c-ink-muted);line-height:var(--lh-body);max-width:60ch;
  }
  #shopify-section-{{ section.id }} .image-text--ink .image-text__body-text{color:rgba(255,255,255,.78)}
  #shopify-section-{{ section.id }} .image-text__body-text p{margin:0 0 var(--s-3)}
  #shopify-section-{{ section.id }} .image-text__body-text p:last-child{margin:0}
  #shopify-section-{{ section.id }} .image-text__actions{margin-top:var(--s-5)}
</style>

{% schema %}
{
  "name": "Image with text",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    {
      "type": "select", "id": "image_side", "label": "Image position",
      "options": [
        { "value": "left",  "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Crafted for the long run." },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Tell the story of your product, brand or value. Generous whitespace, clean type.</p>" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Learn more" },
    { "type": "url",  "id": "cta_url",   "label": "Button link" },
    {
      "type": "select", "id": "cta_style", "label": "Button style",
      "options": [
        { "value": "primary",   "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "ghost",     "label": "Ghost" }
      ],
      "default": "primary"
    },
    {
      "type": "select", "id": "bg", "label": "Background",
      "options": [
        { "value": "bg",      "label": "White" },
        { "value": "surface", "label": "Surface" },
        { "value": "elev",    "label": "Elevated" },
        { "value": "ink",     "label": "Dark" }
      ],
      "default": "bg"
    }
  ],
  "presets": [{ "name": "Image with text" }]
}
{% endschema %}

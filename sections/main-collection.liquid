{%- comment -%}
  Zelexto v2 — sections/main-collection.liquid
  Collection page: header, toolbar (count + sort + filter toggle),
  filter sidebar via <facets-form>, product grid, pagination.
{%- endcomment -%}

{%- liquid
  assign per_page = section.settings.products_per_page | default: 24
  assign show_filters = section.settings.enable_filtering
-%}

<div class="collection" id="collection-{{ section.id }}">
  <div class="container">

    {%- if section.settings.show_header -%}
      <header class="collection__header">
        {% render 'breadcrumb' %}
        <h1 class="collection__title">{{ collection.title }}</h1>
        {%- if collection.description != blank -%}
          <div class="collection__description rte">{{ collection.description }}</div>
        {%- endif -%}
        {%- if collection.image -%}
          <div class="collection__image aspect" style="aspect-ratio: 16/6;">
            {% render 'responsive-image',
               image: collection.image,
               alt: collection.image.alt | default: collection.title,
               sizes: '100vw',
               loading: 'eager',
               aspect_ratio: '16/6' %}
          </div>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="collection__toolbar">
      <div class="collection__toolbar-left">
        {%- if show_filters -%}
          <button type="button" class="btn btn--ghost btn--sm collection__filter-toggle" data-filter-toggle aria-expanded="false" aria-controls="collection-facets-{{ section.id }}">
            {% render 'icon', name: 'menu' %}
            <span>{{ 'filters.title' | t | default: 'Filter' }}</span>
          </button>
        {%- endif -%}
        <p class="collection__count" aria-live="polite">
          {{ 'collection.product_count' | t: count: collection.products_count }}
        </p>
      </div>

      <div class="collection__toolbar-right">
        <label class="collection__sort-label" for="sort-{{ section.id }}">
          <span>{{ 'filters.sort_by' | t | default: 'Sort by' }}</span>
          <select id="sort-{{ section.id }}" class="field__select collection__sort" data-collection-sort>
            {%- for opt in collection.sort_options -%}
              <option value="{{ opt.value }}" {% if opt.value == collection.sort_by %}selected{% endif %}>{{ opt.name }}</option>
            {%- endfor -%}
          </select>
        </label>
      </div>
    </div>

    <div class="collection__layout{% unless show_filters %} collection__layout--no-filters{% endunless %}">
      {%- if show_filters -%}
        <aside id="collection-facets-{{ section.id }}" class="collection__facets" data-facets-region>
          {% render 'filter-sidebar', collection: collection, section: section %}
        </aside>
      {%- endif -%}

      <div class="collection__main" id="collection-products-{{ section.id }}" data-products-region>
        {%- paginate collection.products by per_page -%}
          {%- if collection.products.size > 0 -%}
            <div class="collection__grid grid">
              {%- for product in collection.products -%}
                {% render 'product-card', product: product, index: forloop.index %}
              {%- endfor -%}
            </div>
            {% render 'pagination', paginate: paginate %}
          {%- else -%}
            <div class="collection__empty">
              <h2>{{ 'collection.empty.title' | t | default: 'No products found' }}</h2>
              <p>{{ 'collection.empty.subtitle' | t | default: 'Try removing a filter or browse all products.' }}</p>
              <a href="{{ collection.url }}" class="btn btn--primary">{{ 'filters.clear_all' | t | default: 'Clear all filters' }}</a>
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section section--collection",
  "settings": [
    { "type": "checkbox", "id": "show_header", "label": "Show collection header", "default": true },
    { "type": "checkbox", "id": "enable_filtering", "label": "Enable filters", "default": true },
    { "type": "checkbox", "id": "show_filter_count", "label": "Show product count per filter", "default": true },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 8, "max": 48, "step": 4, "default": 24 },
    { "type": "select", "id": "columns_desktop", "label": "Columns (desktop)", "options": [
      { "value": "3", "label": "3" }, { "value": "4", "label": "4" }, { "value": "5", "label": "5" }
    ], "default": "4" }
  ],
  "presets": [{ "name": "Collection" }]
}
{% endschema %}

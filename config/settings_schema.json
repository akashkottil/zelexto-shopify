[
  {
    "name": "theme_info",
    "theme_name": "Zelexto",
    "theme_version": "1.0.0",
    "theme_author": "Zelexto",
    "theme_documentation_url": "https://zelexto.com/docs",
    "theme_support_url": "https://zelexto.com/support"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary color",
        "default": "#1a1a1a"
      },
      {
        "type": "color",
        "id": "color_primary_hover",
        "label": "Primary hover color",
        "default": "#333333"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Secondary color",
        "default": "#6b7280"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent color",
        "default": "#e63946"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Page background",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_surface",
        "label": "Surface / card background",
        "default": "#f9fafb"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border color",
        "default": "#e5e7eb"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Body text color",
        "default": "#111827"
      },
      {
        "type": "color",
        "id": "color_text_secondary",
        "label": "Secondary text color",
        "default": "#6b7280"
      },
      {
        "type": "color",
        "id": "color_success",
        "label": "Success color",
        "default": "#10b981"
      },
      {
        "type": "color",
        "id": "color_warning",
        "label": "Warning color",
        "default": "#f59e0b"
      },
      {
        "type": "color",
        "id": "color_error",
        "label": "Error color",
        "default": "#ef4444"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "inter_n7"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "inter_n4"
      },
      {
        "type": "range",
        "id": "font_size_base",
        "label": "Base font size",
        "min": 14,
        "max": 20,
        "step": 1,
        "unit": "px",
        "default": 16
      },
      {
        "type": "select",
        "id": "heading_text_transform",
        "label": "Heading text transform",
        "options": [
          { "value": "none", "label": "Normal" },
          { "value": "uppercase", "label": "Uppercase" },
          { "value": "capitalize", "label": "Capitalize" }
        ],
        "default": "none"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "container_max_width",
        "label": "Container max width",
        "min": 1000,
        "max": 1600,
        "step": 40,
        "unit": "px",
        "default": 1280
      },
      {
        "type": "range",
        "id": "section_spacing_vertical",
        "label": "Section vertical spacing",
        "min": 20,
        "max": 120,
        "step": 4,
        "unit": "px",
        "default": 64
      },
      {
        "type": "range",
        "id": "grid_gap",
        "label": "Grid gap",
        "min": 8,
        "max": 48,
        "step": 4,
        "unit": "px",
        "default": 24
      },
      {
        "type": "range",
        "id": "border_radius",
        "label": "Border radius",
        "min": 0,
        "max": 24,
        "step": 2,
        "unit": "px",
        "default": 8
      },
      {
        "type": "range",
        "id": "card_radius",
        "label": "Card border radius",
        "min": 0,
        "max": 32,
        "step": 2,
        "unit": "px",
        "default": 12
      }
    ]
  },
  {
    "name": "Header",
    "settings": [
      {
        "type": "checkbox",
        "id": "header_sticky",
        "label": "Sticky header",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "header_transparent",
        "label": "Transparent header on hero",
        "info": "Header becomes transparent when placed over a hero section",
        "default": false
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Logo width",
        "min": 60,
        "max": 300,
        "step": 10,
        "unit": "px",
        "default": 140
      },
      {
        "type": "checkbox",
        "id": "show_language_selector",
        "label": "Show language selector",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "show_currency_selector",
        "label": "Show currency selector",
        "default": false
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Slide-out drawer" },
          { "value": "page", "label": "Cart page" },
          { "value": "notification", "label": "Notification only" }
        ],
        "default": "drawer"
      },
      {
        "type": "checkbox",
        "id": "cart_notes",
        "label": "Enable cart notes",
        "default": true
      },
      {
        "type": "number",
        "id": "free_shipping_threshold",
        "label": "Free shipping threshold",
        "info": "Set to 0 to disable free shipping bar",
        "default": 50
      }
    ]
  },
  {
    "name": "Product cards",
    "settings": [
      {
        "type": "select",
        "id": "card_image_ratio",
        "label": "Card image ratio",
        "options": [
          { "value": "natural", "label": "Natural" },
          { "value": "square", "label": "Square (1:1)" },
          { "value": "portrait", "label": "Portrait (3:4)" },
          { "value": "landscape", "label": "Landscape (4:3)" }
        ],
        "default": "portrait"
      },
      {
        "type": "checkbox",
        "id": "card_show_vendor",
        "label": "Show vendor on cards",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "card_show_rating",
        "label": "Show rating on cards",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "card_quick_view",
        "label": "Enable quick view",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "card_hover_image",
        "label": "Show second image on hover",
        "default": true
      }
    ]
  },
  {
    "name": "Animations",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_animations",
        "label": "Enable animations",
        "info": "Disable for maximum performance. Animations respect user's reduced-motion preference automatically.",
        "default": true
      },
      {
        "type": "select",
        "id": "default_animation",
        "label": "Default animation style",
        "options": [
          { "value": "fade-in", "label": "Fade in" },
          { "value": "slide-up", "label": "Slide up" },
          { "value": "slide-left", "label": "Slide from left" },
          { "value": "scale-in", "label": "Scale in" }
        ],
        "default": "slide-up"
      },
      {
        "type": "range",
        "id": "animation_duration",
        "label": "Animation duration",
        "min": 200,
        "max": 1200,
        "step": 100,
        "unit": "ms",
        "default": 600
      }
    ]
  },
  {
    "name": "Feature flags",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_quick_view",
        "label": "Enable quick view",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_recently_viewed",
        "label": "Enable recently viewed products",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_back_to_top",
        "label": "Enable back to top button",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_sticky_cart",
        "label": "Enable sticky add-to-cart bar",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_predictive_search",
        "label": "Enable predictive search",
        "default": true
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_facebook",
        "label": "Facebook URL"
      },
      {
        "type": "text",
        "id": "social_tiktok",
        "label": "TikTok URL"
      },
      {
        "type": "text",
        "id": "social_twitter",
        "label": "Twitter / X URL"
      },
      {
        "type": "text",
        "id": "social_youtube",
        "label": "YouTube URL"
      },
      {
        "type": "text",
        "id": "social_pinterest",
        "label": "Pinterest URL"
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      }
    ]
  }
]

{%- comment -%}
  Zelexto v2 — variant-picker.liquid
  Color swatches, size buttons, generic dropdowns. Inputs carry
  data-variant-input so the parent <product-form> can react.

  Color swatches read from product.metafields.swatches.<option_handle>
  (a single_line_text_field with hex value, OR a file_reference). Falls
  back to lowercased value as CSS color.

  Accepts:
    product — required
{%- endcomment -%}

{%- liquid
  assign p = product
-%}

{%- unless p.has_only_default_variant -%}
  <div class="variant-picker" data-variant-picker>
    {%- for option in p.options_with_values -%}
      {%- liquid
        assign option_index = forloop.index0
        assign name_lower = option.name | downcase
        assign option_handle = option.name | handleize
        assign is_color = false
        if name_lower == 'color' or name_lower == 'colour'
          assign is_color = true
        endif
        assign is_size = false
        if name_lower == 'size'
          assign is_size = true
        endif
      -%}

      <fieldset class="variant-picker__group" data-option-index="{{ option_index }}">
        <legend class="variant-picker__legend">
          <span class="variant-picker__label">{{ option.name }}</span>
          <span class="variant-picker__selected" data-selected-value>{{ option.selected_value }}</span>
        </legend>

        {%- if is_color -%}
          <div class="variant-picker__swatches" role="radiogroup" aria-label="{{ option.name }}">
            {%- for value in option.values -%}
              {%- liquid
                assign val_handle = value | handleize
                assign swatch_meta = p.metafields.swatches[option_handle]
                assign swatch_color = nil
                if swatch_meta and swatch_meta.value
                  assign swatch_color = swatch_meta.value
                endif
                assign value_id = 'opt-' | append: option_index | append: '-' | append: forloop.index0
                assign is_selected = false
                if value == option.selected_value
                  assign is_selected = true
                endif
              -%}
              <label class="swatch{% if is_selected %} is-selected{% endif %}" for="{{ value_id }}" title="{{ value | escape }}">
                <input
                  type="radio"
                  class="sr-only"
                  id="{{ value_id }}"
                  name="options[{{ option.name | escape }}]"
                  value="{{ value | escape }}"
                  data-variant-input
                  data-option-index="{{ option_index }}"
                  {% if is_selected %}checked{% endif %}>
                <span
                  class="swatch__dot"
                  style="background-color: {{ swatch_color | default: val_handle }};"
                  aria-hidden="true"></span>
                <span class="sr-only">{{ value }}</span>
              </label>
            {%- endfor -%}
          </div>

        {%- elsif is_size -%}
          <div class="variant-picker__sizes" role="radiogroup" aria-label="{{ option.name }}">
            {%- for value in option.values -%}
              {%- liquid
                assign value_id = 'opt-' | append: option_index | append: '-' | append: forloop.index0
                assign is_selected = false
                if value == option.selected_value
                  assign is_selected = true
                endif
              -%}
              <label class="size-pill{% if is_selected %} is-selected{% endif %}" for="{{ value_id }}">
                <input
                  type="radio"
                  class="sr-only"
                  id="{{ value_id }}"
                  name="options[{{ option.name | escape }}]"
                  value="{{ value | escape }}"
                  data-variant-input
                  data-option-index="{{ option_index }}"
                  {% if is_selected %}checked{% endif %}>
                <span>{{ value }}</span>
              </label>
            {%- endfor -%}
          </div>

        {%- else -%}
          <div class="field">
            <select
              class="field__select"
              name="options[{{ option.name | escape }}]"
              data-variant-input
              data-option-index="{{ option_index }}"
              aria-label="{{ option.name }}">
              {%- for value in option.values -%}
                <option value="{{ value | escape }}" {% if value == option.selected_value %}selected{% endif %}>{{ value }}</option>
              {%- endfor -%}
            </select>
          </div>
        {%- endif -%}
      </fieldset>
    {%- endfor -%}

    {%- comment -%} Master variant id input — kept in sync by product-form.js {%- endcomment -%}
    <input type="hidden" name="id" value="{{ p.selected_or_first_available_variant.id }}" data-variant-id>
  </div>
{%- else -%}
  <input type="hidden" name="id" value="{{ p.variants.first.id }}" data-variant-id>
{%- endunless -%}

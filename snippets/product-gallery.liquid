{%- comment -%}
  Zelexto v2 — product-gallery.liquid
  <media-gallery> Custom Element. Slides + thumbnails + zoom on click.
  Uses scroll-snap on mobile for native swipe; arrows on desktop.

  Accepts:
    product — required
{%- endcomment -%}

{%- liquid
  assign featured = product.selected_or_first_available_variant.featured_media | default: product.featured_media
  assign media_list = product.media
-%}

<media-gallery
  class="media-gallery"
  data-module="product-media.js"
  data-product-id="{{ product.id }}"
  aria-label="{{ 'product.gallery' | t | default: 'Product gallery' }}">

  <div class="media-gallery__viewer" data-gallery-viewer>
    <div class="media-gallery__rail" data-gallery-rail role="list">
      {%- for media in media_list -%}
        <div
          class="media-gallery__slide{% if media.id == featured.id %} is-active{% endif %}"
          role="listitem"
          data-slide-id="{{ media.id }}"
          data-slide-index="{{ forloop.index0 }}"
          aria-hidden="{% if media.id == featured.id %}false{% else %}true{% endif %}">

          {%- case media.media_type -%}
            {%- when 'image' -%}
              <button
                type="button"
                class="media-gallery__zoom-trigger"
                data-zoom-trigger
                aria-label="{{ 'product.zoom' | t | default: 'Zoom image' }}">
                {% render 'responsive-image',
                   image: media,
                   alt: media.alt | default: product.title,
                   sizes: '(min-width:1024px) 55vw, 100vw',
                   loading: forloop.first,
                   fetchpriority: forloop.first | default: 'auto',
                   class: 'media-gallery__img',
                   aspect_ratio: '1/1' %}
              </button>

            {%- when 'video' -%}
              <div class="media-gallery__video-wrap aspect" style="aspect-ratio: 1/1;">
                {{ media | video_tag: class: 'media-gallery__video', controls: true, image_size: '1200x', loop: false, muted: false, playsinline: true }}
              </div>

            {%- when 'external_video' -%}
              <div class="media-gallery__video-wrap aspect" style="aspect-ratio: 16/9;">
                {{ media | external_video_tag: class: 'media-gallery__video', loading: 'lazy' }}
              </div>

            {%- when 'model' -%}
              <div class="media-gallery__model-wrap aspect" style="aspect-ratio: 1/1;">
                {{ media | model_viewer_tag: image_size: '1200x', reveal: 'interaction', toggleable: true, ar: true }}
              </div>
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if media_list.size > 1 -%}
      <button type="button" class="media-gallery__arrow media-gallery__arrow--prev" data-gallery-prev aria-label="{{ 'general.previous' | t | default: 'Previous' }}">
        {% render 'icon', name: 'arrow-left' %}
      </button>
      <button type="button" class="media-gallery__arrow media-gallery__arrow--next" data-gallery-next aria-label="{{ 'general.next' | t | default: 'Next' }}">
        {% render 'icon', name: 'arrow-right' %}
      </button>
      <div class="media-gallery__counter" aria-live="polite">
        <span data-gallery-current>1</span>/<span>{{ media_list.size }}</span>
      </div>
    {%- endif -%}
  </div>

  {%- if media_list.size > 1 -%}
    <ul class="media-gallery__thumbs" role="list" data-gallery-thumbs>
      {%- for media in media_list -%}
        <li>
          <button
            type="button"
            class="media-gallery__thumb{% if media.id == featured.id %} is-active{% endif %}"
            data-thumb-index="{{ forloop.index0 }}"
            data-thumb-id="{{ media.id }}"
            aria-label="{{ media.alt | default: product.title }} — {{ forloop.index }}"
            aria-pressed="{% if media.id == featured.id %}true{% else %}false{% endif %}">
            <img
              src="{{ media.preview_image | image_url: width: 160 }}"
              srcset="{{ media.preview_image | image_url: width: 80 }} 80w, {{ media.preview_image | image_url: width: 160 }} 160w"
              sizes="80px"
              width="80" height="80"
              alt="{{ media.alt | default: product.title }}"
              loading="lazy" decoding="async">
            {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
              <span class="media-gallery__thumb-icon" aria-hidden="true">▶</span>
            {%- elsif media.media_type == 'model' -%}
              <span class="media-gallery__thumb-icon" aria-hidden="true">3D</span>
            {%- endif -%}
          </button>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}
</media-gallery>

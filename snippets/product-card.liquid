{%- comment -%}
  Zelexto v2 — product-card.liquid
  Apple-style minimal product card. Image (with optional hover swap),
  title, vendor, price, optional rating, optional quick-view CTA.

  Accepts:
    product          — required
    show_vendor      — default settings.card_show_vendor
    show_rating      — default settings.card_show_rating
    show_quick_view  — default settings.card_quick_view
    show_hover_image — default settings.card_hover_image
    image_ratio      — default settings.card_image_ratio
    sizes            — img sizes (default responsive PLP grid)
    loading          — default 'lazy'
    index            — for analytics list position
{%- endcomment -%}

{%- liquid
  assign p = product
  assign image_ratio = image_ratio | default: settings.card_image_ratio | default: '3/4'
  assign show_vendor_attr = show_vendor
  if show_vendor_attr == nil
    assign show_vendor_attr = settings.card_show_vendor
  endif
  assign show_rating_attr = show_rating
  if show_rating_attr == nil
    assign show_rating_attr = settings.card_show_rating
  endif
  assign show_qv_attr = show_quick_view
  if show_qv_attr == nil
    assign show_qv_attr = settings.card_quick_view
  endif
  if show_qv_attr and settings.enable_quick_view == false
    assign show_qv_attr = false
  endif
  assign show_hover = show_hover_image
  if show_hover == nil
    assign show_hover = settings.card_hover_image
  endif

  assign first_variant = p.selected_or_first_available_variant
  assign on_sale = false
  if first_variant.compare_at_price and first_variant.compare_at_price > first_variant.price
    assign on_sale = true
  endif

  assign img_sizes = sizes | default: '(min-width:1024px) 25vw, (min-width:640px) 33vw, 50vw'
  assign img_loading = loading | default: 'lazy'
  assign hover_img = nil
  if show_hover and p.images.size > 1
    assign hover_img = p.images[1]
  endif
-%}

<article
  class="product-card"
  data-product-card
  data-product-id="{{ p.id }}"
  data-product-handle="{{ p.handle }}"
  {% if index %}data-list-index="{{ index }}"{% endif %}>

  <a class="product-card__media-link" href="{{ p.url | within: collection }}" aria-label="{{ p.title | escape }}">
    <div class="product-card__media aspect" style="aspect-ratio: {{ image_ratio }};">
      {%- if p.featured_image -%}
        {% render 'responsive-image',
           image: p.featured_image,
           alt: p.featured_image.alt | default: p.title,
           sizes: img_sizes,
           loading: img_loading,
           class: 'product-card__img product-card__img--primary',
           aspect_ratio: image_ratio %}
        {%- if hover_img -%}
          {% render 'responsive-image',
             image: hover_img,
             alt: hover_img.alt | default: p.title,
             sizes: img_sizes,
             loading: 'lazy',
             class: 'product-card__img product-card__img--hover',
             aspect_ratio: image_ratio %}
        {%- endif -%}
      {%- else -%}
        <div class="product-card__placeholder">
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}

      <div class="product-card__badges">
        {%- if p.available == false -%}
          <span class="badge badge--soldout">{{ 'product.sold_out' | t }}</span>
        {%- elsif on_sale -%}
          {%- assign pct = first_variant.compare_at_price | minus: first_variant.price | times: 100 | divided_by: first_variant.compare_at_price | round -%}
          <span class="badge badge--sale">&minus;{{ pct }}%</span>
        {%- endif -%}
      </div>
    </div>
  </a>

  {%- if show_qv_attr and p.available -%}
    <div class="product-card__qv">
      <button
        type="button"
        class="btn btn--secondary btn--sm product-card__qv-btn"
        data-quick-view
        data-product-handle="{{ p.handle }}"
        aria-label="{{ 'product.quick_view' | t | default: 'Quick view' }}: {{ p.title | escape }}">
        {{ 'product.quick_view' | t | default: 'Quick view' }}
      </button>
    </div>
  {%- endif -%}

  <div class="product-card__body">
    {%- if show_vendor_attr and p.vendor != blank -%}
      <p class="product-card__vendor">{{ p.vendor }}</p>
    {%- endif -%}

    <h3 class="product-card__title">
      <a href="{{ p.url | within: collection }}" class="product-card__title-link">{{ p.title }}</a>
    </h3>

    {%- if show_rating_attr -%}
      {% render 'rating-stars', product: p, size: 'sm' %}
    {%- endif -%}

    <div class="product-card__price">
      {% render 'price', product: p, show_badge: false %}
    </div>
  </div>
</article>

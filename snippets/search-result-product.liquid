{%- comment -%}
  Zelexto v2 — search-result-product.liquid
  Inline result row used by predictive search and the search modal.

  Accepts:
    result — product object (from /search/suggest.json or search.results)
{%- endcomment -%}

<a href="{{ result.url }}" class="search-result" role="option">
  <div class="search-result__media aspect" style="aspect-ratio: 1/1;">
    {%- if result.featured_image or result.image -%}
      {%- assign img = result.featured_image | default: result.image -%}
      {% render 'responsive-image',
         image: img,
         alt: result.title,
         sizes: '64px',
         loading: 'lazy',
         aspect_ratio: '1/1' %}
    {%- endif -%}
  </div>
  <div class="search-result__body">
    {%- if result.vendor != blank -%}
      <span class="search-result__vendor">{{ result.vendor }}</span>
    {%- endif -%}
    <span class="search-result__title">{{ result.title }}</span>
    {%- if result.price -%}
      <span class="search-result__price" data-money-cents="{{ result.price }}">{{ result.price | money }}</span>
    {%- endif -%}
  </div>
</a>

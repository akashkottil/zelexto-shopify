{% comment %}
  ZELEXTO — snippets/search-result-product.liquid
  Single product search result item.
  Accepts: result (product from Predictive Search API)
{% endcomment %}
<a href="{{ result.url }}" class="search-result search-result--product">
  <div class="search-result__image">
    {%- if result.featured_image -%}
      <img
        src="{{ result.featured_image | image_url: width: 80 }}"
        alt="{{ result.featured_image.alt | escape | default: result.title }}"
        width="80" height="80"
        loading="lazy"
        decoding="async">
    {%- endif -%}
  </div>
  <div class="search-result__info">
    <p class="search-result__vendor">{{ result.vendor }}</p>
    <p class="search-result__title">{{ result.title }}</p>
    <p class="search-result__price">{{ result.price | money }}</p>
  </div>
</a>

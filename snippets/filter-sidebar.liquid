{%- comment -%}
  Zelexto v2 — filter-sidebar.liquid
  Apple-style facet filters using Shopify's storefront filtering API.
  Wrapped by <facets-form> so facets.js can intercept changes and use the
  Section Rendering API to swap the grid + sidebar without a page reload.

  Accepts:
    collection — collection or search object (anything with .filters)
    section    — section context (for show_filter_count toggle)
{%- endcomment -%}

{%- liquid
  assign facets_target = collection
  assign filters = facets_target.filters
  assign active_count = 0
  for f in filters
    for v in f.active_values
      assign active_count = active_count | plus: 1
    endfor
    if f.type == 'price_range' and f.min_value.value or f.max_value.value
      assign active_count = active_count | plus: 1
    endif
  endfor
  assign show_count = section.settings.show_filter_count | default: true
-%}

<facets-form
  class="facets"
  data-module="facets.js"
  data-facets-base-url="{{ facets_target.url | default: routes.search_url }}">

  <div class="facets__head">
    <h2 class="facets__title">
      {{ 'filters.title' | t | default: 'Filter' }}
      {%- if active_count > 0 -%}
        <span class="facets__count">{{ active_count }}</span>
      {%- endif -%}
    </h2>
    {%- if active_count > 0 -%}
      <a href="{{ facets_target.url | default: routes.search_url }}" class="facets__clear" data-facet-clear>
        {{ 'filters.clear_all' | t | default: 'Clear all' }}
      </a>
    {%- endif -%}
  </div>

  {%- if active_count > 0 -%}
    <ul class="facets__active" role="list">
      {%- for f in filters -%}
        {%- for v in f.active_values -%}
          <li>
            <a class="facets__pill" href="{{ v.url_to_remove }}" data-facet-remove>
              <span>{{ v.label }}</span>
              {% render 'icon', name: 'close' %}
            </a>
          </li>
        {%- endfor -%}
        {%- if f.type == 'price_range' -%}
          {%- if f.min_value.value or f.max_value.value -%}
            <li>
              <a class="facets__pill" href="{{ f.url_to_remove }}" data-facet-remove>
                <span>{{ f.min_value.value | money | default: 0 | money }} – {{ f.max_value.value | money | default: f.range_max | money }}</span>
                {% render 'icon', name: 'close' %}
              </a>
            </li>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </ul>
  {%- endif -%}

  <form data-facets-form>
    {%- for f in filters -%}
      <details class="facet" open>
        <summary class="facet__summary">
          <span>{{ f.label }}</span>
          {% render 'icon', name: 'chevron-down', class: 'facet__chevron' %}
        </summary>

        <div class="facet__body">
          {%- case f.type -%}

            {%- when 'list' -%}
              {%- liquid
                assign label_lower = f.label | downcase
                assign is_color = false
                if label_lower == 'color' or label_lower == 'colour'
                  assign is_color = true
                endif
              -%}
              <ul class="facet__list" role="list">
                {%- for v in f.values -%}
                  <li>
                    <label class="facet-option{% if v.active %} is-active{% endif %}{% if v.count == 0 and v.active == false %} is-disabled{% endif %}{% if is_color %} facet-option--color{% endif %}">
                      <input
                        type="checkbox"
                        class="sr-only"
                        name="{{ v.param_name }}"
                        value="{{ v.value | escape }}"
                        {% if v.active %}checked{% endif %}
                        {% if v.count == 0 and v.active == false %}disabled{% endif %}
                        data-facet-input>
                      {%- if is_color -%}
                        <span class="facet-option__swatch" style="background-color: {{ v.value | downcase | replace: ' ', '-' }};" aria-hidden="true"></span>
                      {%- else -%}
                        <span class="facet-option__check" aria-hidden="true"></span>
                      {%- endif -%}
                      <span class="facet-option__label">{{ v.label }}{% if show_count %} <span class="facet-option__count">({{ v.count }})</span>{% endif %}</span>
                    </label>
                  </li>
                {%- endfor -%}
              </ul>

            {%- when 'price_range' -%}
              <div class="facet-price">
                <div class="facet-price__inputs">
                  <label class="facet-price__field">
                    <span>{{ 'filters.min_price' | t | default: 'Min' }}</span>
                    <input
                      type="number"
                      class="field__input"
                      name="{{ f.min_value.param_name }}"
                      value="{{ f.min_value.value | divided_by: 100.0 | default: '' }}"
                      min="0"
                      placeholder="0"
                      data-facet-input>
                  </label>
                  <span class="facet-price__sep" aria-hidden="true">–</span>
                  <label class="facet-price__field">
                    <span>{{ 'filters.max_price' | t | default: 'Max' }}</span>
                    <input
                      type="number"
                      class="field__input"
                      name="{{ f.max_value.param_name }}"
                      value="{{ f.max_value.value | divided_by: 100.0 | default: '' }}"
                      min="0"
                      placeholder="{{ f.range_max | divided_by: 100.0 | round }}"
                      data-facet-input>
                  </label>
                </div>
              </div>

            {%- when 'boolean' -%}
              <ul class="facet__list" role="list">
                {%- for v in f.true_values | split: ',' -%}
                  <li>
                    <label class="facet-option">
                      <input type="checkbox" class="sr-only" name="{{ f.param_name }}" value="{{ v }}" data-facet-input>
                      <span class="facet-option__check" aria-hidden="true"></span>
                      <span class="facet-option__label">{{ f.label }}</span>
                    </label>
                  </li>
                {%- endfor -%}
              </ul>

          {%- endcase -%}
        </div>
      </details>
    {%- endfor -%}

    <noscript>
      <button type="submit" class="btn btn--primary btn--full">{{ 'filters.apply' | t | default: 'Apply filters' }}</button>
    </noscript>
  </form>
</facets-form>

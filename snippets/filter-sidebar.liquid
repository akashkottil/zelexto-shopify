{% comment %}
  ZELEXTO THEME — snippets/filter-sidebar.liquid
  Desktop sidebar + mobile drawer filter UI.
  Uses Shopify's native collection filtering API (filter.param_name).
  Updates via Section Rendering API without full page reload.
{% endcomment %}

{%- liquid
  assign active_filter_count = 0
  for filter in collection.filters
    for value in filter.active_values
      assign active_filter_count = active_filter_count | plus: 1
    endfor
    if filter.type == 'price_range'
      if filter.min_value.value or filter.max_value.value
        assign active_filter_count = active_filter_count | plus: 1
      endif
    endif
  endfor
-%}

<!-- Desktop sidebar header controls -->
<div class="filter-header">
  <h2 class="filter-header__title">
    {{ 'collection.filters.title' | t | default: 'Filters' }}
    {%- if active_filter_count > 0 -%}
      <span class="filter-header__count">{{ active_filter_count }}</span>
    {%- endif -%}
  </h2>
  {%- if active_filter_count > 0 -%}
    <a href="{{ collection.url }}" class="filter-header__clear">{{ 'collection.filters.clear_all' | t | default: 'Clear all' }}</a>
  {%- endif -%}
</div>

<!-- Active filter pills -->
{%- if active_filter_count > 0 -%}
  <div class="filter-active" role="list" aria-label="{{ 'collection.filters.active' | t | default: 'Active filters' }}">
    {%- for filter in collection.filters -%}
      {%- for value in filter.active_values -%}
        <a
          class="filter-active__pill"
          href="{{ value.url_to_remove }}"
          role="listitem"
          aria-label="{{ 'general.remove' | t | default: 'Remove' }} {{ value.label }}">
          {{ value.label }}
          {%- render 'icon', name: 'close', size: 12 -%}
        </a>
      {%- endfor -%}
      {%- if filter.type == 'price_range' and filter.min_value.value or filter.max_value.value -%}
        <a class="filter-active__pill" href="{{ filter.url_to_remove }}" role="listitem">
          {{ filter.min_value.value | money | default: '0' }} – {{ filter.max_value.value | money | default: filter.range_max | money }}
          {%- render 'icon', name: 'close', size: 12 -%}
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
{%- endif -%}

<!-- Filter groups -->
<form id="filter-form" data-filter-form>
  {%- for filter in collection.filters -%}
    <details
      class="filter-group"
      id="filter-group-{{ filter.param_name | handleize }}"
      open>
      <summary class="filter-group__summary">
        <span>{{ filter.label }}</span>
        <span class="filter-group__indicator" aria-hidden="true">
          {%- render 'icon', name: 'chevron-down', size: 14 -%}
        </span>
      </summary>

      <div class="filter-group__body">

        {%- case filter.type -%}

          {%- when 'list' -%}
            {%- liquid
              assign display_type = 'checkbox'
              assign label_lower = filter.label | downcase
              if label_lower == 'color' or label_lower == 'colour'
                assign display_type = 'color'
              endif
            -%}

            <ul class="filter-list" role="list">
              {%- for value in filter.values -%}
                <li class="filter-list__item" role="listitem">
                  <label
                    class="filter-option{% if value.active %} is-active{% endif %}{% if value.count == 0 %} is-disabled{% endif %} filter-option--{{ display_type }}"
                    for="{{ filter.param_name }}-{{ value.param_name }}">

                    <input
                      type="checkbox"
                      id="{{ filter.param_name }}-{{ value.param_name }}"
                      name="{{ filter.param_name }}"
                      value="{{ value.value }}"
                      class="filter-option__input visually-hidden"
                      {% if value.active %}checked{% endif %}
                      {% if value.count == 0 %}disabled{% endif %}
                      data-filter>

                    {%- if display_type == 'color' -%}
                      <span
                        class="filter-swatch"
                        style="background-color: {{ value.value | downcase | replace: ' ', '-' }};
                               background-image: url({{ value.value | handle | append: '.png' | file_img_url: '30x' }});"
                        title="{{ value.label }}">
                      </span>
                    {%- else -%}
                      <span class="filter-option__check" aria-hidden="true"></span>
                    {%- endif -%}

                    <span class="filter-option__label">
                      {{ value.label }}
                      {%- if section.settings.show_filter_count -%}
                        <span class="filter-option__count">({{ value.count }})</span>
                      {%- endif -%}
                    </span>

                  </label>
                </li>
              {%- endfor -%}
            </ul>

          {%- when 'price_range' -%}
            <div class="filter-price">
              <div class="filter-price__range">
                <span>${{ filter.range_min | divided_by: 100.0 | round }}</span>
                <span>${{ filter.range_max | divided_by: 100.0 | round }}</span>
              </div>
              <div class="filter-price__slider" id="price-slider-{{ filter.param_name | handleize }}">
                <div class="filter-price__track">
                  <div class="filter-price__fill" id="price-fill-{{ filter.param_name | handleize }}"></div>
                </div>
                <input
                  type="range"
                  class="filter-price__input filter-price__input--min"
                  name="{{ filter.min_value.param_name }}"
                  min="{{ filter.range_min }}"
                  max="{{ filter.range_max }}"
                  value="{{ filter.min_value.value | default: filter.range_min }}"
                  step="100"
                  data-price-min>
                <input
                  type="range"
                  class="filter-price__input filter-price__input--max"
                  name="{{ filter.max_value.param_name }}"
                  min="{{ filter.range_min }}"
                  max="{{ filter.range_max }}"
                  value="{{ filter.max_value.value | default: filter.range_max }}"
                  step="100"
                  data-price-max>
              </div>
              <div class="filter-price__inputs">
                <div class="filter-price__field">
                  <label class="filter-price__field-label">From</label>
                  <div class="filter-price__field-input">
                    <span class="filter-price__currency">$</span>
                    <input
                      type="number"
                      name="{{ filter.min_value.param_name }}"
                      value="{{ filter.min_value.value | default: filter.range_min | divided_by: 100.0 | round }}"
                      min="{{ filter.range_min | divided_by: 100.0 | round }}"
                      max="{{ filter.range_max | divided_by: 100.0 | round }}"
                      class="filter-price__number"
                      placeholder="{{ filter.range_min | divided_by: 100.0 | round }}"
                      data-price-input-min>
                  </div>
                </div>
                <div class="filter-price__field">
                  <label class="filter-price__field-label">To</label>
                  <div class="filter-price__field-input">
                    <span class="filter-price__currency">$</span>
                    <input
                      type="number"
                      name="{{ filter.max_value.param_name }}"
                      value="{{ filter.max_value.value | default: filter.range_max | divided_by: 100.0 | round }}"
                      min="{{ filter.range_min | divided_by: 100.0 | round }}"
                      max="{{ filter.range_max | divided_by: 100.0 | round }}"
                      class="filter-price__number"
                      placeholder="{{ filter.range_max | divided_by: 100.0 | round }}"
                      data-price-input-max>
                  </div>
                </div>
              </div>
            </div>

        {%- endcase -%}

      </div>
    </details>
  {%- endfor -%}

  <!-- Filter submit on mobile -->
  <button type="submit" class="btn btn--primary btn--full filter-apply-btn" data-filter-apply>
    {{ 'collection.filters.apply' | t | default: 'Apply filters' }}
  </button>
</form>

<style>
  /* Filter header */
  .filter-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-4);
  }
  .filter-header__title {
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-semibold);
    display: flex; align-items: center; gap: var(--space-2);
    margin: 0;
  }
  .filter-header__count {
    display: inline-flex; align-items: center; justify-content: center;
    width: 20px; height: 20px;
    background: var(--color-primary); color: #fff;
    font-size: 10px; font-weight: 700;
    border-radius: var(--radius-full);
  }
  .filter-header__clear {
    font-size: var(--font-size-xs);
    color: var(--color-primary);
    text-decoration: underline;
  }

  /* Active pills */
  .filter-active {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }
  .filter-active__pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    font-size: var(--font-size-xs);
    text-decoration: none;
    color: var(--color-text);
    transition: background-color var(--transition-fast);
  }
  .filter-active__pill:hover { background: var(--color-border); }

  /* Filter groups */
  .filter-group {
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-4);
  }
  .filter-group__summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    list-style: none;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    user-select: none;
  }
  .filter-group__summary::-webkit-details-marker { display: none; }
  .filter-group__indicator { transition: transform var(--transition-fast); }
  details[open] .filter-group__indicator { transform: rotate(180deg); }

  .filter-group__body { padding-top: var(--space-4); }

  /* Checkbox list */
  .filter-list { list-style: none; display: flex; flex-direction: column; gap: var(--space-2); max-height: 240px; overflow-y: auto; }
  .filter-option {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    cursor: pointer;
    font-size: var(--font-size-sm);
    padding: var(--space-1) 0;
  }
  .filter-option.is-disabled { opacity: 0.4; cursor: default; }

  .filter-option__check {
    width: 18px; height: 18px;
    border: 1.5px solid var(--color-border);
    border-radius: 4px;
    flex-shrink: 0;
    transition: background-color var(--transition-fast), border-color var(--transition-fast);
    display: flex; align-items: center; justify-content: center;
  }
  .filter-option.is-active .filter-option__check {
    background: var(--color-primary);
    border-color: var(--color-primary);
  }
  .filter-option.is-active .filter-option__check::after {
    content: '';
    width: 10px; height: 6px;
    border-bottom: 2px solid #fff;
    border-left: 2px solid #fff;
    transform: rotate(-45deg) translateY(-1px);
  }

  .filter-option__label { user-select: none; }
  .filter-option__count { color: var(--color-text-secondary); font-size: var(--font-size-xs); }

  /* Color swatches */
  .filter-swatch {
    width: 24px; height: 24px;
    border-radius: var(--radius-full);
    border: 2px solid var(--color-border);
    flex-shrink: 0;
    background-size: cover;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.08);
  }
  .filter-option.is-active .filter-swatch {
    border-color: var(--color-primary);
    outline: 2px solid var(--color-primary);
    outline-offset: 1px;
  }

  /* Price range */
  .filter-price { display: flex; flex-direction: column; gap: var(--space-4); }
  .filter-price__range {
    display: flex;
    justify-content: space-between;
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
  }
  .filter-price__slider { position: relative; height: 36px; }
  .filter-price__track {
    position: absolute;
    top: 50%; left: 0; right: 0;
    height: 4px;
    background: var(--color-border);
    border-radius: var(--radius-full);
    transform: translateY(-50%);
  }
  .filter-price__fill {
    position: absolute;
    height: 100%;
    background: var(--color-primary);
    border-radius: var(--radius-full);
  }
  .filter-price__input {
    position: absolute;
    width: 100%;
    pointer-events: none;
    appearance: none; -webkit-appearance: none;
    background: transparent;
    top: 50%; transform: translateY(-50%);
    margin: 0;
  }
  .filter-price__input::-webkit-slider-thumb {
    pointer-events: all;
    appearance: none; -webkit-appearance: none;
    width: 18px; height: 18px;
    border-radius: var(--radius-full);
    background: var(--color-primary);
    border: 2px solid #fff;
    box-shadow: var(--shadow);
    cursor: pointer;
  }
  .filter-price__inputs { display: flex; gap: var(--space-3); }
  .filter-price__field { flex: 1; }
  .filter-price__field-label { font-size: var(--font-size-xs); color: var(--color-text-secondary); margin-bottom: var(--space-1); display: block; }
  .filter-price__field-input {
    display: flex; align-items: center;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    padding-left: var(--space-2);
    background: var(--color-bg);
  }
  .filter-price__currency { font-size: var(--font-size-sm); color: var(--color-text-secondary); }
  .filter-price__number { border: none; outline: none; width: 100%; padding: var(--space-2); font-family: var(--font-body); font-size: var(--font-size-sm); background: transparent; }

  /* Mobile apply button */
  .filter-apply-btn { display: none; }
  @media (max-width: 768px) { .filter-apply-btn { display: flex; } }
</style>

{%- comment -%}
  snippets/mobile-menu.liquid
  Slide-in mobile navigation. Uses <details>/<summary> accordions (no JS for nesting).
  Accepts: menu (linklist; defaults to main-menu)
{%- endcomment -%}

{%- liquid
  assign nav_menu = menu | default: linklists['main-menu']
-%}

<div class="mobile-menu-overlay" id="mobile-menu-overlay" aria-hidden="true" data-mobile-menu-overlay></div>

<aside
  class="mobile-menu"
  id="mobile-menu"
  role="dialog"
  aria-label="{{ 'navigation.open_menu' | t }}"
  aria-modal="true"
  aria-hidden="true"
  tabindex="-1">

  <div class="mobile-menu__header">
    <span class="mobile-menu__brand">{{ shop.name }}</span>
    <button
      type="button"
      class="header-icon-btn"
      aria-label="{{ 'navigation.close_menu' | t }}"
      data-mobile-menu-close>
      {%- render 'icon', name: 'close', class: 'icon' -%}
    </button>
  </div>

  <form class="mobile-menu__search" action="{{ routes.search_url }}" method="get" role="search">
    <label class="sr-only" for="mobile-search">{{ 'header.search_placeholder' | t }}</label>
    <span class="mobile-menu__search-icon">{%- render 'icon', name: 'search', class: 'icon' -%}</span>
    <input
      type="search"
      id="mobile-search"
      name="q"
      class="mobile-menu__search-input"
      placeholder="{{ 'header.search_placeholder' | t }}"
      autocomplete="off">
  </form>

  <nav class="mobile-menu__nav" aria-label="{{ 'navigation.open_menu' | t }}">
    <ul class="mobile-menu__list" role="list">
      {%- for link in nav_menu.links -%}
        <li class="mobile-menu__item">
          {%- if link.links.size > 0 -%}
            <details class="mobile-menu__accordion">
              <summary class="mobile-menu__trigger">
                <span>{{ link.title }}</span>
                <span class="mobile-menu__chevron" aria-hidden="true">
                  {%- render 'icon', name: 'chevron-down', class: 'icon icon--xs' -%}
                </span>
              </summary>
              <div class="mobile-menu__panel">
                <a href="{{ link.url }}" class="mobile-menu__view-all">
                  {{ 'general.view_all' | t }} {{ link.title }}
                </a>
                <ul class="mobile-menu__sub-list" role="list">
                  {%- for sub in link.links -%}
                    <li>
                      {%- if sub.links.size > 0 -%}
                        <details class="mobile-menu__accordion mobile-menu__accordion--lvl2">
                          <summary class="mobile-menu__trigger mobile-menu__trigger--lvl2">
                            <span>{{ sub.title }}</span>
                            <span class="mobile-menu__chevron" aria-hidden="true">
                              {%- render 'icon', name: 'chevron-down', class: 'icon icon--xs' -%}
                            </span>
                          </summary>
                          <ul class="mobile-menu__sub-list mobile-menu__sub-list--lvl2" role="list">
                            {%- for deep in sub.links -%}
                              <li>
                                <a href="{{ deep.url }}" class="mobile-menu__sub-link mobile-menu__sub-link--deep">{{ deep.title }}</a>
                              </li>
                            {%- endfor -%}
                          </ul>
                        </details>
                      {%- else -%}
                        <a href="{{ sub.url }}" class="mobile-menu__sub-link"{% if sub.current %} aria-current="page"{% endif %}>{{ sub.title }}</a>
                      {%- endif -%}
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            </details>
          {%- else -%}
            <a href="{{ link.url }}" class="mobile-menu__link"{% if link.current %} aria-current="page"{% endif %}>{{ link.title }}</a>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </nav>

  <div class="mobile-menu__footer">
    <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="mobile-menu__footer-link">
      {%- render 'icon', name: 'account', class: 'icon icon--sm' -%}
      <span>{%- if customer -%}{{ customer.first_name | default: 'Account' }}{%- else -%}{{ 'account.login' | t }}{%- endif -%}</span>
    </a>
    {%- if localization.available_languages.size > 1 -%}
      <div class="mobile-menu__footer-locale">
        {%- render 'locale-selector' -%}
      </div>
    {%- endif -%}
    {%- if localization.available_countries.size > 1 -%}
      <div class="mobile-menu__footer-locale">
        {%- render 'currency-selector' -%}
      </div>
    {%- endif -%}
  </div>
</aside>

<style>
  .mobile-menu-overlay{
    position:fixed;inset:0;z-index:calc(var(--z-drawer) - 1);
    background:rgba(0,0,0,.4);opacity:0;pointer-events:none;
    -webkit-backdrop-filter:blur(2px);backdrop-filter:blur(2px);
    transition:opacity var(--dur-base) var(--ease-standard);
  }
  .mobile-menu-overlay.is-open{opacity:1;pointer-events:auto}
  .mobile-menu{
    position:fixed;top:0;left:0;height:100vh;height:100dvh;
    width:min(380px, 86vw);background:var(--c-bg);
    z-index:var(--z-drawer);transform:translateX(-100%);
    transition:transform var(--dur-slow) var(--ease-emphasized);
    display:flex;flex-direction:column;overflow:hidden;
    box-shadow:var(--shadow-2);
  }
  [dir="rtl"] .mobile-menu{left:auto;right:0;transform:translateX(100%)}
  .mobile-menu.is-open{transform:translateX(0)}
  @media (min-width:769px){
    .mobile-menu,.mobile-menu-overlay{display:none!important}
  }
  .mobile-menu__header{
    display:flex;align-items:center;justify-content:space-between;
    padding:var(--s-3) var(--s-4);border-bottom:1px solid var(--c-line);
  }
  .mobile-menu__brand{
    font-family:var(--font-display);font-weight:var(--weight-semibold);
    font-size:var(--fs-19);
  }
  .mobile-menu__search{
    display:flex;align-items:center;gap:var(--s-2);
    padding:var(--s-3) var(--s-4);
    border-bottom:1px solid var(--c-line);
  }
  .mobile-menu__search-icon{display:inline-flex;color:var(--c-ink-muted)}
  .mobile-menu__search-input{
    flex:1;background:var(--c-elev);
    border:1px solid var(--c-line);border-radius:var(--radius-pill);
    padding:var(--s-2) var(--s-3);
    font-size:var(--fs-14);color:var(--c-ink);min-height:40px;
  }
  .mobile-menu__nav{flex:1;overflow-y:auto;padding-block:var(--s-2)}
  .mobile-menu__list,.mobile-menu__sub-list{list-style:none;padding:0;margin:0}
  .mobile-menu__item{border-bottom:1px solid var(--c-line)}
  .mobile-menu__link,.mobile-menu__trigger{
    display:flex;align-items:center;justify-content:space-between;
    padding:var(--s-4);
    font-size:var(--fs-16);font-weight:var(--weight-medium);
    color:var(--c-ink);min-height:48px;
    cursor:pointer;list-style:none;
    transition:background-color var(--dur-fast) var(--ease-standard);
  }
  .mobile-menu__trigger::-webkit-details-marker{display:none}
  .mobile-menu__link:hover,.mobile-menu__trigger:hover{background:var(--c-elev)}
  .mobile-menu__chevron{transition:transform var(--dur-fast) var(--ease-standard)}
  details[open] > .mobile-menu__trigger .mobile-menu__chevron{transform:rotate(180deg)}
  .mobile-menu__panel{background:var(--c-elev);padding-block:var(--s-2)}
  .mobile-menu__view-all{
    display:block;padding:var(--s-2) var(--s-6);
    font-size:var(--fs-12);font-weight:var(--weight-semibold);
    color:var(--c-accent);text-transform:uppercase;letter-spacing:.06em;
  }
  .mobile-menu__sub-link{
    display:flex;align-items:center;justify-content:space-between;
    padding:var(--s-3) var(--s-6);
    font-size:var(--fs-14);min-height:44px;
  }
  .mobile-menu__sub-link:hover{color:var(--c-accent)}
  .mobile-menu__sub-link--deep{padding-left:var(--s-7);font-size:var(--fs-12);color:var(--c-ink-muted)}
  .mobile-menu__sub-list--lvl2{background:var(--c-bg)}
  .mobile-menu__trigger--lvl2{padding-inline:var(--s-6);font-size:var(--fs-14);font-weight:var(--weight-regular)}
  .mobile-menu__footer{
    flex-shrink:0;padding:var(--s-4);border-top:1px solid var(--c-line);
    display:flex;align-items:center;flex-wrap:wrap;gap:var(--s-3);
  }
  .mobile-menu__footer-link{
    display:inline-flex;align-items:center;gap:var(--s-2);
    font-size:var(--fs-14);font-weight:var(--weight-medium);
  }
  .mobile-menu__footer-locale{flex:1;min-width:120px}
</style>

<script>
  (function(){
    'use strict';
    var menu = document.getElementById('mobile-menu');
    var overlay = document.getElementById('mobile-menu-overlay');
    if(!menu) return;
    var triggers = document.querySelectorAll('[data-mobile-menu-open]');
    var closers = document.querySelectorAll('[data-mobile-menu-close]');
    var prevFocus = null;

    function open(){
      prevFocus = document.activeElement;
      menu.classList.add('is-open');
      overlay.classList.add('is-open');
      menu.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      triggers.forEach(function(t){ t.setAttribute('aria-expanded', 'true'); });
      var first = menu.querySelector('button, a, input');
      if(first) first.focus();
    }
    function close(){
      menu.classList.remove('is-open');
      overlay.classList.remove('is-open');
      menu.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      triggers.forEach(function(t){ t.setAttribute('aria-expanded', 'false'); });
      if(prevFocus) prevFocus.focus();
    }
    triggers.forEach(function(t){ t.addEventListener('click', open); });
    closers.forEach(function(c){ c.addEventListener('click', close); });
    overlay.addEventListener('click', close);
    menu.addEventListener('keydown', function(e){
      if(e.key === 'Escape') close();
      if(e.key === 'Tab'){
        var focusable = menu.querySelectorAll('a[href], button:not([disabled]), input, select, [tabindex]:not([tabindex="-1"])');
        if(!focusable.length) return;
        var first = focusable[0], last = focusable[focusable.length - 1];
        if(e.shiftKey && document.activeElement === first){ e.preventDefault(); last.focus(); }
        else if(!e.shiftKey && document.activeElement === last){ e.preventDefault(); first.focus(); }
      }
    });
  })();
</script>

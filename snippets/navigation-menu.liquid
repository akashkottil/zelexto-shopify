{%- comment -%}
  snippets/navigation-menu.liquid
  Desktop multi-level navigation. Pure CSS hover, JS only for keyboard a11y.
  Accepts: menu (linklist; defaults to main-menu)
{%- endcomment -%}

{%- liquid
  assign nav_menu = menu | default: linklists['main-menu']
-%}

<nav class="nav-desktop" aria-label="Primary">
  <ul class="nav-desktop__list" role="list">
    {%- for link in nav_menu.links -%}
      {%- assign has_children = false -%}
      {%- if link.links.size > 0 -%}{%- assign has_children = true -%}{%- endif -%}

      <li class="nav-desktop__item{% if has_children %} nav-desktop__item--has-children{% endif %}{% if link.current %} is-active{% endif %}" data-nav-item>
        <a
          href="{{ link.url }}"
          class="nav-desktop__link"
          {% if link.current %}aria-current="page"{% endif %}
          {% if has_children %}aria-haspopup="true" aria-expanded="false" aria-controls="mega-{{ link.handle }}"{% endif %}>
          <span>{{ link.title }}</span>
          {%- if has_children -%}
            {%- render 'icon', name: 'chevron-down', class: 'nav-desktop__chevron' -%}
          {%- endif -%}
        </a>

        {%- if has_children -%}
          {%- render 'mega-menu', menu_item: link -%}
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>
</nav>

<style>
  .nav-desktop{display:none}
  @media (min-width:769px){
    .nav-desktop{display:flex;justify-content:center;flex:1}
  }
  .nav-desktop__list{
    display:flex;align-items:center;gap:var(--s-2);
    list-style:none;padding:0;margin:0;
  }
  .nav-desktop__item{position:static}
  .nav-desktop__link{
    display:inline-flex;align-items:center;gap:var(--s-1);
    padding:var(--s-2) var(--s-3);
    font-size:var(--fs-14);font-weight:var(--weight-medium);
    letter-spacing:var(--tracking-body);
    color:inherit;border-radius:var(--radius-pill);
    transition:background-color var(--dur-fast) var(--ease-standard),
               color var(--dur-fast) var(--ease-standard);
    white-space:nowrap;text-decoration:none;
  }
  .nav-desktop__link:hover,
  .nav-desktop__item.is-active > .nav-desktop__link{
    background:var(--c-elev);color:var(--c-ink);
  }
  .site-header--transparent:not(.is-scrolled) .nav-desktop__link:hover,
  .site-header--transparent:not(.is-scrolled) .nav-desktop__item.is-active > .nav-desktop__link{
    background:rgba(255,255,255,.14);color:#fff;
  }
  .nav-desktop__chevron{
    width:14px;height:14px;
    transition:transform var(--dur-fast) var(--ease-standard);
  }
  .nav-desktop__item--has-children:hover > .nav-desktop__link .nav-desktop__chevron,
  .nav-desktop__item--has-children.is-open > .nav-desktop__link .nav-desktop__chevron{
    transform:rotate(180deg);
  }
  .nav-desktop__item--has-children:hover > .mega-menu,
  .nav-desktop__item--has-children:focus-within > .mega-menu,
  .nav-desktop__item--has-children.is-open > .mega-menu{
    opacity:1;pointer-events:auto;transform:translate(-50%, 0);
  }
</style>

<script>
  (function(){
    'use strict';
    var items = document.querySelectorAll('.nav-desktop__item--has-children');
    items.forEach(function(item){
      var trigger = item.querySelector('.nav-desktop__link');
      var menu = item.querySelector('.mega-menu');
      if(!trigger || !menu) return;
      trigger.addEventListener('keydown', function(e){
        if(e.key === 'Enter' || e.key === ' '){
          e.preventDefault();
          var open = item.classList.toggle('is-open');
          trigger.setAttribute('aria-expanded', String(open));
          if(open){
            var first = menu.querySelector('a');
            if(first) first.focus();
          }
        }
        if(e.key === 'Escape'){
          item.classList.remove('is-open');
          trigger.setAttribute('aria-expanded', 'false');
        }
      });
      item.addEventListener('focusout', function(){
        setTimeout(function(){
          if(!item.contains(document.activeElement)){
            item.classList.remove('is-open');
            trigger.setAttribute('aria-expanded', 'false');
          }
        }, 50);
      });
    });
    document.addEventListener('click', function(e){
      if(!e.target.closest('.nav-desktop__item--has-children')){
        items.forEach(function(item){
          item.classList.remove('is-open');
          var t = item.querySelector('.nav-desktop__link');
          if(t) t.setAttribute('aria-expanded', 'false');
        });
      }
    });
  })();
</script>

{%- comment -%}
  Locale (language) selector using Shopify Markets `localization` form.
{%- endcomment -%}

{%- if localization.available_languages.size > 1 -%}
  <localization-form
    class="loc-selector loc-selector--locale"
    data-module="localization.js"
    data-loc-type="language"
  >
    {%- form 'localization', class: 'loc-selector__form' -%}
      <input type="hidden" name="_method" value="put">
      <details class="loc-selector__details">
        <summary class="loc-selector__summary" aria-label="{{ 'localization.language_label' | t }}">
          {%- render 'icon', name: 'globe', class: 'icon icon--sm' -%}
          <span class="loc-selector__current">
            {{ localization.language.iso_code | upcase }}
          </span>
          {%- render 'icon', name: 'chevron-down', class: 'icon icon--sm loc-selector__chev' -%}
        </summary>

        <div class="loc-selector__panel" role="dialog" aria-label="{{ 'localization.language_label' | t }}">
          <ul class="loc-selector__list" role="list">
            {%- for lang in localization.available_languages -%}
              <li>
                <button
                  type="submit"
                  name="locale_code"
                  value="{{ lang.iso_code }}"
                  class="loc-selector__option {% if lang.iso_code == localization.language.iso_code %}is-active{% endif %}"
                  aria-current="{% if lang.iso_code == localization.language.iso_code %}true{% else %}false{% endif %}"
                >
                  <span class="loc-selector__option-name">{{ lang.endonym_name | capitalize }}</span>
                  <span class="loc-selector__option-meta">{{ lang.iso_code | upcase }}</span>
                  {%- if lang.iso_code == localization.language.iso_code -%}
                    {%- render 'icon', name: 'check', class: 'icon icon--sm' -%}
                  {%- endif -%}
                </button>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </details>
    {%- endform -%}
  </localization-form>
{%- endif -%}

{%- comment -%}
  Zelexto v2 — rating-stars.liquid
  Reads product.metafields.reviews.rating + .rating_count by default;
  caller can override with `rating` / `count` params. Falls back gracefully
  when no metafield is set (renders nothing).

  Accepts:
    product   — optional, used to read metafields
    rating    — optional float 0-5
    count     — optional integer
    show_count — default true
    size      — default 'sm' ('sm' | 'md')
{%- endcomment -%}

{%- liquid
  assign rating_value = rating
  assign rating_count = count

  if rating_value == nil and product
    if product.metafields.reviews.rating.value
      assign rating_data = product.metafields.reviews.rating.value
      if rating_data.rating
        assign rating_value = rating_data.rating | times: 1.0
      else
        assign rating_value = rating_data | times: 1.0
      endif
    endif
    if product.metafields.reviews.rating_count.value
      assign rating_count = product.metafields.reviews.rating_count.value
    endif
  endif

  assign show_count_attr = show_count
  if show_count_attr == nil
    assign show_count_attr = true
  endif
  assign size_class = size | default: 'sm'
-%}

{%- if rating_value and rating_value > 0 -%}
  {%- assign full = rating_value | floor -%}
  {%- assign frac = rating_value | minus: full -%}
  {%- assign empty = 5 | minus: full -%}
  {%- if frac > 0 -%}{%- assign empty = empty | minus: 1 -%}{%- endif -%}

  <div class="rating rating--{{ size_class }}" role="img" aria-label="{{ rating_value }} {{ 'general.out_of' | t | default: 'out of' }} 5">
    <span class="rating__stars" aria-hidden="true">
      {%- for i in (1..full) -%}
        {%- render 'icon', name: 'star', class: 'rating__star rating__star--full' -%}
      {%- endfor -%}
      {%- if frac > 0 -%}
        <span class="rating__star rating__star--partial" style="--fill:{{ frac | times: 100 | round }}%;">
          {%- render 'icon', name: 'star-empty', class: 'rating__star-bg' -%}
          <span class="rating__star-fg">{%- render 'icon', name: 'star' -%}</span>
        </span>
      {%- endif -%}
      {%- if empty > 0 -%}
        {%- for i in (1..empty) -%}
          {%- render 'icon', name: 'star-empty', class: 'rating__star rating__star--empty' -%}
        {%- endfor -%}
      {%- endif -%}
    </span>
    {%- if show_count_attr and rating_count -%}
      <span class="rating__count">({{ rating_count }})</span>
    {%- endif -%}
  </div>
{%- endif -%}

{%- comment -%}
  snippets/header-icons.liquid
  Search, account, cart triggers + currency/locale selectors.
  Accepts:
    show_currency_selector (bool)
    show_locale_selector (bool)
{%- endcomment -%}

<div class="header-icons">

  {%- if show_locale_selector and localization.available_languages.size > 1 -%}
    <div class="header-icons__locale">
      {%- render 'locale-selector' -%}
    </div>
  {%- endif -%}

  {%- if show_currency_selector and localization.available_countries.size > 1 -%}
    <div class="header-icons__currency">
      {%- render 'currency-selector' -%}
    </div>
  {%- endif -%}

  {%- if settings.enable_predictive_search != false -%}
    <button
      type="button"
      class="header-icon-btn"
      aria-label="{{ 'header.search_label' | t | default: 'Search' }}"
      aria-expanded="false"
      aria-controls="search-modal"
      data-search-toggle>
      {%- render 'icon', name: 'search', class: 'icon' -%}
    </button>
  {%- endif -%}

  <a
    href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
    class="header-icon-btn"
    aria-label="{{ 'header.account_label' | t }}">
    {%- render 'icon', name: 'account', class: 'icon' -%}
  </a>

  <button
    type="button"
    class="header-icon-btn header-icon-btn--cart"
    aria-label="{{ 'header.cart_label' | t }}"
    aria-expanded="false"
    aria-controls="cart-drawer"
    data-cart-toggle>
    {%- render 'icon', name: 'cart', class: 'icon' -%}
    <span
      class="cart-count"
      data-cart-count
      data-empty="{% if cart.item_count == 0 %}true{% else %}false{% endif %}"
      aria-live="polite"
      aria-atomic="true">{{ cart.item_count }}</span>
  </button>
</div>

<style>
  .header-icons{
    display:flex;align-items:center;gap:var(--s-1);
  }
  .header-icons__locale,.header-icons__currency{display:none}
  @media (min-width:769px){
    .header-icons__locale,.header-icons__currency{display:flex;align-items:center}
  }
  .header-icon-btn{
    display:inline-flex;align-items:center;justify-content:center;
    position:relative;width:44px;height:44px;border-radius:var(--radius-pill);
    color:inherit;background:none;
    transition:background-color var(--dur-fast) var(--ease-standard),
               color var(--dur-fast) var(--ease-standard);
  }
  .header-icon-btn:hover{background:var(--c-elev)}
  .site-header--transparent:not(.is-scrolled) .header-icon-btn:hover{
    background:rgba(255,255,255,.12)
  }
  .header-icon-btn .icon{width:22px;height:22px}
  .cart-count{
    position:absolute;top:6px;right:6px;
    min-width:18px;height:18px;padding:0 5px;
    background:var(--c-accent);color:var(--c-accent-ink);
    font-size:11px;font-weight:var(--weight-semibold);
    line-height:18px;border-radius:var(--radius-pill);
    text-align:center;
  }
  .cart-count[data-empty="true"]{display:none}
</style>

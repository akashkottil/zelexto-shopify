{%- comment -%}
  trust-badges.liquid

  Row of trust signals (free shipping, returns, secure checkout, support).
  Uses the v2 token system and locale strings under `trust.*`.

  Accepts:
    style ('row' | 'column'), size ('sm' | 'md'),
    items (comma-separated subset: shipping,returns,secure,support)
{%- endcomment -%}

{%- liquid
  assign badge_style = style | default: 'row'
  assign badge_size  = size  | default: 'md'
  assign list = items | default: 'shipping,returns,secure,support'
  assign tokens = list | split: ','
-%}

<ul class="trust-badges trust-badges--{{ badge_style }} trust-badges--{{ badge_size }}"
    role="list"
    aria-label="{{ 'trust.secure_checkout' | t }}">
  {%- for raw in tokens -%}
    {%- assign tok = raw | strip -%}
    {%- case tok -%}
      {%- when 'shipping' -%}
        <li class="trust-badge">
          {%- render 'icon', name: 'truck', class: 'trust-badge__icon' -%}
          <span class="trust-badge__label">{{ 'trust.free_shipping' | t }}</span>
        </li>
      {%- when 'returns' -%}
        <li class="trust-badge">
          {%- render 'icon', name: 'refresh', class: 'trust-badge__icon' -%}
          <span class="trust-badge__label">{{ 'trust.free_returns' | t }}</span>
        </li>
      {%- when 'secure' -%}
        <li class="trust-badge">
          {%- render 'icon', name: 'shield', class: 'trust-badge__icon' -%}
          <span class="trust-badge__label">{{ 'trust.secure_checkout' | t }}</span>
        </li>
      {%- when 'support' -%}
        <li class="trust-badge">
          {%- render 'icon', name: 'mail', class: 'trust-badge__icon' -%}
          <span class="trust-badge__label">{{ 'trust.support' | t }}</span>
        </li>
    {%- endcase -%}
  {%- endfor -%}
</ul>

<style>
  .trust-badges {
    display: flex;
    gap: var(--s-5);
    flex-wrap: wrap;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .trust-badges--row    { flex-direction: row; }
  .trust-badges--column { flex-direction: column; }
  .trust-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    color: var(--c-ink-muted);
  }
  .trust-badge__icon { width: 20px; height: 20px; flex-shrink: 0; }
  .trust-badge__label {
    font-size: var(--fs-14);
    color: var(--c-ink);
  }
  .trust-badges--sm .trust-badge__label { font-size: var(--fs-12); }
  @media (max-width: 480px) {
    .trust-badges--row { gap: var(--s-3); }
    .trust-badges--row .trust-badge__label { font-size: var(--fs-12); }
  }
</style>

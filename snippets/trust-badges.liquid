{% comment %}
  ZELEXTO THEME — snippets/trust-badges.liquid
  Configurable trust badges row. Used on product pages, CTA sections, cart.
  Accepts: style ("row" | "column"), size ("sm" | "md")
{% endcomment %}

{%- liquid
  assign badge_style = style | default: 'row'
  assign badge_size  = size  | default: 'md'
-%}

<div class="trust-badges trust-badges--{{ badge_style }} trust-badges--{{ badge_size }}" aria-label="Trust signals">
  <div class="trust-badge">
    {%- render 'icon', name: 'shield', size: 20 -%}
    <span>{{ 'trust.secure_checkout' | t }}</span>
  </div>
  <div class="trust-badge">
    {%- render 'icon', name: 'truck', size: 20 -%}
    <span>{{ 'trust.free_shipping' | t }}</span>
  </div>
  <div class="trust-badge">
    {%- render 'icon', name: 'refresh', size: 20 -%}
    <span>{{ 'trust.free_returns' | t }}</span>
  </div>
  <div class="trust-badge">
    {%- render 'icon', name: 'check', size: 20 -%}
    <span>{{ 'trust.authentic' | t }}</span>
  </div>
</div>

<style>
  .trust-badges {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .trust-badges--row { flex-direction: row; justify-content: center; }
  .trust-badges--column { flex-direction: column; }

  .trust-badge {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-secondary);
  }

  .trust-badge svg { flex-shrink: 0; }

  .trust-badge span {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    white-space: nowrap;
  }

  .trust-badges--sm .trust-badge span { font-size: var(--font-size-xs); }

  @media (max-width: 480px) {
    .trust-badges--row { gap: var(--space-3); }
    .trust-badges--row .trust-badge span { display: none; }
  }
</style>

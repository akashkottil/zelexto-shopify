{% comment %}
  ZELEXTO THEME — snippets/mega-menu.liquid
  Multi-column mega menu for desktop navigation.
  Accepts: menu_item (linklists item), position (index for z-index staggering)

  Mega menu content is enhanced via metafields on the Shopify navigation linklist:
  - navigation.featured_image  → image shown in featured column
  - navigation.promo_title     → promotional banner headline
  - navigation.promo_text      → promotional banner description
  - navigation.promo_link      → promotional banner CTA URL
  - navigation.featured_collection_handle → collection handle to show products from
{% endcomment %}

{%- liquid
  assign sub_links = menu_item.links
  assign cols_count = 1
  if sub_links.size > 0
    assign cols_count = 2
  endif

  assign featured_image = menu_item.object.metafields.navigation.featured_image.value
  assign promo_title    = menu_item.object.metafields.navigation.promo_title.value
  assign promo_link     = menu_item.object.metafields.navigation.promo_link.value
  assign featured_col   = menu_item.object.metafields.navigation.featured_collection_handle.value

  if featured_image != blank or promo_title != blank
    assign cols_count = 3
  endif
  if featured_col != blank
    assign featured_collection = collections[featured_col]
    assign cols_count = 4
  endif
-%}

<div
  class="mega-menu mega-menu--cols-{{ cols_count }}"
  id="mega-menu-{{ menu_item.handle }}"
  role="region"
  aria-label="{{ menu_item.title }} navigation">

  <!-- Column 1+: Sub-navigation links grouped by level-2 items -->
  {%- if sub_links.size > 0 -%}
    <div class="mega-menu__links">
      {%- for link in sub_links -%}
        <div class="mega-menu__group">
          <a
            href="{{ link.url }}"
            class="mega-menu__group-title"
            {% if link.current %}aria-current="page"{% endif %}>
            {{ link.title }}
          </a>
          {%- if link.links.size > 0 -%}
            <ul class="mega-menu__sub-list" role="list">
              {%- for sub_link in link.links -%}
                <li>
                  <a
                    href="{{ sub_link.url }}"
                    class="mega-menu__sub-link"
                    {% if sub_link.current %}aria-current="page"{% endif %}>
                    {{ sub_link.title }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  <!-- Featured image column -->
  {%- if featured_image != blank -%}
    <div class="mega-menu__featured">
      {%- if promo_link != blank -%}<a href="{{ promo_link }}" class="mega-menu__featured-link">{%- endif -%}
        <div class="mega-menu__featured-image ratio-portrait">
          <img
            src="{{ featured_image | image_url: width: 400 }}"
            srcset="{{ featured_image | image_url: width: 300 }} 300w,
                    {{ featured_image | image_url: width: 500 }} 500w"
            sizes="280px"
            loading="lazy"
            decoding="async"
            width="400"
            height="533"
            alt="{{ featured_image.alt | escape | default: menu_item.title }}">
        </div>
        {%- if promo_title != blank -%}
          <div class="mega-menu__featured-body">
            <p class="mega-menu__featured-title">{{ promo_title }}</p>
            {%- assign promo_text = menu_item.object.metafields.navigation.promo_text.value -%}
            {%- if promo_text -%}
              <p class="mega-menu__featured-text">{{ promo_text }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- if promo_link != blank -%}</a>{%- endif -%}
    </div>
  {%- endif -%}

  <!-- Featured products column -->
  {%- if featured_collection != blank -%}
    <div class="mega-menu__products">
      <p class="mega-menu__products-title">{{ 'general.view_all' | t }}</p>
      <ul class="mega-menu__products-list" role="list">
        {%- for product in featured_collection.products limit: 3 -%}
          <li class="mega-menu__product-item">
            <a href="{{ product.url }}" class="mega-menu__product-link">
              <div class="mega-menu__product-image">
                <img
                  src="{{ product.featured_image | image_url: width: 80 }}"
                  width="80"
                  height="80"
                  loading="lazy"
                  decoding="async"
                  alt="{{ product.featured_image.alt | escape | default: product.title }}">
              </div>
              <div class="mega-menu__product-info">
                <p class="mega-menu__product-title">{{ product.title }}</p>
                <p class="mega-menu__product-price">{{ product.price | money }}</p>
              </div>
            </a>
          </li>
        {%- endfor -%}
      </ul>
      <a href="{{ featured_collection.url }}" class="mega-menu__view-all btn btn--ghost btn--sm">
        {{ 'general.view_all' | t }}
        {%- render 'icon', name: 'arrow-right', size: 14 -%}
      </a>
    </div>
  {%- endif -%}

</div>

<style>
  .mega-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    width: min(1100px, calc(100vw - 2rem));
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-xl);
    padding: var(--space-8);
    display: none;
    grid-gap: var(--space-8);
    z-index: var(--z-dropdown);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-base), transform var(--transition-base);
    transform-origin: top center;
  }

  .mega-menu--cols-2 { grid-template-columns: 1fr 280px; display: grid; }
  .mega-menu--cols-3 { grid-template-columns: 1fr 280px 280px; display: grid; }
  .mega-menu--cols-4 { grid-template-columns: 1fr 200px 200px 220px; display: grid; }

  .mega-menu.is-open {
    opacity: 1;
    pointer-events: auto;
    display: grid;
  }

  .mega-menu__group { margin-bottom: var(--space-6); }
  .mega-menu__group:last-child { margin-bottom: 0; }

  .mega-menu__group-title {
    display: block;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-bottom: var(--space-3);
    transition: color var(--transition-fast);
  }
  .mega-menu__group-title:hover { color: var(--color-primary); }

  .mega-menu__sub-list { list-style: none; display: flex; flex-direction: column; gap: var(--space-2); }
  .mega-menu__sub-link {
    font-size: var(--font-size-sm);
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--transition-fast), padding-left var(--transition-fast);
    display: block;
    padding: var(--space-1) 0;
  }
  .mega-menu__sub-link:hover { color: var(--color-primary); padding-left: var(--space-2); }

  /* Featured image */
  .mega-menu__featured-link { text-decoration: none; display: block; }
  .mega-menu__featured-image { border-radius: var(--radius); overflow: hidden; }
  .mega-menu__featured-image img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--transition-slow); }
  .mega-menu__featured-link:hover .mega-menu__featured-image img { transform: scale(1.04); }
  .mega-menu__featured-body { margin-top: var(--space-3); }
  .mega-menu__featured-title { font-weight: var(--font-weight-semibold); font-size: var(--font-size-sm); }
  .mega-menu__featured-text { font-size: var(--font-size-xs); color: var(--color-text-secondary); margin-top: var(--space-1); }

  /* Featured products */
  .mega-menu__products-title {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
  }
  .mega-menu__products-list { list-style: none; display: flex; flex-direction: column; gap: var(--space-3); margin-bottom: var(--space-4); }
  .mega-menu__product-link { display: flex; gap: var(--space-3); align-items: center; text-decoration: none; }
  .mega-menu__product-link:hover .mega-menu__product-title { color: var(--color-primary); }
  .mega-menu__product-image { width: 56px; height: 56px; border-radius: var(--radius); overflow: hidden; flex-shrink: 0; background: var(--color-surface); }
  .mega-menu__product-image img { width: 100%; height: 100%; object-fit: cover; }
  .mega-menu__product-title { font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); line-height: 1.3; transition: color var(--transition-fast); }
  .mega-menu__product-price { font-size: var(--font-size-xs); color: var(--color-text-secondary); margin-top: 2px; }
</style>

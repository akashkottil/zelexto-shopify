{%- comment -%}
  snippets/mega-menu.liquid — Apple-style mega menu.
  Accepts: menu_item (linklist link)
  Optional metafields on the linklist item:
    navigation.featured_image
    navigation.promo_title
    navigation.promo_text
    navigation.promo_link
    navigation.featured_collection_handle
{%- endcomment -%}

{%- liquid
  assign sub_links = menu_item.links

  assign featured_image = menu_item.object.metafields.navigation.featured_image.value
  assign promo_title    = menu_item.object.metafields.navigation.promo_title.value
  assign promo_text     = menu_item.object.metafields.navigation.promo_text.value
  assign promo_link     = menu_item.object.metafields.navigation.promo_link.value
  assign featured_handle = menu_item.object.metafields.navigation.featured_collection_handle.value

  assign cols = 1
  if sub_links.size > 0
    assign cols = 2
  endif
  if featured_image != blank
    assign cols = cols | plus: 1
  endif
  if featured_handle != blank
    assign featured_collection = collections[featured_handle]
    assign cols = cols | plus: 1
  endif
-%}

<div
  class="mega-menu mega-menu--cols-{{ cols }}"
  id="mega-{{ menu_item.handle }}"
  role="region"
  aria-label="{{ menu_item.title }}">

  {%- if sub_links.size > 0 -%}
    <div class="mega-menu__cols">
      {%- for link in sub_links -%}
        <div class="mega-menu__group">
          <a
            href="{{ link.url }}"
            class="mega-menu__group-title"
            {% if link.current %}aria-current="page"{% endif %}>
            {{ link.title }}
          </a>
          {%- if link.links.size > 0 -%}
            <ul class="mega-menu__sub-list" role="list">
              {%- for sub in link.links -%}
                <li>
                  <a href="{{ sub.url }}" class="mega-menu__sub-link"{% if sub.current %} aria-current="page"{% endif %}>
                    {{ sub.title }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- if featured_image != blank -%}
    <a class="mega-menu__featured" href="{{ promo_link | default: menu_item.url }}">
      <div class="aspect aspect--3/4 mega-menu__featured-img">
        {%- render 'responsive-image',
          image: featured_image,
          alt: promo_title | default: menu_item.title,
          sizes: '(min-width: 1024px) 280px, 240px',
          loading: 'lazy'
        -%}
      </div>
      {%- if promo_title != blank -%}
        <div class="mega-menu__featured-body">
          <p class="mega-menu__featured-title">{{ promo_title }}</p>
          {%- if promo_text != blank -%}
            <p class="mega-menu__featured-text">{{ promo_text }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}
    </a>
  {%- endif -%}

  {%- if featured_collection != blank -%}
    <div class="mega-menu__products">
      <p class="mega-menu__products-title">{{ featured_collection.title }}</p>
      <ul class="mega-menu__products-list" role="list">
        {%- for product in featured_collection.products limit: 3 -%}
          <li>
            <a href="{{ product.url }}" class="mega-menu__product">
              <span class="mega-menu__product-img aspect aspect--1/1">
                {%- render 'responsive-image',
                  image: product.featured_image,
                  alt: product.title,
                  sizes: '64px',
                  loading: 'lazy'
                -%}
              </span>
              <span class="mega-menu__product-body">
                <span class="mega-menu__product-title">{{ product.title }}</span>
                <span class="mega-menu__product-price">{{ product.price | money }}</span>
              </span>
            </a>
          </li>
        {%- endfor -%}
      </ul>
      <a href="{{ featured_collection.url }}" class="mega-menu__view-all">
        {{ 'general.view_all' | t }} {%- render 'icon', name: 'arrow-right', class: 'icon icon--xs' -%}
      </a>
    </div>
  {%- endif -%}
</div>

<style>
  .mega-menu{
    position:absolute;left:50%;top:100%;transform:translate(-50%, 4px);
    width:min(1100px, calc(100vw - 2 * var(--gutter)));
    background:var(--c-bg);color:var(--c-ink);
    border:1px solid var(--c-line);border-radius:var(--radius-lg);
    box-shadow:var(--shadow-2);
    padding:var(--s-6);
    display:grid;gap:var(--s-6);
    opacity:0;pointer-events:none;
    transition:opacity var(--dur-base) var(--ease-standard),
               transform var(--dur-base) var(--ease-standard);
    z-index:calc(var(--z-sticky) + 1);
  }
  .mega-menu--cols-1{grid-template-columns:1fr}
  .mega-menu--cols-2{grid-template-columns:1fr 280px}
  .mega-menu--cols-3{grid-template-columns:1fr 240px 240px}
  .mega-menu--cols-4{grid-template-columns:1fr 220px 220px 240px}
  .mega-menu__cols{
    display:grid;grid-template-columns:repeat(auto-fit, minmax(180px,1fr));
    gap:var(--s-6);
  }
  .mega-menu__group-title{
    display:block;
    font-size:var(--fs-12);font-weight:var(--weight-semibold);
    letter-spacing:.08em;text-transform:uppercase;
    color:var(--c-ink-muted);margin-bottom:var(--s-3);
  }
  .mega-menu__sub-list{display:flex;flex-direction:column;gap:var(--s-2);list-style:none;padding:0;margin:0}
  .mega-menu__sub-link{
    display:block;padding:var(--s-1) 0;
    font-size:var(--fs-14);color:var(--c-ink-muted);
    transition:color var(--dur-fast) var(--ease-soft);
  }
  .mega-menu__sub-link:hover{color:var(--c-ink)}

  .mega-menu__featured{display:block}
  .mega-menu__featured-img{border-radius:var(--radius-md);overflow:hidden;background:var(--c-elev)}
  .mega-menu__featured-body{margin-top:var(--s-3)}
  .mega-menu__featured-title{font-weight:var(--weight-semibold);font-size:var(--fs-14)}
  .mega-menu__featured-text{font-size:var(--fs-12);color:var(--c-ink-muted);margin-top:2px}

  .mega-menu__products-title{
    font-size:var(--fs-12);font-weight:var(--weight-semibold);
    letter-spacing:.08em;text-transform:uppercase;
    color:var(--c-ink-muted);margin-bottom:var(--s-3);
  }
  .mega-menu__products-list{display:flex;flex-direction:column;gap:var(--s-3);list-style:none;padding:0;margin:0 0 var(--s-3)}
  .mega-menu__product{display:flex;gap:var(--s-3);align-items:center}
  .mega-menu__product-img{
    width:56px;height:56px;border-radius:var(--radius-sm);
    overflow:hidden;background:var(--c-elev);flex-shrink:0;
  }
  .mega-menu__product-body{display:flex;flex-direction:column;gap:2px}
  .mega-menu__product-title{font-size:var(--fs-14);font-weight:var(--weight-medium)}
  .mega-menu__product-price{font-size:var(--fs-12);color:var(--c-ink-muted)}
  .mega-menu__view-all{
    display:inline-flex;align-items:center;gap:var(--s-1);
    font-size:var(--fs-14);font-weight:var(--weight-medium);
    color:var(--c-accent);
  }
  .mega-menu__view-all:hover{text-decoration:underline}
</style>

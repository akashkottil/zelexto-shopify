{%- comment -%}
  Zelexto v2 — breadcrumb.liquid
  Apple-style minimal breadcrumb. Home → Section → Page.
{%- endcomment -%}

<nav class="breadcrumb" aria-label="{{ 'general.breadcrumb' | t | default: 'Breadcrumb' }}">
  <ol class="breadcrumb__list" role="list">
    <li class="breadcrumb__item">
      <a href="{{ routes.root_url }}" class="breadcrumb__link">{{ 'general.home' | t | default: 'Home' }}</a>
    </li>

    {%- case template.name -%}
      {%- when 'collection' -%}
        <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">{{ collection.title }}</li>

      {%- when 'product' -%}
        {%- if collection -%}
          <li class="breadcrumb__item">
            <a href="{{ collection.url }}" class="breadcrumb__link">{{ collection.title }}</a>
          </li>
        {%- endif -%}
        <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">{{ product.title }}</li>

      {%- when 'article' -%}
        <li class="breadcrumb__item">
          <a href="{{ blog.url }}" class="breadcrumb__link">{{ blog.title }}</a>
        </li>
        <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">{{ article.title }}</li>

      {%- when 'blog' -%}
        <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">{{ blog.title }}</li>

      {%- when 'page' -%}
        <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">{{ page.title }}</li>

      {%- when 'search' -%}
        <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">{{ 'search.title' | t | default: 'Search' }}</li>

      {%- when 'cart' -%}
        <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">{{ 'cart.title' | t | default: 'Cart' }}</li>
    {%- endcase -%}
  </ol>
</nav>

{% comment %}
  ZELEXTO THEME — snippets/open-graph.liquid
  Open Graph, Twitter Card, and canonical meta tags.
  Rendered in <head> via theme.liquid.
{% endcomment %}

{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_description = page_description | default: shop.description | default: shop.name
  assign og_url = canonical_url

  case template.name
    when 'product'
      assign og_type = 'product'
      assign og_image = product.featured_image
    when 'article'
      assign og_type = 'article'
      assign og_image = article.image
    when 'collection'
      assign og_type = 'website'
      assign og_image = collection.image
    else
      assign og_type = 'website'
      assign og_image = settings.og_image
  endcase
-%}

<!-- Primary meta -->
<meta name="description" content="{{ og_description | strip_html | truncate: 160 | escape }}">
<meta name="author" content="{{ shop.name }}">

<!-- Open Graph -->
<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | strip_html | truncate: 70 | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | strip_html | truncate: 160 | escape }}">

{%- if og_image -%}
  <meta property="og:image" content="{{ og_image | image_url: width: 1200 }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="{{ og_image.height | times: 1200 | divided_by: og_image.width | round }}">
  <meta property="og:image:alt" content="{{ og_image.alt | escape | default: og_title }}">
{%- elsif settings.favicon -%}
  <meta property="og:image" content="{{ settings.favicon | image_url: width: 512 }}">
{%- endif -%}

<!-- Article-specific OG -->
{%- if template.name == 'article' -%}
  <meta property="article:published_time" content="{{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' }}">
  <meta property="article:author" content="{{ article.author }}">
  {%- if article.tags != blank -%}
    {%- for tag in article.tags -%}
      <meta property="article:tag" content="{{ tag }}">
    {%- endfor -%}
  {%- endif -%}
{%- endif -%}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | strip_html | truncate: 70 | escape }}">
<meta name="twitter:description" content="{{ og_description | strip_html | truncate: 160 | escape }}">
{%- if og_image -%}
  <meta name="twitter:image" content="{{ og_image | image_url: width: 1200 }}">
{%- endif -%}

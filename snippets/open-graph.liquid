{%- comment -%}
  Zelexto v2 — open-graph.liquid
  Open Graph + Twitter Card meta tags. Render in <head>.
{%- endcomment -%}

{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_description = page_description | default: shop.description | default: shop.name
  assign og_url = canonical_url
  case template.name
    when 'product'
      assign og_type = 'product'
      assign og_image = product.featured_image
    when 'article'
      assign og_type = 'article'
      assign og_image = article.image
    when 'collection'
      assign og_type = 'website'
      assign og_image = collection.image
    else
      assign og_type = 'website'
      assign og_image = settings.share_image
  endcase
-%}

<meta property="og:site_name" content="{{ shop.name | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:title" content="{{ og_title | strip_html | truncate: 90 | escape }}">
<meta property="og:description" content="{{ og_description | strip_html | truncate: 200 | escape }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:locale" content="{{ request.locale.iso_code | default: 'en' }}">

{%- if og_image -%}
  <meta property="og:image" content="https:{{ og_image | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="https:{{ og_image | image_url: width: 1200 }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="{{ og_image.height | times: 1200 | divided_by: og_image.width | round }}">
  <meta property="og:image:alt" content="{{ og_image.alt | escape | default: og_title }}">
{%- elsif settings.share_image -%}
  <meta property="og:image" content="https:{{ settings.share_image | image_url: width: 1200 }}">
{%- endif -%}

{%- if template.name == 'product' -%}
  <meta property="product:price:amount" content="{{ product.price | divided_by: 100.0 }}">
  <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
  <meta property="product:availability" content="{% if product.available %}in stock{% else %}out of stock{% endif %}">
  {%- if product.vendor != blank -%}
    <meta property="product:brand" content="{{ product.vendor | escape }}">
  {%- endif -%}
{%- endif -%}

{%- if template.name == 'article' -%}
  <meta property="article:published_time" content="{{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' }}">
  <meta property="article:modified_time" content="{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%SZ' }}">
  <meta property="article:author" content="{{ article.author | escape }}">
  {%- for tag in article.tags -%}
    <meta property="article:tag" content="{{ tag | escape }}">
  {%- endfor -%}
{%- endif -%}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | strip_html | truncate: 70 | escape }}">
<meta name="twitter:description" content="{{ og_description | strip_html | truncate: 200 | escape }}">
{%- if og_image -%}
  <meta name="twitter:image" content="https:{{ og_image | image_url: width: 1200 }}">
  <meta name="twitter:image:alt" content="{{ og_image.alt | escape | default: og_title }}">
{%- endif -%}
{%- if settings.twitter_handle != blank -%}
  <meta name="twitter:site" content="@{{ settings.twitter_handle | remove: '@' }}">
{%- endif -%}

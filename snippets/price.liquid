{%- comment -%}
  Zelexto v2 — price.liquid
  Apple-style price block. Renders compare-at strikethrough, sale badge,
  sold-out state. Wraps money in [data-money-cents] so Agent C's INR formatter
  can post-process via inr-format.js.

  Accepts:
    product       — product object
    variant       — optional, defaults to selected_or_first_available_variant
    show_badge    — default true; hide for compact card use
    show_compare  — default true
    class         — extra css class
    use_variant   — true to always render variant price even if it varies
{%- endcomment -%}

{%- liquid
  assign target = variant | default: product.selected_or_first_available_variant
  assign current = target.price
  assign compare = target.compare_at_price
  assign price_varies = product.price_varies
  assign on_sale = false
  if compare and compare > current
    assign on_sale = true
    assign savings_pct = compare | minus: current | times: 100 | divided_by: compare | round
  endif
  assign sold_out = false
  if target.available == false
    assign sold_out = true
  endif
  assign show_badge_attr = show_badge
  if show_badge_attr == nil
    assign show_badge_attr = true
  endif
  assign show_compare_attr = show_compare
  if show_compare_attr == nil
    assign show_compare_attr = true
  endif
  assign extra_class = class | default: ''
-%}

<div class="price{% if on_sale %} price--on-sale{% endif %}{% if sold_out %} price--sold-out{% endif %} {{ extra_class }}">
  <div class="price__values">
    {%- if price_varies and variant == nil and use_variant != true -%}
      <span class="price__from">{{ 'product.from' | t | default: 'From' }}</span>
    {%- endif -%}

    <span
      class="price__current"
      data-money-cents="{{ current }}"
      data-currency="{{ cart.currency.iso_code }}">
      {{ current | money }}
    </span>

    {%- if on_sale and show_compare_attr -%}
      <s class="price__compare" data-money-cents="{{ compare }}" aria-label="{{ 'product.compare_at_price' | t | default: 'Original price' }}">
        {{ compare | money }}
      </s>
    {%- endif -%}

    {%- if sold_out -%}
      <span class="price__sold-out">{{ 'product.sold_out' | t }}</span>
    {%- endif -%}
  </div>

  {%- if on_sale and show_badge_attr -%}
    <span class="price__badge" aria-label="{{ 'product.on_sale' | t | default: 'Sale' }}">
      &minus;{{ savings_pct }}%
    </span>
  {%- endif -%}
</div>

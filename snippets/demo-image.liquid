{%- comment -%}
  Demo / placeholder image — visually rich black & white SVG used when a
  merchant has not yet uploaded an image. Falls through to Shopify's built-in
  placeholder if the requested kind isn't recognised.

  Usage:
    {% render 'demo-image', kind: 'hero',     class: 'hero__image' %}
    {% render 'demo-image', kind: 'lifestyle', class: 'feature__image' %}
    {% render 'demo-image', kind: 'product',  class: 'card__image' %}
    {% render 'demo-image', kind: 'collection' %}
    {% render 'demo-image', kind: 'avatar' %}

  All variants are pure ink/bg with zero colour, scalable, and CLS-safe via
  preserveAspectRatio + viewBox. Decorative — `aria-hidden="true"`.
{%- endcomment -%}

{%- liquid
  assign css_class = class | default: ''
  assign demo_kind = kind | default: 'lifestyle'
-%}

{%- case demo_kind -%}
{%- when 'hero' -%}
<svg class="demo-image demo-image--hero {{ css_class }}" viewBox="0 0 1600 900" preserveAspectRatio="xMidYMid slice" role="img" aria-hidden="true">
  <defs>
    <linearGradient id="demo-hero-bg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#1d1d1f"/>
      <stop offset="100%" stop-color="#000000"/>
    </linearGradient>
    <radialGradient id="demo-hero-spot" cx="50%" cy="55%" r="40%">
      <stop offset="0%" stop-color="#f5f5f7" stop-opacity="0.18"/>
      <stop offset="100%" stop-color="#000" stop-opacity="0"/>
    </radialGradient>
  </defs>
  <rect width="1600" height="900" fill="url(#demo-hero-bg)"/>
  <rect width="1600" height="900" fill="url(#demo-hero-spot)"/>
  <g opacity="0.06" fill="#ffffff">
    <circle cx="800" cy="520" r="280"/>
  </g>
  <g opacity="0.85">
    <rect x="700" y="380" width="200" height="200" rx="40" fill="#1d1d1f" stroke="#3a3a3c" stroke-width="1.5"/>
    <rect x="730" y="410" width="140" height="140" rx="28" fill="#000"/>
    <circle cx="800" cy="480" r="32" fill="#1d1d1f" stroke="#48484a" stroke-width="1"/>
  </g>
</svg>

{%- when 'lifestyle' -%}
<svg class="demo-image demo-image--lifestyle {{ css_class }}" viewBox="0 0 1200 1500" preserveAspectRatio="xMidYMid slice" role="img" aria-hidden="true">
  <defs>
    <linearGradient id="demo-life-bg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#f5f5f7"/>
      <stop offset="100%" stop-color="#d2d2d7"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="1500" fill="url(#demo-life-bg)"/>
  <g fill="#1d1d1f">
    <circle cx="600" cy="650" r="220" opacity="0.92"/>
    <ellipse cx="600" cy="970" rx="280" ry="44" opacity="0.18"/>
  </g>
  <g fill="#86868b" opacity="0.4">
    <path d="M0 1200 Q 300 1140 600 1190 T 1200 1180 V1500 H0 Z"/>
  </g>
  <g fill="#ffffff" opacity="0.8">
    <circle cx="540" cy="600" r="38"/>
  </g>
</svg>

{%- when 'product' -%}
<svg class="demo-image demo-image--product {{ css_class }}" viewBox="0 0 1000 1000" preserveAspectRatio="xMidYMid meet" role="img" aria-hidden="true">
  <rect width="1000" height="1000" fill="#f5f5f7"/>
  <g transform="translate(500 540)">
    <circle r="280" fill="#1d1d1f"/>
    <circle r="280" fill="url(#demo-prod-shine)"/>
    <ellipse cx="0" cy="290" rx="260" ry="22" fill="#000" opacity="0.2"/>
  </g>
  <defs>
    <radialGradient id="demo-prod-shine" cx="40%" cy="32%" r="55%">
      <stop offset="0%" stop-color="#ffffff" stop-opacity="0.35"/>
      <stop offset="60%" stop-color="#ffffff" stop-opacity="0"/>
    </radialGradient>
  </defs>
</svg>

{%- when 'collection' -%}
<svg class="demo-image demo-image--collection {{ css_class }}" viewBox="0 0 800 1000" preserveAspectRatio="xMidYMid slice" role="img" aria-hidden="true">
  <rect width="800" height="1000" fill="#1d1d1f"/>
  <g fill="#f5f5f7" opacity="0.06">
    <rect x="0" y="0" width="800" height="1"/>
    <rect x="0" y="999" width="800" height="1"/>
  </g>
  <g transform="translate(400 540)">
    <rect x="-140" y="-140" width="280" height="280" rx="20" fill="#2c2c2e"/>
    <rect x="-110" y="-110" width="220" height="220" rx="14" fill="#3a3a3c"/>
    <rect x="-80" y="-80" width="160" height="160" rx="8" fill="#48484a"/>
  </g>
</svg>

{%- when 'avatar' -%}
<svg class="demo-image demo-image--avatar {{ css_class }}" viewBox="0 0 80 80" preserveAspectRatio="xMidYMid meet" role="img" aria-hidden="true">
  <circle cx="40" cy="40" r="40" fill="#e8e8ed"/>
  <circle cx="40" cy="33" r="14" fill="#86868b"/>
  <path d="M14 70 Q 14 50 40 50 Q 66 50 66 70 Z" fill="#86868b"/>
</svg>

{%- when 'logo' -%}
<svg class="demo-image demo-image--logo {{ css_class }}" viewBox="0 0 200 60" preserveAspectRatio="xMidYMid meet" role="img" aria-hidden="true">
  <rect width="200" height="60" fill="transparent"/>
  <g fill="#86868b">
    <rect x="20" y="22" width="40" height="16" rx="4"/>
    <text x="74" y="38" font-family="-apple-system,BlinkMacSystemFont,'Inter',sans-serif" font-size="16" font-weight="600">Demo brand</text>
  </g>
</svg>

{%- else -%}
{{ 'lifestyle-1' | placeholder_svg_tag: css_class }}
{%- endcase -%}

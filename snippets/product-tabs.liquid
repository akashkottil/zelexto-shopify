{%- comment -%}
  Zelexto v2 — product-tabs.liquid
  Apple-style accordion using <details>/<summary>. Supports description,
  shipping/returns, size_guide, custom_text, metafield, app blocks.

  Accepts:
    product — required
    section — section context for blocks
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}
  <div class="product-tabs">
    {%- for block in section.blocks -%}
      {%- case block.type -%}

        {%- when 'description' -%}
          <details class="product-tabs__item" {{ block.shopify_attributes }} {% if forloop.first %}open{% endif %}>
            <summary class="product-tabs__summary">
              <span>{{ block.settings.tab_label | default: 'Description' }}</span>
              {% render 'icon', name: 'chevron-down', class: 'product-tabs__chevron' %}
            </summary>
            <div class="product-tabs__panel rte">{{ product.description }}</div>
          </details>

        {%- when 'shipping' -%}
          <details class="product-tabs__item" {{ block.shopify_attributes }}>
            <summary class="product-tabs__summary">
              <span>{{ block.settings.tab_label | default: 'Shipping' }}</span>
              {% render 'icon', name: 'chevron-down', class: 'product-tabs__chevron' %}
            </summary>
            <div class="product-tabs__panel rte">
              {% if block.settings.content != blank %}{{ block.settings.content }}{% else %}<p>{{ 'product.shipping_default' | t | default: 'Free shipping on prepaid orders.' }}</p>{% endif %}
            </div>
          </details>

        {%- when 'returns' -%}
          <details class="product-tabs__item" {{ block.shopify_attributes }}>
            <summary class="product-tabs__summary">
              <span>{{ block.settings.tab_label | default: 'Returns' }}</span>
              {% render 'icon', name: 'chevron-down', class: 'product-tabs__chevron' %}
            </summary>
            <div class="product-tabs__panel rte">
              {% if block.settings.content != blank %}{{ block.settings.content }}{% else %}<p>{{ 'product.returns_default' | t | default: '7-day easy returns.' }}</p>{% endif %}
            </div>
          </details>

        {%- when 'size_guide' -%}
          <details class="product-tabs__item" {{ block.shopify_attributes }}>
            <summary class="product-tabs__summary">
              <span>{{ block.settings.tab_label | default: 'Size guide' }}</span>
              {% render 'icon', name: 'chevron-down', class: 'product-tabs__chevron' %}
            </summary>
            <div class="product-tabs__panel rte">{{ block.settings.content }}</div>
          </details>

        {%- when 'custom' -%}
          <details class="product-tabs__item" {{ block.shopify_attributes }}>
            <summary class="product-tabs__summary">
              <span>{{ block.settings.tab_label | default: 'Details' }}</span>
              {% render 'icon', name: 'chevron-down', class: 'product-tabs__chevron' %}
            </summary>
            <div class="product-tabs__panel rte">{{ block.settings.content }}</div>
          </details>

        {%- when 'metafield' -%}
          {%- assign mf = product.metafields[block.settings.namespace][block.settings.key] -%}
          {%- if mf != blank -%}
            <details class="product-tabs__item" {{ block.shopify_attributes }}>
              <summary class="product-tabs__summary">
                <span>{{ block.settings.tab_label | default: block.settings.key }}</span>
                {% render 'icon', name: 'chevron-down', class: 'product-tabs__chevron' %}
              </summary>
              <div class="product-tabs__panel rte">{{ mf }}</div>
            </details>
          {%- endif -%}

        {%- when '@app' -%}
          <details class="product-tabs__item product-tabs__item--app" {{ block.shopify_attributes }}>
            <summary class="product-tabs__summary">
              <span>{{ 'product.more_info' | t | default: 'More info' }}</span>
              {% render 'icon', name: 'chevron-down', class: 'product-tabs__chevron' %}
            </summary>
            <div class="product-tabs__panel">{% render block %}</div>
          </details>

      {%- endcase -%}
    {%- endfor -%}
  </div>
{%- endif -%}
